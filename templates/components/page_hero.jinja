<section class="relative overflow-hidden bg-brand-900 py-20 text-white sm:py-24">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-800 via-brand-900 to-ink-900"></div>
    <div class="absolute -right-20 top-0 h-80 w-80 rounded-full bg-gold-500/10 blur-3xl"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        {% if hero_eyebrow %}
        <span class="eyebrow !text-gold-300 before:!bg-gold-400">{{ hero_eyebrow }}</span>
        {% endif %}
        <h1 class="mt-6 max-w-3xl font-display text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl">{{ hero_title }}</h1>
        {% if hero_text %}
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-slate-300">{{ hero_text }}</p>
        {% endif %}
    </div>
</section>
