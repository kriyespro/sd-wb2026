<script>
/* Global broken-image fallback (skips logo / already-handled imgs) */
document.addEventListener('error', function (e) {
  var t = e.target;
  if (!t || t.tagName !== 'IMG' || t.dataset.fallbackApplied) return;
  if (t.getAttribute('onerror')) return;
  t.dataset.fallbackApplied = '1';
  t.src = '{{ static("img/placeholder.svg") }}';
  t.classList.add('object-contain', 'bg-ink-900');
}, true);
</script>
