{% set nav_groups = [
    {'label': 'Home', 'url': 'website:home'},
    {'label': 'Services', 'url': 'website:services'},
    {'label': 'Work', 'children': [
        {'label': 'Our Work', 'url': 'website:our_work'},
        {'label': 'Case Studies', 'url': 'website:case_studies'}
    ]},
    {'label': 'Academy', 'url': 'academy:courses'},
    {'label': 'Team', 'url': 'website:team'},
    {'label': 'Company', 'children': [
        {'label': 'About', 'url': 'website:about'},
        {'label': 'Industries', 'url': 'website:industries'},
        {'label': 'Careers', 'url': 'website:careers'},
        {'label': 'Pricing', 'url': 'website:pricing'}
    ]},
] %}

<header x-data="{ open: false, scrolled: false }"
        @scroll.window="scrolled = window.pageYOffset > 20"
        class="fixed inset-x-0 top-0 z-50 bg-white transition-shadow"
        :class="scrolled ? 'shadow-[0_2px_40px_rgba(6,18,43,0.08)]' : ''">
    <div class="mx-auto flex h-[76px] max-w-7xl items-center justify-between gap-6 px-4 sm:px-6 lg:px-8">
        <a href="{{ url('website:home') }}" class="flex shrink-0 items-center gap-3">
            <img src="{{ static('img/logo.png') }}" alt="{{ site_name }}" class="h-8 w-auto sm:h-9">
        </a>

        <nav class="hidden items-center gap-7 lg:flex">
            {% for group in nav_groups %}
                {% if group.children %}
                <div x-data="{ o: false }" @mouseenter="o = true" @mouseleave="o = false" class="relative">
                    <button @click="o = !o" class="flex items-center gap-1 text-[15px] font-medium text-slate-600 transition hover:text-ink-900">
                        {{ group.label }}
                        <svg class="h-3.5 w-3.5 transition" :class="o ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div x-show="o" x-cloak x-transition class="absolute left-0 top-full w-52 pt-3">
                        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white py-2 shadow-2xl">
                            {% for child in group.children %}
                            <a href="{{ url(child.url) }}" class="block px-5 py-2.5 text-sm text-slate-600 transition hover:bg-slate-50 hover:text-brand-600">{{ child.label }}</a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
                {% else %}
                <a href="{{ url(group.url) }}" class="text-[15px] font-medium text-slate-600 transition hover:text-ink-900">{{ group.label }}</a>
                {% endif %}
            {% endfor %}
        </nav>

        <div class="hidden items-center gap-5 lg:flex">
            {% if contact_info is defined and contact_info.phone %}
            <a href="tel:{{ contact_info.phone|replace(' ', '') }}" class="flex items-center gap-2 text-sm text-slate-600 transition hover:text-brand-600">
                <svg class="h-4 w-4 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                {{ contact_info.phone }}
            </a>
            {% endif %}
            {% if user.is_authenticated %}
            <a href="{{ url('users:dashboard_redirect') }}" class="text-sm font-medium text-slate-600 hover:text-brand-600">Dashboard</a>
            {% else %}
            <a href="{{ url('users:login') }}" class="text-sm font-medium text-slate-600 hover:text-brand-600">Login</a>
            {% endif %}
            <a href="{{ url('website:contact') }}" class="btn-primary !px-6 !py-3">Get a Quote →</a>
        </div>

        <button @click="open = !open" class="rounded-lg p-2 text-ink-900 lg:hidden" aria-label="Menu">
            <svg x-show="!open" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            <svg x-show="open" x-cloak class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>

    <div x-show="open" x-cloak x-transition class="border-t border-slate-200 bg-white px-4 py-4 shadow-lg lg:hidden">
        <nav class="flex flex-col gap-1">
            {% for group in nav_groups %}
                {% if group.children %}
                <p class="px-3 pb-1 pt-3 text-[11px] font-semibold uppercase tracking-widest text-slate-400">{{ group.label }}</p>
                {% for child in group.children %}
                <a href="{{ url(child.url) }}" class="rounded-lg px-3 py-2.5 text-sm text-slate-700 hover:bg-slate-50">{{ child.label }}</a>
                {% endfor %}
                {% else %}
                <a href="{{ url(group.url) }}" class="rounded-lg px-3 py-2.5 text-sm text-slate-700 hover:bg-slate-50">{{ group.label }}</a>
                {% endif %}
            {% endfor %}
            <a href="{{ url('website:contact') }}" class="btn-primary mt-3 text-center">Get a Quote →</a>
        </nav>
    </div>
</header>
<div class="h-[76px]"></div>
