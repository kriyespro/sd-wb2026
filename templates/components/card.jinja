<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-brand-200 hover:shadow-md {{ extra_class|default('') }}">
    {% if icon %}
    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-2xl">{{ icon }}</div>
    {% endif %}
    {% if category %}
    <span class="inline-block rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">{{ category }}</span>
    {% endif %}
    {% if title %}
    <h3 class="mt-4 font-display text-lg font-semibold text-ink-900">{{ title }}</h3>
    {% endif %}
    {% if desc %}
    <p class="mt-2 text-sm leading-relaxed text-slate-600">{{ desc }}</p>
    {% endif %}
    {% if result %}
    <p class="mt-3 font-display text-sm font-bold text-brand-600">{{ result }}</p>
    {% endif %}
    {% block card_body %}{% endblock %}
</div>
