{% if paginator_page.has_other_pages() %}
<div class="mt-6 flex items-center justify-between border-t border-slate-200 pt-4 text-sm text-slate-600">
    <span>Page {{ paginator_page.number }} of {{ paginator_page.paginator.num_pages }} · {{ paginator_page.paginator.count }} total</span>
    <div class="flex gap-2">
        {% if paginator_page.has_previous() %}
        <a href="?page={{ paginator_page.previous_page_number() }}" class="rounded-lg border border-slate-200 px-3 py-1.5 hover:bg-slate-50">Previous</a>
        {% endif %}
        {% if paginator_page.has_next() %}
        <a href="?page={{ paginator_page.next_page_number() }}" class="rounded-lg border border-slate-200 px-3 py-1.5 hover:bg-slate-50">Next</a>
        {% endif %}
    </div>
</div>
{% endif %}
