<footer class="bg-ink-900 text-slate-300">
    <div class="border-b border-white/10 bg-brand-800">
        <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-6 px-4 py-12 sm:px-6 md:flex-row lg:px-8">
            <div>
                <h3 class="font-display text-2xl font-bold text-white sm:text-3xl">Ready to start selling directly?</h3>
                <p class="mt-2 text-sm text-slate-400">Book a free consultation — store, ads, and prepaid orders for your factory.</p>
            </div>
            <a href="{{ url('website:contact') }}" class="btn-gold shrink-0">Book Free Consultation →</a>
        </div>
    </div>

    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
        <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
            <div class="lg:col-span-2">
                <img src="{{ static('img/logo.png') }}" alt="{{ site_name }}" class="h-9 w-auto">
                <p class="mt-5 max-w-md text-sm leading-relaxed text-slate-400">
                    {{ site_tagline }}. We help textile manufacturers set up their online store, run ads,
                    manage logistics, and get real prepaid orders — with an Academy that keeps delivery sharp.
                </p>
                {% if contact_info is defined %}
                <div class="mt-6 space-y-2 text-sm">
                    {% if contact_info.address %}
                    <p class="flex items-start gap-2">
                        <span class="mt-0.5 text-gold-400">📍</span>
                        <span>{{ contact_info.address }}</span>
                    </p>
                    {% endif %}
                    {% if contact_info.phone %}
                    <p class="flex items-center gap-2">
                        <span class="text-gold-400">📞</span>
                        <a href="tel:{{ contact_info.phone|replace(' ', '') }}" class="transition hover:text-white">{{ contact_info.phone }}</a>
                    </p>
                    {% endif %}
                    {% if contact_info.email %}
                    <p class="flex items-center gap-2"><span class="text-gold-400">✉️</span> {{ contact_info.email }}</p>
                    {% endif %}
                </div>
                {% endif %}
            </div>
            <div>
                <h4 class="text-xs font-semibold uppercase tracking-widest text-gold-400">Company</h4>
                <ul class="mt-4 space-y-2.5 text-sm">
                    <li><a href="{{ url('website:about') }}" class="text-slate-400 transition hover:text-white">About</a></li>
                    <li><a href="{{ url('website:startup') }}" class="text-slate-400 transition hover:text-white">Startup Plan</a></li>
                    <li><a href="{{ url('website:team') }}" class="text-slate-400 transition hover:text-white">Our Team</a></li>
                    <li><a href="{{ url('website:careers') }}" class="text-slate-400 transition hover:text-white">Careers</a></li>
                    <li><a href="{{ url('partners_public:landing') }}" class="text-slate-400 transition hover:text-white">Join as DGC</a></li>
                    <li><a href="{{ url('website:contact') }}" class="text-slate-400 transition hover:text-white">Contact</a></li>
                    <li><a href="{{ url('academy:courses') }}" class="text-slate-400 transition hover:text-white">Academy</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-xs font-semibold uppercase tracking-widest text-gold-400">Services</h4>
                <ul class="mt-4 space-y-2.5 text-sm">
                    <li><a href="{{ url('website:services') }}" class="text-slate-400 transition hover:text-white">All Services</a></li>
                    <li><a href="{{ url('website:case_studies') }}" class="text-slate-400 transition hover:text-white">Case Studies</a></li>
                    <li><a href="{{ url('website:pricing') }}" class="text-slate-400 transition hover:text-white">Pricing</a></li>
                    <li><a href="{{ url('website:industries') }}" class="text-slate-400 transition hover:text-white">Industries</a></li>
                </ul>
            </div>
        </div>

        <div class="mt-14 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 text-sm text-slate-500 sm:flex-row">
            <span>© {{ site_name }}. All rights reserved.</span>
            <span class="flex items-center gap-2">
                <span class="h-1.5 w-1.5 rounded-full bg-gold-500"></span>
                Building growth, one blueprint at a time.
            </span>
        </div>
    </div>
</footer>
