{% if href %}
<a href="{{ href }}" class="dash-stat group block">
{% else %}
<div class="dash-stat">
{% endif %}
    <p class="text-sm font-medium text-slate-500">{{ label }}</p>
    <p class="mt-2 font-display text-3xl font-bold {{ value_color|default('text-ink-900') }}">{{ value }}</p>
    {% if hint %}
    <p class="mt-1 text-xs text-slate-400">{{ hint }}</p>
    {% endif %}
{% if href %}
</a>
{% else %}
</div>
{% endif %}
