{% macro kpi(href, label, value, meta, accent='text-ink-900') %}
<a href="{{ href }}"
   class="group relative overflow-hidden rounded-2xl border border-slate-200/80 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-md sm:p-5">
    <p class="text-[10px] font-bold uppercase tracking-[0.14em] text-slate-500">{{ label }}</p>
    <p class="mt-2 font-display text-3xl font-bold tabular-nums tracking-tight {{ accent }} group-hover:text-brand-700 sm:text-4xl">{{ value }}</p>
    <p class="mt-1.5 truncate text-[11px] text-slate-400">{{ meta }}</p>
</a>
{% endmacro %}

{{ kpi(url('operations:leads'), 'Inbound new', stats.new_leads, stats.unassigned_leads ~ ' unassigned', 'text-emerald-700') }}
{{ kpi(url('operations:quality_check'), 'QA pending', stats.pending_deliverables, 'awaiting review', 'text-orange-600') }}
