{% if recent_dgc_applications %}
<ul class="divide-y divide-slate-100">
    {% for app in recent_dgc_applications %}
    <li class="flex min-w-0 items-center gap-2.5 py-2.5">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-cyan-50 font-display text-[11px] font-bold text-cyan-800">
            {{ app.name[:1]|upper }}
        </span>
        <div class="min-w-0 flex-1 overflow-hidden">
            <a href="{{ url('operations:dgc_applications') }}" class="block truncate text-[13px] font-semibold text-ink-900 hover:text-cyan-700">{{ app.name }}</a>
            <p class="truncate text-[10px] text-slate-500">{{ app.city or app.email }} · {{ app.get_status_display() }}</p>
        </div>
        <time class="shrink-0 text-[10px] font-semibold tabular-nums text-slate-400" title="{{ app.created_at.strftime('%d %b %Y, %H:%M') }}">{{ timeago(app.created_at) }}</time>
    </li>
    {% endfor %}
</ul>
{% else %}
<div class="flex h-full min-h-[10rem] items-center justify-center px-2">
    <p class="text-center text-[11px] text-slate-400">No partner applications waiting.</p>
</div>
{% endif %}
