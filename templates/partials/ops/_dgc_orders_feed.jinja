{% if recent_dgc_orders %}
<div class="ops-feed">
    {% for order in recent_dgc_orders %}
    <div class="ops-feed-row">
        <div class="ops-feed-main">
            <div class="flex min-w-0 items-center justify-between gap-2">
                <a href="{{ url('operations:dgc_orders') }}"
                   class="ops-feed-title hover:text-violet-700"
                   title="{{ order.offer.title }}">#{{ order.id }} · {{ order.offer.title }}</a>
                <time class="ops-feed-time" title="{{ order.created_at.strftime('%d %b %Y, %H:%M') }}">{{ timeago(order.created_at) }}</time>
            </div>
            <p class="ops-feed-meta">
                {{ order.partner.code }} · ₹{{ '{:,.0f}'.format(order.total) }} · ×{{ order.quantity }}
            </p>
            <div class="ops-feed-tags">
                <span class="ops-pill
                    {% if order.status == 'fulfilled' %}bg-emerald-50 text-emerald-700
                    {% elif order.status == 'cancelled' %}bg-slate-50 text-slate-500
                    {% elif order.status == 'confirmed' %}bg-sky-50 text-sky-700
                    {% else %}bg-amber-50 text-amber-700{% endif %}">
                    {{ order.get_status_display() }}
                </span>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="flex min-h-[7rem] items-center justify-center py-6">
    <p class="text-[11px] text-slate-400">No partner orders yet.</p>
</div>
{% endif %}
