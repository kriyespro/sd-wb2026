{% if recent_job_applications %}
<ul class="divide-y divide-slate-100">
    {% for app in recent_job_applications %}
    <li class="flex items-start gap-2.5 border-l-4 border-l-violet-400 py-2.5 pl-2.5">
        <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-1.5">
                <a href="{{ url('operations:job_applications') }}#job-app-{{ app.id }}"
                   class="truncate text-sm font-semibold text-ink-900 hover:text-violet-700">
                    {{ app.name }}
                </a>
                <span class="inline-flex rounded-full px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wide
                    {% if app.status == 'new' %}bg-violet-100 text-violet-800
                    {% elif app.status == 'hired' %}bg-emerald-100 text-emerald-800
                    {% elif app.status == 'rejected' %}bg-slate-100 text-slate-600
                    {% elif app.status == 'interview' %}bg-amber-100 text-amber-800
                    {% else %}bg-sky-100 text-sky-800{% endif %}">
                    {{ app.get_status_display() }}
                </span>
            </div>
            <p class="mt-0.5 truncate text-[11px] text-slate-500">{{ app.role }} · {{ app.get_application_type_display() }}</p>
        </div>
        <time class="shrink-0 text-[10px] font-medium text-slate-400">{{ timesince(app.created_at) }}</time>
    </li>
    {% endfor %}
</ul>
{% else %}
<p class="py-6 text-center text-xs text-slate-500">No job applications yet.</p>
{% endif %}
