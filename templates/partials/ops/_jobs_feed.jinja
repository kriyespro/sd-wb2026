{% if recent_job_applications %}
<div class="ops-feed">
    {% for app in recent_job_applications %}
    <div class="ops-feed-row">
        <div class="ops-feed-main">
            <div class="flex min-w-0 items-center gap-1.5">
                <a href="{{ url('operations:job_applications') }}#job-app-{{ app.id }}"
                   class="ops-feed-title min-w-0 hover:text-violet-700"
                   title="{{ app.name }}">{{ app.name }}</a>
                <span class="ops-pill
                    {% if app.status == 'new' %}bg-violet-50 text-violet-700
                    {% elif app.status == 'hired' %}bg-emerald-50 text-emerald-700
                    {% elif app.status == 'rejected' %}bg-slate-50 text-slate-500
                    {% elif app.status == 'interview' %}bg-amber-50 text-amber-700
                    {% else %}bg-sky-50 text-sky-700{% endif %}">
                    {{ app.get_status_display() }}
                </span>
            </div>
            <p class="ops-feed-meta" title="{{ app.role }}">{{ app.role }} · {{ app.get_application_type_display() }}</p>
        </div>
        <time class="ops-feed-time" title="{{ app.created_at.strftime('%d %b %Y, %H:%M') }}">{{ timeago(app.created_at) }}</time>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="flex h-full min-h-[8rem] items-center justify-center">
    <p class="text-[11px] text-slate-400">No job applications yet.</p>
</div>
{% endif %}
