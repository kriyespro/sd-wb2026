{% if recent_applications %}
<ul class="divide-y divide-slate-100">
    {% for app in recent_applications %}
    <li class="flex items-center justify-between gap-2 border-l-4 border-l-brand-500 py-2.5 pl-2.5">
        <div class="min-w-0">
            <p class="truncate text-sm font-semibold text-ink-900">{{ app.name }}</p>
            <p class="truncate text-[11px] text-slate-500">{{ app.course_interest or 'General application' }}</p>
        </div>
        <time class="shrink-0 text-[10px] font-medium text-slate-400">{{ timesince(app.created_at) }}</time>
    </li>
    {% endfor %}
</ul>
{% else %}
<p class="py-5 text-center text-xs text-slate-500">No new academy applications.</p>
{% endif %}
