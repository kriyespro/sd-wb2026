{% if recent_applications %}
<div class="ops-feed">
    {% for app in recent_applications %}
    <div class="ops-feed-row">
        <div class="ops-feed-main">
            <div class="flex min-w-0 items-baseline justify-between gap-2">
                <p class="ops-feed-title" title="{{ app.name }}">{{ app.name }}</p>
                <time class="ops-feed-time" title="{{ app.created_at.strftime('%d %b %Y, %H:%M') }}">{{ timeago(app.created_at) }}</time>
            </div>
            <p class="ops-feed-meta" title="{{ app.course_interest or 'General application' }}">
                {{ app.course_interest or 'General application' }}
            </p>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="flex h-full min-h-[8rem] items-center justify-center">
    <p class="text-[11px] text-slate-400">No new academy applications.</p>
</div>
{% endif %}
