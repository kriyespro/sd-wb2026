<tr id="dgc-lead-{{ lead.id }}" class="align-top transition hover:bg-slate-50/80">
    <td class="px-4 py-4">
        <p class="font-semibold text-ink-900">{{ lead.name }}</p>
        <p class="text-xs text-slate-500">{{ lead.phone }}</p>
        {% if lead.email %}
        <a href="mailto:{{ lead.email }}" class="text-xs text-brand-600 hover:underline">{{ lead.email }}</a>
        {% endif %}
    </td>
    <td class="px-4 py-4">
        {% if lead.company %}<p class="font-medium text-slate-800">{{ lead.company }}</p>{% endif %}
        <p class="text-xs text-slate-500">{{ lead.interest or 'General' }}</p>
    </td>
    <td class="px-4 py-4 font-medium text-ink-900">₹{{ lead.deal_value }}</td>
    <td class="px-4 py-4">
        <p class="font-semibold text-violet-800">{{ lead.partner.code }}</p>
        <p class="text-xs text-slate-500">{{ lead.partner.user.get_full_name() or lead.partner.user.username }}</p>
    </td>
    <td class="px-4 py-4 whitespace-nowrap text-xs text-slate-500">
        <p class="font-medium text-slate-700">{{ lead.created_at.strftime('%d %b %Y') }}</p>
        <p>{{ lead.created_at.strftime('%H:%M') }}</p>
    </td>
    <td class="px-4 py-4 max-w-xs">
        {% if lead.notes %}
        <details class="text-xs text-slate-600">
            <summary class="cursor-pointer font-medium text-brand-600">View</summary>
            <p class="mt-2 whitespace-pre-wrap rounded-xl border border-slate-100 bg-slate-50 p-2">{{ lead.notes }}</p>
        </details>
        {% else %}
        <span class="text-xs text-slate-400">—</span>
        {% endif %}
    </td>
    <td class="px-4 py-4">
        <form hx-post="{{ url('operations:dgc_lead_status', kwargs={'pk': lead.id}) }}"
              hx-target="#dgc-lead-{{ lead.id }}"
              hx-swap="outerHTML"
              class="min-w-[9rem]">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <select name="status"
                    class="ops-select text-xs font-semibold
                    {% if lead.status == 'won' %}border-emerald-300 bg-emerald-50 text-emerald-900
                    {% elif lead.status == 'lost' %}border-slate-300 bg-slate-50 text-slate-600
                    {% elif lead.status == 'contacted' %}border-sky-300 bg-sky-50 text-sky-900
                    {% else %}border-amber-300 bg-amber-50 text-amber-900{% endif %}"
                    onchange="htmx.trigger(this.form, 'submit')">
                {% for value, label in status_choices %}
                <option value="{{ value }}" {% if lead.status == value %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
        </form>
    </td>
</tr>
