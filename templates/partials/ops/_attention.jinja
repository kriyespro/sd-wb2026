{% set tone_map = {
    'emerald': 'border-emerald-200 bg-emerald-50 text-emerald-800 hover:bg-emerald-100',
    'amber': 'border-amber-200 bg-amber-50 text-amber-800 hover:bg-amber-100',
    'orange': 'border-orange-200 bg-orange-50 text-orange-800 hover:bg-orange-100',
    'rose': 'border-rose-200 bg-rose-50 text-rose-800 hover:bg-rose-100',
    'brand': 'border-sky-200 bg-sky-50 text-sky-800 hover:bg-sky-100',
    'violet': 'border-violet-200 bg-violet-50 text-violet-800 hover:bg-violet-100',
    'teal': 'border-teal-200 bg-teal-50 text-teal-800 hover:bg-teal-100',
} %}

{% if attention_items %}
<div class="flex max-w-full flex-wrap items-center gap-1">
    {% for item in attention_items[:4] %}
    <a href="{{ url(item.href_name) }}"
       class="inline-flex max-w-[10rem] items-center gap-1 truncate rounded-md border px-2 py-0.5 text-[10px] font-semibold transition {{ tone_map.get(item.tone, 'border-slate-200 bg-slate-50 text-slate-700 hover:bg-slate-100') }}">
        <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-current opacity-70"></span>
        <span class="truncate">{{ item.label }}</span>
    </a>
    {% endfor %}
    {% if attention_items|length > 4 %}
    <span class="rounded-md bg-slate-100 px-2 py-0.5 text-[10px] font-semibold text-slate-500">+{{ attention_items|length - 4 }}</span>
    {% endif %}
</div>
{% else %}
<p class="text-[10px] font-medium text-slate-400">All clear</p>
{% endif %}
