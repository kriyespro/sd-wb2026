{% set tone_map = {
    'emerald': 'border-emerald-300/40 bg-emerald-400/15 text-emerald-100',
    'amber': 'border-amber-300/40 bg-amber-400/15 text-amber-100',
    'orange': 'border-orange-300/40 bg-orange-400/15 text-orange-100',
    'rose': 'border-rose-300/40 bg-rose-400/15 text-rose-100',
    'brand': 'border-sky-300/40 bg-sky-400/15 text-sky-100',
    'violet': 'border-violet-300/40 bg-violet-400/15 text-violet-100',
    'teal': 'border-teal-300/40 bg-teal-400/15 text-teal-100',
} %}

{% if attention_items %}
<div class="flex flex-wrap gap-1.5">
    {% for item in attention_items %}
    <a href="{{ url(item.href_name) }}"
       class="inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-[11px] font-semibold transition hover:opacity-90 {{ tone_map.get(item.tone, 'border-white/20 bg-white/10 text-slate-200') }}">
        <span class="h-1.5 w-1.5 rounded-full bg-current"></span>
        {{ item.label }}
    </a>
    {% endfor %}
</div>
{% else %}
<p class="text-[11px] text-slate-400">All clear — no urgent items.</p>
{% endif %}
