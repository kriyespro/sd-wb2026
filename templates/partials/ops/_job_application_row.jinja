<tr id="job-app-{{ app.id }}" class="align-top transition hover:bg-slate-50/80">
    <td class="px-5 py-4">
        <div class="flex items-start gap-3">
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-violet-100 font-display text-xs font-bold text-violet-800">
                {{ app.name[:1]|upper }}
            </span>
            <div class="min-w-0">
                <p class="font-semibold text-ink-900">{{ app.name }}</p>
                <a href="mailto:{{ app.email }}" class="block truncate text-xs text-brand-600 hover:underline">{{ app.email }}</a>
                <p class="mt-0.5 text-xs text-slate-500">{{ app.phone }}</p>
            </div>
        </div>
    </td>
    <td class="px-4 py-4">
        <p class="max-w-[12rem] font-medium text-slate-800">{{ app.role }}</p>
    </td>
    <td class="px-4 py-4">
        <span class="rounded-full bg-slate-100 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-slate-600">
            {{ app.get_application_type_display() }}
        </span>
    </td>
    <td class="px-4 py-4 text-slate-600">
        {{ app.experience or '—' }}
    </td>
    <td class="px-4 py-4 text-xs">
        <div class="flex flex-col gap-1">
            {% if app.portfolio_url %}
            <a href="{{ app.portfolio_url }}" target="_blank" rel="noopener" class="font-medium text-brand-600 hover:underline">Portfolio</a>
            {% endif %}
            {% if app.linkedin_url %}
            <a href="{{ app.linkedin_url }}" target="_blank" rel="noopener" class="font-medium text-brand-600 hover:underline">LinkedIn</a>
            {% endif %}
            {% if not app.portfolio_url and not app.linkedin_url %}
            <span class="text-slate-400">—</span>
            {% endif %}
        </div>
    </td>
    <td class="px-4 py-4 whitespace-nowrap text-xs text-slate-500">
        <p class="font-medium text-slate-700">{{ app.created_at.strftime('%d %b %Y') }}</p>
        <p class="mt-0.5">{{ app.created_at.strftime('%H:%M') }}</p>
    </td>
    <td class="px-4 py-4">
        <form hx-post="{{ url('operations:job_application_status', kwargs={'pk': app.id}) }}"
              hx-target="#job-app-{{ app.id }}"
              hx-swap="outerHTML"
              class="min-w-[9.5rem]">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <select name="status"
                    class="ops-select text-xs font-semibold
                    {% if app.status == 'hired' %}border-emerald-300 bg-emerald-50 text-emerald-900
                    {% elif app.status == 'rejected' %}border-slate-300 bg-slate-50 text-slate-600
                    {% elif app.status == 'interview' %}border-amber-300 bg-amber-50 text-amber-900
                    {% elif app.status == 'review' %}border-sky-300 bg-sky-50 text-sky-900
                    {% elif app.status == 'new' %}border-violet-300 bg-violet-50 text-violet-900
                    {% else %}border-slate-200{% endif %}"
                    onchange="htmx.trigger(this.form, 'submit')">
                {% for value, label in status_choices %}
                <option value="{{ value }}" {% if app.status == value %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
        </form>
    </td>
    <td class="px-5 py-4 max-w-xs">
        <details class="group text-xs text-slate-600">
            <summary class="cursor-pointer list-none font-semibold text-brand-600 hover:text-brand-700">
                <span class="group-open:hidden">View letter →</span>
                <span class="hidden group-open:inline">Hide ↑</span>
            </summary>
            <p class="mt-2 rounded-xl border border-slate-100 bg-slate-50 p-3 whitespace-pre-wrap leading-relaxed text-slate-600">{{ app.cover_letter }}</p>
        </details>
    </td>
</tr>
