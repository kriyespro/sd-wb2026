{# KPI strip + pipeline in one panel — no floating uneven cards #}
{% macro cell(href, label, value, meta, accent='bg-brand-600', pulse=false) %}
<a href="{{ href }}"
   class="group relative flex min-w-0 flex-col justify-center gap-1 overflow-hidden px-3 py-3 transition hover:bg-slate-50/80 sm:px-4">
    <span class="absolute inset-y-2 left-0 w-0.5 rounded-full {{ accent }} opacity-80"></span>
    <div class="flex items-center gap-1.5 pl-2">
        <p class="truncate text-[10px] font-bold uppercase tracking-[0.1em] text-slate-500">{{ label }}</p>
        {% if pulse %}
        <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-500"></span>
        {% endif %}
    </div>
    <p class="pl-2 font-display text-2xl font-bold leading-none tabular-nums tracking-tight text-ink-900 group-hover:text-brand-700">{{ value }}</p>
    <p class="truncate pl-2 text-[10px] text-slate-500">{{ meta }}</p>
</a>
{% endmacro %}

<div class="overflow-hidden rounded-xl border border-slate-200/90 bg-white shadow-sm">
    <div class="grid grid-cols-2 divide-x divide-y divide-slate-100 sm:grid-cols-3 {% if include_jobs %}lg:grid-cols-5{% else %}lg:grid-cols-6{% endif %}">
        {{ cell(url('operations:leads'), 'Inbound', stats.new_leads, stats.unassigned_leads ~ ' unassigned · ' ~ stats.open_pipeline ~ ' open', 'bg-emerald-500', stats.new_leads > 0) }}
        {{ cell(url('operations:quality_check'), 'QA', stats.pending_deliverables, 'awaiting review', 'bg-orange-500', stats.pending_deliverables > 0) }}
        {{ cell(url('operations:projects'), 'Projects', stats.active_projects, stats.planning_projects ~ ' planning', 'bg-sky-500') }}
        {{ cell(url('operations:pipeline'), 'Academy', stats.new_applications, 'new admissions', 'bg-brand-600', stats.new_applications > 0) }}
        {{ cell(url('operations:invoices'), 'Billing', stats.overdue_invoices, stats.sent_invoices ~ ' sent · overdue', 'bg-rose-500', stats.overdue_invoices > 0) }}
        {% if include_jobs %}
        {{ cell(url('operations:job_applications'), 'Hiring', stats.new_job_applications, stats.job_interview ~ ' int · ' ~ stats.job_review ~ ' review', 'bg-violet-500', stats.new_job_applications > 0) }}
        {{ cell(url('operations:dgc_leads'), 'DGC leads', stats.new_dgc_leads, stats.open_dgc_leads ~ ' open · ' ~ stats.dgc_won_month ~ ' won/mo', 'bg-teal-500', stats.new_dgc_leads > 0) }}
        {{ cell(url('operations:dgc_applications'), 'DGC apps', stats.new_dgc_applications, stats.dgc_apps_review ~ ' in review', 'bg-cyan-500', stats.new_dgc_applications > 0) }}
        {{ cell(url('admin:partners_payoutrequest_changelist'), 'Payouts', stats.pending_payouts, 'pending', 'bg-amber-500', stats.pending_payouts > 0) }}
        {{ cell(url('operations:leads'), 'Week', stats.leads_week, 'inbound · 7 days', 'bg-slate-400') }}
        {% else %}
        {{ cell(url('operations:allocation'), 'Staffing', '→', 'assign team', 'bg-slate-400') }}
        {% endif %}
    </div>
    <div id="ops-pipeline-bar" class="border-t border-slate-100 bg-slate-50/50 px-3 py-2.5 sm:px-4">
        {% include "partials/ops/_pipeline_bar.jinja" %}
    </div>
</div>
