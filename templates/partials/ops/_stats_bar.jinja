<div class="grid grid-cols-2 gap-2 sm:grid-cols-3 {% if include_jobs %}xl:grid-cols-6{% else %}xl:grid-cols-5{% endif %}">
    <a href="{{ url('operations:leads') }}" class="rounded-xl border border-emerald-200 bg-emerald-50/70 px-3 py-2.5 shadow-sm transition hover:border-emerald-300 hover:shadow">
        <p class="text-[10px] font-bold uppercase tracking-wide text-emerald-700">New leads</p>
        <p class="mt-0.5 font-display text-2xl font-bold text-emerald-800">{{ stats.new_leads }}</p>
        <p class="text-[10px] text-emerald-800/70">{{ stats.unassigned_leads }} unassigned · {{ stats.leads_today }} today</p>
    </a>
    <a href="{{ url('operations:quality_check') }}" class="rounded-xl border border-orange-200 bg-orange-50/70 px-3 py-2.5 shadow-sm transition hover:border-orange-300 hover:shadow">
        <p class="text-[10px] font-bold uppercase tracking-wide text-orange-700">Pending QA</p>
        <p class="mt-0.5 font-display text-2xl font-bold text-orange-800">{{ stats.pending_deliverables }}</p>
        <p class="text-[10px] text-orange-800/70">deliverables waiting</p>
    </a>
    <a href="{{ url('operations:projects') }}" class="rounded-xl border border-sky-200 bg-sky-50/70 px-3 py-2.5 shadow-sm transition hover:border-sky-300 hover:shadow">
        <p class="text-[10px] font-bold uppercase tracking-wide text-sky-700">Projects</p>
        <p class="mt-0.5 font-display text-2xl font-bold text-sky-800">{{ stats.active_projects }}</p>
        <p class="text-[10px] text-sky-800/70">{{ stats.planning_projects }} planning · {{ stats.hot_leads }} hot</p>
    </a>
    <a href="{{ url('operations:pipeline') }}" class="rounded-xl border border-brand-200 bg-brand-50/70 px-3 py-2.5 shadow-sm transition hover:border-brand-300 hover:shadow">
        <p class="text-[10px] font-bold uppercase tracking-wide text-brand-700">Academy</p>
        <p class="mt-0.5 font-display text-2xl font-bold text-brand-800">{{ stats.new_applications }}</p>
        <p class="text-[10px] text-brand-800/70">new admissions</p>
    </a>
    <a href="{{ url('operations:invoices') }}" class="rounded-xl border border-rose-200 bg-rose-50/70 px-3 py-2.5 shadow-sm transition hover:border-rose-300 hover:shadow">
        <p class="text-[10px] font-bold uppercase tracking-wide text-rose-700">Billing</p>
        <p class="mt-0.5 font-display text-2xl font-bold text-rose-800">{{ stats.overdue_invoices }}</p>
        <p class="text-[10px] text-rose-800/70">overdue · {{ stats.sent_invoices }} sent</p>
    </a>
    {% if include_jobs %}
    <a href="{{ url('operations:job_applications') }}" class="rounded-xl border border-violet-200 bg-violet-50/70 px-3 py-2.5 shadow-sm transition hover:border-violet-300 hover:shadow">
        <p class="text-[10px] font-bold uppercase tracking-wide text-violet-700">Hiring</p>
        <p class="mt-0.5 font-display text-2xl font-bold text-violet-800">{{ stats.new_job_applications }}</p>
        <p class="text-[10px] text-violet-800/70">{{ stats.job_interview }} interview · {{ stats.job_review }} review</p>
    </a>
    {% endif %}
</div>
