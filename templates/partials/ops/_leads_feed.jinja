{% if recent_leads %}
<ul class="divide-y divide-slate-100">
    {% for lead in recent_leads %}
    <li class="flex items-start justify-between gap-3 py-3 first:pt-0 last:pb-0">
        <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2">
                <a href="{{ url('operations:leads') }}#lead-{{ lead.id }}" class="truncate font-medium text-ink-900 hover:text-brand-600">
                    {{ lead.name }}
                </a>
                {% include "partials/ops/_status_badge.jinja" %}
            </div>
            <p class="mt-0.5 truncate text-xs text-slate-500">
                {{ lead.email }}
                {% if lead.service_interest %}· {{ lead.service_interest }}{% endif %}
            </p>
            {% if lead.source_page %}
            <p class="mt-0.5 text-[10px] text-slate-400">via {{ lead.source_page }}</p>
            {% endif %}
        </div>
        <time class="shrink-0 text-[10px] text-slate-400" datetime="{{ lead.created_at.isoformat() }}">
            {{ lead.created_at.strftime('%H:%M') }}
        </time>
    </li>
    {% endfor %}
</ul>
{% else %}
<p class="py-6 text-center text-sm text-slate-500">No inbound leads yet. Public form submissions appear here instantly.</p>
{% endif %}
