{% set status_chip = {
    'new': 'bg-emerald-50 text-emerald-700',
    'contacted': 'bg-sky-50 text-sky-700',
    'qualified': 'bg-violet-50 text-violet-700',
    'proposal': 'bg-amber-50 text-amber-700',
    'won': 'bg-brand-50 text-brand-700',
    'lost': 'bg-slate-50 text-slate-500',
} %}

{% if recent_leads %}
<div class="ops-feed">
    {% for lead in recent_leads %}
    <div class="ops-feed-row">
        <div class="ops-feed-main">
            <div class="flex min-w-0 items-baseline justify-between gap-2">
                <a href="{{ url('operations:leads') }}#lead-{{ lead.id }}"
                   class="ops-feed-title hover:text-brand-600"
                   title="{{ lead.name }}">{{ lead.name }}</a>
                <time class="ops-feed-time" title="{{ lead.created_at.strftime('%d %b %Y, %H:%M') }}">{{ timeago(lead.created_at) }}</time>
            </div>
            <p class="ops-feed-meta" title="{{ lead.company or '' }} {{ lead.service_interest or 'General' }}">
                {% if lead.company %}{{ lead.company }} · {% endif %}{{ lead.service_interest or 'General' }}
            </p>
            <div class="mt-1 flex min-w-0 flex-wrap gap-1">
                <span class="ops-pill {{ status_chip.get(lead.status, 'bg-slate-50 text-slate-600') }}">
                    {{ lead.get_status_display() }}
                </span>
                {% if not lead.assigned_to_id and lead.status not in ['won', 'lost'] %}
                <span class="ops-pill bg-amber-50 text-amber-700">Unassigned</span>
                {% endif %}
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="flex h-full min-h-[8rem] items-center justify-center">
    <p class="text-[11px] text-slate-400">No inbound leads yet.</p>
</div>
{% endif %}
