{% if recent_leads %}
<ul class="divide-y divide-slate-100">
    {% for lead in recent_leads %}
    <li class="flex items-start gap-3 py-3.5 first:pt-0 last:pb-0">
        <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-brand-900 font-display text-xs font-bold text-gold-300">
            {{ lead.name[:1]|upper }}
        </span>
        <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2">
                <a href="{{ url('operations:leads') }}#lead-{{ lead.id }}"
                   class="truncate font-semibold text-ink-900 hover:text-brand-600">
                    {{ lead.name }}
                </a>
                {% include "partials/ops/_status_badge.jinja" %}
            </div>
            <p class="mt-0.5 truncate text-xs text-slate-500">
                {{ lead.email }}
                {% if lead.service_interest %} · {{ lead.service_interest }}{% endif %}
            </p>
            {% if lead.source_page %}
            <p class="mt-0.5 text-[10px] text-slate-400">via {{ lead.source_page }}</p>
            {% endif %}
        </div>
        <time class="shrink-0 rounded-lg bg-slate-50 px-2 py-1 text-[10px] font-medium text-slate-500"
              datetime="{{ lead.created_at.isoformat() }}">
            {{ lead.created_at.strftime('%H:%M') }}
        </time>
    </li>
    {% endfor %}
</ul>
{% else %}
<p class="py-8 text-center text-sm text-slate-500">No inbound leads yet. Public form submissions appear here instantly.</p>
{% endif %}
