<div class="mb-5 flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap gap-2">
        {% for value, label in status_choices %}
        <span class="ops-chip">
            <span class="text-slate-400">{{ label }}</span>
            <span class="font-bold text-ink-900">{{ status_counts[value] }}</span>
        </span>
        {% endfor %}
    </div>
    <span class="text-[10px] font-medium uppercase tracking-wider text-slate-400">Live · every 15s</span>
</div>

{% if leads %}
<div class="dash-panel overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full min-w-[1100px] text-left text-sm">
            <thead class="border-b border-slate-100 bg-slate-50/80 text-[10px] uppercase tracking-[0.14em] text-slate-500">
                <tr>
                    <th class="px-5 py-3.5 font-semibold">Lead</th>
                    <th class="px-4 py-3.5 font-semibold">Company / Interest</th>
                    <th class="px-4 py-3.5 font-semibold">Received</th>
                    <th class="px-4 py-3.5 font-semibold">Status</th>
                    <th class="px-4 py-3.5 font-semibold">Assigned</th>
                    <th class="px-4 py-3.5 font-semibold">Notes</th>
                    <th class="px-5 py-3.5 font-semibold">Convert</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {% for lead in leads %}
                {% include "partials/_lead_row.jinja" %}
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% else %}
<div class="dash-panel p-12 text-center">
    <p class="font-display text-lg font-semibold text-ink-900">No inbound leads yet</p>
    <p class="mt-2 text-sm text-slate-500">Contact forms and strategy call submissions appear here instantly.</p>
</div>
{% endif %}
