{# OOB fragments — polled by mission control root #}
<div id="ops-stats-bar" hx-swap-oob="true">
    {% include "partials/ops/_stats_bar.jinja" %}
</div>

<div id="ops-attention" hx-swap-oob="true">
    {% include "partials/ops/_attention.jinja" %}
</div>

<div id="ops-leads-feed" hx-swap-oob="true">
    {% include "partials/ops/_leads_feed.jinja" %}
</div>

<div id="ops-qa-queue" hx-swap-oob="true">
    {% include "partials/ops/_qa_queue.jinja" %}
</div>

<div id="ops-applications-feed" hx-swap-oob="true">
    {% include "partials/ops/_applications_feed.jinja" %}
</div>

{% if include_jobs %}
<div id="ops-jobs-feed" hx-swap-oob="true">
    {% include "partials/ops/_jobs_feed.jinja" %}
</div>
<span id="ops-hiring-chips" hx-swap-oob="true" class="hidden text-[10px] font-medium text-slate-400 lg:inline">
    {{ stats.new_job_applications }} new
</span>
<div id="ops-dgc-leads-feed" hx-swap-oob="true">
    {% include "partials/ops/_dgc_leads_feed.jinja" %}
</div>
<div id="ops-dgc-apps-feed" hx-swap-oob="true">
    {% include "partials/ops/_dgc_apps_feed.jinja" %}
</div>
<span id="ops-jobs-badge" hx-swap-oob="true">
    {% if job_application_new %} ({{ job_application_new }}){% endif %}
</span>
{% endif %}

<span id="ops-live-timestamp" hx-swap-oob="true" class="rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[10px] font-semibold text-slate-600">
    {{ updated_at.strftime('%H:%M:%S') }}
</span>
