{% if pending_deliverables %}
<ul class="divide-y divide-slate-100">
    {% for deliverable in pending_deliverables %}
    <li class="flex items-center justify-between gap-2 border-l-4 border-l-orange-400 py-2 pl-2.5">
        <div class="min-w-0">
            <p class="truncate text-sm font-semibold text-ink-900">{{ deliverable.title }}</p>
            <p class="truncate text-[11px] text-slate-500">{{ deliverable.project.name }}</p>
        </div>
        <a href="{{ url('operations:quality_check') }}" class="shrink-0 rounded-md bg-orange-100 px-2 py-1 text-[10px] font-bold text-orange-800 hover:bg-orange-200">QA</a>
    </li>
    {% endfor %}
</ul>
{% else %}
<p class="py-5 text-center text-xs text-emerald-700">All clear — nothing in QA.</p>
{% endif %}
