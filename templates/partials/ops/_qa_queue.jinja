{% if pending_deliverables %}
<div class="ops-feed">
    {% for deliverable in pending_deliverables %}
    <div class="ops-feed-row">
        <div class="ops-feed-main">
            <p class="ops-feed-title" title="{{ deliverable.title }}">{{ deliverable.title }}</p>
            <p class="ops-feed-meta" title="{{ deliverable.project.name }}">{{ deliverable.project.name }}</p>
        </div>
        <a href="{{ url('operations:quality_check') }}"
           class="shrink-0 rounded-md bg-orange-50 px-2 py-1 text-[10px] font-bold text-orange-700 hover:bg-orange-100">
            Review
        </a>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="flex h-full min-h-[8rem] items-center justify-center">
    <p class="text-[11px] text-slate-400">All clear — nothing in QA.</p>
</div>
{% endif %}
