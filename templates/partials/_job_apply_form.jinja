<div id="job-apply-form-container">
    <form action="{{ url('website:job_apply') }}"
          method="post"
          hx-post="{{ url('website:job_apply') }}"
          hx-target="#job-apply-form-container"
          hx-swap="outerHTML"
          hx-disabled-elt="find button[type='submit']"
          novalidate
          class="space-y-4">
        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">

        {% if show_errors and form.errors %}
        <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
            Please fix the highlighted fields and try again.
            {% if form.non_field_errors %}
            <p class="mt-1">{{ form.non_field_errors[0] }}</p>
            {% endif %}
        </div>
        {% endif %}

        <div class="grid gap-4 sm:grid-cols-2">
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Full Name *</label>
                {{ form.name }}
                {% if show_errors and form.name.errors %}<p class="mt-1 text-xs text-red-600">{{ form.name.errors[0] }}</p>{% endif %}
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Email *</label>
                {{ form.email }}
                {% if show_errors and form.email.errors %}<p class="mt-1 text-xs text-red-600">{{ form.email.errors[0] }}</p>{% endif %}
            </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Phone *</label>
                {{ form.phone }}
                {% if show_errors and form.phone.errors %}<p class="mt-1 text-xs text-red-600">{{ form.phone.errors[0] }}</p>{% endif %}
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Application type *</label>
                {{ form.application_type }}
                {% if show_errors and form.application_type.errors %}<p class="mt-1 text-xs text-red-600">{{ form.application_type.errors[0] }}</p>{% endif %}
            </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Role *</label>
                {{ form.role }}
                {% if show_errors and form.role.errors %}<p class="mt-1 text-xs text-red-600">{{ form.role.errors[0] }}</p>{% endif %}
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Experience</label>
                {{ form.experience }}
                {% if show_errors and form.experience.errors %}<p class="mt-1 text-xs text-red-600">{{ form.experience.errors[0] }}</p>{% endif %}
            </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Portfolio URL</label>
                {{ form.portfolio_url }}
                {% if show_errors and form.portfolio_url.errors %}<p class="mt-1 text-xs text-red-600">{{ form.portfolio_url.errors[0] }}</p>{% endif %}
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">LinkedIn URL</label>
                {{ form.linkedin_url }}
                {% if show_errors and form.linkedin_url.errors %}<p class="mt-1 text-xs text-red-600">{{ form.linkedin_url.errors[0] }}</p>{% endif %}
            </div>
        </div>

        <div>
            <label class="mb-1 block text-sm font-medium text-slate-700">Why you? *</label>
            {{ form.cover_letter }}
            {% if show_errors and form.cover_letter.errors %}<p class="mt-1 text-xs text-red-600">{{ form.cover_letter.errors[0] }}</p>{% endif %}
        </div>

        <button type="submit" class="btn-primary w-full min-w-[180px] sm:w-auto">
            <span class="htmx-request-hide">Submit Job Application</span>
            <span class="htmx-indicator inline-flex items-center gap-2">
                <svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                </svg>
                Submitting…
            </span>
        </button>
        <p class="text-xs text-slate-500">This is a job application — not an Academy course signup. Looking for courses? <a href="{{ url('academy:courses') }}" class="font-semibold text-brand-600 hover:text-brand-700">Browse Academy</a>.</p>
    </form>
</div>
