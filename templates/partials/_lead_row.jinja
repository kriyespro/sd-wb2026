<div id="lead-{{ lead.id }}" class="dash-panel p-5">
    <div class="flex flex-wrap items-start justify-between gap-4 border-b border-slate-100 pb-4">
        <div>
            <h3 class="font-display font-semibold text-ink-900">{{ lead.name }}</h3>
            <p class="text-xs text-slate-500">{{ lead.email }}{% if lead.phone %} · {{ lead.phone }}{% endif %}</p>
            <p class="mt-1 text-sm text-slate-600">
                {% if lead.company %}{{ lead.company }} · {% endif %}
                {{ lead.service_interest or 'General inquiry' }}
                {% if lead.source_page %}<span class="text-slate-400">· {{ lead.source_page }}</span>{% endif %}
            </p>
            {% if lead.message %}
            <p class="mt-2 text-sm text-slate-600">{{ lead.message }}</p>
            {% endif %}
        </div>
        <div class="text-right text-xs text-slate-400">
            {{ lead.created_at.strftime('%d %b %Y') }}
            {% if lead.is_converted %}
            <p class="mt-1 font-semibold text-emerald-600">Converted → {{ lead.converted_client.company_name }}</p>
            {% endif %}
        </div>
    </div>

    <div class="mt-4 grid gap-4 lg:grid-cols-3">
        <form hx-post="{{ url('operations:lead_status', kwargs={'pk': lead.id}) }}"
              hx-target="#lead-{{ lead.id }}"
              hx-swap="outerHTML"
              class="flex items-end gap-2">
            <div class="flex-1">
                <label class="mb-1 block text-xs font-medium text-slate-500">Status</label>
                <select name="status" class="wb-input text-sm" onchange="htmx.trigger(this.form, 'submit')">
                    {% for value, label in status_choices %}
                    <option value="{{ value }}" {% if lead.status == value %}selected{% endif %}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
        </form>

        <form hx-post="{{ url('operations:lead_assign', kwargs={'pk': lead.id}) }}"
              hx-target="#lead-{{ lead.id }}"
              hx-swap="outerHTML"
              class="flex items-end gap-2">
            <div class="flex-1">
                <label class="mb-1 block text-xs font-medium text-slate-500">Assigned to</label>
                <select name="assigned_to" class="wb-input text-sm" onchange="htmx.trigger(this.form, 'submit')">
                    <option value="">Unassigned</option>
                    {% for exec in sales_executives|default([]) %}
                    <option value="{{ exec.id }}" {% if lead.assigned_to_id == exec.id %}selected{% endif %}>
                        {{ exec.get_full_name() or exec.username }}
                    </option>
                    {% endfor %}
                </select>
            </div>
        </form>

        {% if not lead.is_converted %}
        <form hx-post="{{ url('operations:lead_convert', kwargs={'pk': lead.id}) }}"
              hx-target="#lead-{{ lead.id }}"
              hx-swap="outerHTML"
              hx-confirm="Convert this lead to a client account and create a project?"
              class="flex items-end gap-2">
            <div class="flex-1">
                <label class="mb-1 block text-xs font-medium text-slate-500">Convert to client</label>
                <input type="text" name="project_name" placeholder="Project name (optional)" class="wb-input text-sm">
            </div>
            <button type="submit" class="shrink-0 rounded-full bg-gold-500 px-4 py-2.5 text-xs font-bold text-ink-900 hover:bg-gold-400">
                Convert
            </button>
        </form>
        {% endif %}
    </div>

    <form hx-post="{{ url('operations:lead_notes', kwargs={'pk': lead.id}) }}"
          hx-target="#lead-{{ lead.id }}"
          hx-swap="outerHTML"
          class="mt-4">
        <label class="mb-1 block text-xs font-medium text-slate-500">Handoff notes</label>
        <div class="flex gap-2">
            <textarea name="handoff_notes" rows="2" class="wb-input flex-1 text-sm" placeholder="Business consultant handoff notes…">{{ lead.handoff_notes }}</textarea>
            <button type="submit" class="shrink-0 self-end rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">
                Save
            </button>
        </div>
    </form>
</div>
