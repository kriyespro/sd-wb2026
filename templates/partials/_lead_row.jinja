<tr id="lead-{{ lead.id }}" class="align-top transition hover:bg-slate-50/80">
    <td class="px-5 py-4">
        <div class="flex items-start gap-3">
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-brand-900 font-display text-xs font-bold text-gold-300">
                {{ lead.name[:1]|upper }}
            </span>
            <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                    <p class="font-semibold text-ink-900">{{ lead.name }}</p>
                    {% if lead.is_converted %}
                    <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-emerald-800">Converted</span>
                    {% endif %}
                </div>
                <a href="mailto:{{ lead.email }}" class="block truncate text-xs text-brand-600 hover:underline">{{ lead.email }}</a>
                {% if lead.phone %}
                <p class="mt-0.5 text-xs text-slate-500">{{ lead.phone }}</p>
                {% endif %}
            </div>
        </div>
    </td>
    <td class="px-4 py-4">
        {% if lead.company %}
        <p class="font-medium text-slate-800">{{ lead.company }}</p>
        {% endif %}
        <p class="text-xs text-slate-500">{{ lead.service_interest or 'General inquiry' }}</p>
        {% if lead.source_page %}
        <p class="mt-1 text-[10px] text-slate-400">via {{ lead.source_page }}</p>
        {% endif %}
    </td>
    <td class="px-4 py-4 whitespace-nowrap text-xs text-slate-500">
        <p class="font-medium text-slate-700">{{ lead.created_at.strftime('%d %b %Y') }}</p>
        <p class="mt-0.5">{{ lead.created_at.strftime('%H:%M') }}</p>
    </td>
    <td class="px-4 py-4">
        <form hx-post="{{ url('operations:lead_status', kwargs={'pk': lead.id}) }}"
              hx-target="#lead-{{ lead.id }}"
              hx-swap="outerHTML"
              class="min-w-[8.5rem]">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <select name="status"
                    class="ops-select text-xs font-semibold
                    {% if lead.status == 'new' %}border-emerald-300 bg-emerald-50 text-emerald-900
                    {% elif lead.status == 'won' %}border-brand-300 bg-brand-50 text-brand-900
                    {% elif lead.status == 'lost' %}border-slate-300 bg-slate-50 text-slate-600
                    {% elif lead.status == 'proposal' %}border-amber-300 bg-amber-50 text-amber-900
                    {% elif lead.status == 'qualified' %}border-violet-300 bg-violet-50 text-violet-900
                    {% elif lead.status == 'contacted' %}border-sky-300 bg-sky-50 text-sky-900
                    {% else %}border-slate-200{% endif %}"
                    onchange="htmx.trigger(this.form, 'submit')">
                {% for value, label in status_choices %}
                <option value="{{ value }}" {% if lead.status == value %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
        </form>
    </td>
    <td class="px-4 py-4">
        <form hx-post="{{ url('operations:lead_assign', kwargs={'pk': lead.id}) }}"
              hx-target="#lead-{{ lead.id }}"
              hx-swap="outerHTML"
              class="min-w-[9rem]">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <select name="assigned_to" class="ops-select text-xs" onchange="htmx.trigger(this.form, 'submit')">
                <option value="">Unassigned</option>
                {% for exec in sales_executives|default([]) %}
                <option value="{{ exec.id }}" {% if lead.assigned_to_id == exec.id %}selected{% endif %}>
                    {{ exec.get_full_name() or exec.username }}
                </option>
                {% endfor %}
            </select>
        </form>
    </td>
    <td class="px-4 py-4 max-w-[14rem]">
        <details class="group text-xs">
            <summary class="cursor-pointer list-none font-semibold text-brand-600 hover:text-brand-700">
                <span class="group-open:hidden">
                    {% if lead.message or lead.handoff_notes %}Notes / message →{% else %}Add notes →{% endif %}
                </span>
                <span class="hidden group-open:inline">Hide ↑</span>
            </summary>
            <div class="mt-2 space-y-2">
                {% if lead.message %}
                <div class="rounded-xl border border-slate-100 bg-slate-50 p-2.5 leading-relaxed text-slate-600">
                    <p class="mb-1 text-[10px] font-bold uppercase tracking-wide text-slate-400">Message</p>
                    <p class="whitespace-pre-wrap">{{ lead.message }}</p>
                </div>
                {% endif %}
                <form hx-post="{{ url('operations:lead_notes', kwargs={'pk': lead.id}) }}"
                      hx-target="#lead-{{ lead.id }}"
                      hx-swap="outerHTML"
                      class="space-y-2">
                    <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                    <textarea name="handoff_notes" rows="2" class="ops-textarea text-xs" placeholder="Handoff notes…">{{ lead.handoff_notes }}</textarea>
                    <button type="submit" class="rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-[10px] font-semibold text-slate-700 hover:border-brand-200 hover:bg-brand-50 hover:text-brand-700">
                        Save notes
                    </button>
                </form>
                <div class="rounded-xl border border-slate-100 bg-white p-2.5">
                    <p class="mb-1.5 text-[10px] font-bold uppercase tracking-wide text-slate-400">Follow-up checklist</p>
                    <ul class="space-y-1">
                        {% for step in lead.followups.all() %}
                        <li>
                            <form hx-post="{{ url('operations:lead_followup_toggle', kwargs={'pk': step.id}) }}"
                                  hx-target="#lead-{{ lead.id }}"
                                  hx-swap="outerHTML"
                                  class="flex items-start gap-2">
                                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                                <button type="submit" class="mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center rounded border text-[9px]
                                    {% if step.is_done %}border-emerald-500 bg-emerald-500 text-white{% else %}border-slate-300 text-transparent{% endif %}">✓</button>
                                <span class="{% if step.is_done %}text-slate-400 line-through{% else %}text-slate-700{% endif %}">{{ step.label }}</span>
                            </form>
                        </li>
                        {% endfor %}
                    </ul>
                    <form hx-post="{{ url('operations:lead_next_follow_up', kwargs={'pk': lead.id}) }}"
                          hx-target="#lead-{{ lead.id }}"
                          hx-swap="outerHTML"
                          class="mt-2 flex items-center gap-1.5">
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                        <input type="date" name="next_follow_up_at" class="ops-select text-[10px]"
                               value="{{ lead.next_follow_up_at.strftime('%Y-%m-%d') if lead.next_follow_up_at else '' }}">
                        <button type="submit" class="rounded-lg bg-slate-900 px-2 py-1 text-[9px] font-bold text-white">Set</button>
                    </form>
                </div>
            </div>
        </details>
    </td>
    <td class="px-5 py-4">
        {% if lead.is_converted %}
        <p class="text-xs font-semibold text-emerald-600">
            → {{ lead.converted_client.company_name if lead.converted_client else 'Client' }}
        </p>
        {% else %}
        <form hx-post="{{ url('operations:lead_convert', kwargs={'pk': lead.id}) }}"
              hx-target="#lead-{{ lead.id }}"
              hx-swap="outerHTML"
              hx-confirm="Convert this lead to a client account and create a project?"
              class="min-w-[10rem] space-y-1.5">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <input type="text" name="project_name" placeholder="Project name" class="ops-select text-xs">
            <button type="submit" class="w-full rounded-xl bg-gold-500 px-3 py-2 text-[10px] font-bold uppercase tracking-wide text-ink-900 transition hover:bg-gold-400">
                Convert
            </button>
        </form>
        {% endif %}
    </td>
</tr>
