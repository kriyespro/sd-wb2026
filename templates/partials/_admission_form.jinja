<div id="admission-form-container">
    <form hx-post="{{ url('academy:apply_submit') }}"
          hx-target="#admission-form-container"
          hx-swap="outerHTML"
          class="space-y-4">
        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">

        <div class="grid gap-4 sm:grid-cols-2">
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Full Name *</label>
                {{ form.name }}
                {% if show_errors and form.name.errors %}<p class="mt-1 text-xs text-red-600">{{ form.name.errors[0] }}</p>{% endif %}
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Email *</label>
                {{ form.email }}
                {% if show_errors and form.email.errors %}<p class="mt-1 text-xs text-red-600">{{ form.email.errors[0] }}</p>{% endif %}
            </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Phone *</label>
                {{ form.phone }}
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Education *</label>
                {{ form.education }}
            </div>
        </div>

        <div>
            <label class="mb-1 block text-sm font-medium text-slate-700">Course Interest</label>
            {{ form.course_interest }}
        </div>

        <div>
            <label class="mb-1 block text-sm font-medium text-slate-700">Why do you want to join? *</label>
            {{ form.motivation }}
            {% if show_errors and form.motivation.errors %}<p class="mt-1 text-xs text-red-600">{{ form.motivation.errors[0] }}</p>{% endif %}
        </div>

        <button type="submit" class="btn-primary w-full sm:w-auto">Submit Application</button>
    </form>
</div>
