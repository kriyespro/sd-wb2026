<article class="section-card relative flex h-full flex-col overflow-hidden">
    {% if course.featured %}
    <span class="absolute right-4 top-4 z-10 rounded-full bg-gold-500 px-3 py-1 text-xs font-bold text-ink-900">Featured</span>
    {% endif %}
    <a href="{{ url('academy:course_detail', kwargs={'slug': course.slug}) }}" class="block">
        <img src="{{ course.image }}" alt="{{ course.title }}" class="h-44 w-full object-cover">
    </a>
    <div class="flex flex-1 flex-col p-6">
        <a href="{{ url('academy:course_detail', kwargs={'slug': course.slug}) }}" class="font-display text-lg font-semibold text-ink-900 hover:text-brand-700">
            {{ course.title }}
        </a>
        <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600 line-clamp-3">{{ course.goal }}</p>
        {% if course.salary_range %}
        <p class="mt-3 text-sm font-semibold text-gold-600">{{ course.salary_range }}</p>
        {% endif %}
        <div class="mt-4 flex flex-wrap gap-2 text-xs text-slate-500">
            <span class="rounded-full bg-brand-50 px-2.5 py-1 font-medium text-brand-700">{{ course.level }}</span>
            <span class="rounded-full bg-slate-100 px-2.5 py-1">{{ course.duration }}</span>
            <span class="rounded-full bg-slate-100 px-2.5 py-1">{{ course.format }}</span>
            {% if course.modules_count %}
            <span class="rounded-full bg-slate-100 px-2.5 py-1">{{ course.modules_count }} modules</span>
            {% endif %}
        </div>
        <div class="mt-6 flex items-center justify-between gap-4 border-t border-slate-100 pt-5">
            <span class="font-display text-xl font-bold text-brand-700">{{ course.price }}</span>
            <div class="flex gap-2">
                <a href="{{ url('academy:course_detail', kwargs={'slug': course.slug}) }}" class="text-sm font-semibold text-brand-600 hover:text-brand-700">View course</a>
                <a href="{{ url('academy:apply') }}" class="btn-primary !px-4 !py-2 text-xs">Apply</a>
            </div>
        </div>
    </div>
</article>
