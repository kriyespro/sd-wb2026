{% extends "base.jinja" %}

{% block content %}
<!-- HERO -->
<section class="relative overflow-hidden bg-white py-20 sm:py-24">
    <span class="wm text-brand-100" style="font-size:12vw;top:8%;right:-2%;letter-spacing:-0.03em">GROWTH</span>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-2">
            <div>
                <span class="eyebrow">What we do</span>
                <h1 class="mt-6 font-display text-4xl font-bold leading-tight text-ink-900 sm:text-5xl">
                    Factory-to-customer<br>
                    <span class="font-serif text-gradient-gold">services</span>
                </h1>
                <p class="mt-6 max-w-lg text-lg leading-relaxed text-slate-600">
                    Store setup, Meta & Google ads, WhatsApp automation, and backoffice SOPs —
                    built for textile manufacturers selling direct to customers.
                </p>
                <div class="mt-8 flex flex-wrap gap-4">
                    <a href="{{ url('website:contact') }}" class="btn-gold">Book Free Consultation →</a>
                    <a href="{{ url('website:pricing') }}" class="btn-outline">View Pricing</a>
                </div>
                <ul class="mt-10 space-y-2.5 text-sm text-slate-600">
                    {% for point in ['Prepaid order systems', '30–45 day path to first orders', 'You focus on production'] %}
                    <li class="flex items-center gap-2.5">
                        <span class="flex h-5 w-5 items-center justify-center rounded-full bg-gold-100 text-xs text-gold-600">✓</span>
                        {{ point }}
                    </li>
                    {% endfor %}
                </ul>
            </div>
            <div class="relative">
                <div class="absolute -right-4 -top-4 h-40 w-40 rounded-full bg-gold-200/40 blur-3xl"></div>
                <div class="absolute -left-4 bottom-8 h-36 w-36 rounded-full bg-brand-100 blur-3xl"></div>
                <div class="relative overflow-hidden rounded-3xl border border-slate-200 shadow-2xl shadow-brand-900/10">
                    <img src="{{ site_images.hero }}" alt="Growth services dashboard" class="h-56 w-full object-cover sm:h-64">
                    <div class="grid grid-cols-3 gap-px bg-slate-100 p-px">
                        {% for s in stats[:3] %}
                        <div class="bg-white px-4 py-4 text-center">
                            <div class="font-display text-xl font-bold text-brand-700">{{ s.value }}{{ s.suffix }}</div>
                            <div class="text-[10px] uppercase tracking-wider text-slate-500">{{ s.label }}</div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- TRUST -->
<section class="border-y border-slate-200 bg-slate-50 py-10">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Built for manufacturers going direct</p>
    <div class="relative mt-6 overflow-hidden">
        <div class="flex w-max animate-marquee items-center gap-10">
            {% for i in range(2) %}
            {% for tag in audience_tags %}
            <span class="whitespace-nowrap rounded-full border border-slate-200 bg-white px-5 py-2 text-sm font-semibold text-ink-900 shadow-sm">{{ tag }}</span>
            <span class="text-gold-400">✦</span>
            {% endfor %}
            {% endfor %}
        </div>
    </div>
</section>

<!-- SERVICES GRID -->
<section class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
            <div class="lg:col-span-4">
                <div class="lg:sticky lg:top-28">
                    <span class="eyebrow">Our services</span>
                    <h2 class="mt-5 font-display text-3xl font-bold leading-tight text-ink-900 sm:text-4xl">
                        Everything you need to sell direct
                    </h2>
                    <p class="mt-6 max-w-md leading-relaxed text-slate-600">
                        From storefront to ads to backoffice — pick one channel or combine them into a
                        full factory-to-customer engine.
                    </p>
                    <a href="{{ url('website:contact') }}" class="btn-outline mt-8">Get a Custom Quote →</a>
                </div>
            </div>

            {% set svc_icons = {
                'seo': 'M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z',
                'google-ads': 'M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.518l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941',
                'meta-ads': 'M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244',
                'website-development': 'M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5',
                'automation': 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
                'crm': 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z',
                'branding': 'M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42',
                'content-marketing': 'M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10'
            } %}
            <div class="lg:col-span-8">
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                    {% for service in services %}
                    <a href="{{ url('website:service_detail', kwargs={'slug': service.slug}) }}"
                       class="group flex min-h-[220px] flex-col justify-between rounded-2xl border border-slate-200 bg-slate-50 p-8 transition hover:border-brand-300 hover:bg-white hover:shadow-xl hover:shadow-brand-900/5">
                        <span class="text-brand-600">
                            <svg class="h-9 w-9" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="{{ svc_icons.get(service.slug, svc_icons['seo']) }}"/>
                            </svg>
                        </span>
                        <div>
                            <h3 class="font-display text-xl font-semibold text-ink-900 group-hover:text-brand-700">{{ service.title }}</h3>
                            <p class="mt-2 text-sm leading-relaxed text-slate-500">{{ service.short }}</p>
                            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-gold-600 opacity-0 transition group-hover:opacity-100">
                                Learn more →
                            </span>
                        </div>
                    </a>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>

<!-- WHY CHOOSE US -->
<section class="bg-slate-50 py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <span class="eyebrow justify-center">Why choose us</span>
            <h2 class="mt-5 font-display text-3xl font-bold text-ink-900 sm:text-4xl">Built for measurable outcomes</h2>
            <p class="mt-4 text-slate-600">Every engagement ties back to revenue, retention, and scalable growth.</p>
        </div>
        <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
            {% for item in why_choose_us[:4] %}
            <div class="section-card p-7">
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <h3 class="mt-5 font-display font-semibold text-ink-900">{{ item.title }}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">{{ item.desc }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- PROCESS -->
<section class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-2">
            <div>
                <span class="eyebrow">How we work</span>
                <h2 class="mt-5 font-display text-3xl font-bold text-ink-900 sm:text-4xl">A proven delivery framework</h2>
                <p class="mt-4 max-w-md text-slate-600">From discovery to scale — strategy, execution, and reporting stay aligned every step.</p>
                <a href="{{ url('website:case_studies') }}" class="mt-6 inline-flex text-sm font-semibold text-brand-600 hover:text-brand-700">See case studies →</a>
            </div>
            <div class="space-y-4">
                {% for step in service_process %}
                <div class="flex gap-5 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold-100 font-display font-bold text-gold-700">{{ loop.index }}</span>
                    <div>
                        <h3 class="font-display font-semibold text-ink-900">{{ step.title }}</h3>
                        <p class="mt-1 text-sm text-slate-600">{{ step.desc }}</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<!-- STATS -->
<section class="bg-brand-900 py-20 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 text-center sm:grid-cols-2 lg:grid-cols-4">
            {% for stat in stats %}
            <div x-data="{ n: 0 }"
                 x-init="
                    const target = {{ stat.value }};
                    const obs = new IntersectionObserver((entries) => {
                        entries.forEach(entry => {
                            if (entry.isIntersecting) {
                                const duration = 1600;
                                const start = performance.now();
                                const tick = (now) => {
                                    const p = Math.min((now - start) / duration, 1);
                                    n = Math.round((1 - Math.pow(1 - p, 3)) * target);
                                    if (p < 1) requestAnimationFrame(tick);
                                };
                                requestAnimationFrame(tick);
                                obs.unobserve(entry.target);
                            }
                        });
                    }, { threshold: 0.4 });
                    obs.observe($el);
                 ">
                <div class="font-display text-5xl font-bold sm:text-6xl">
                    <span class="text-gradient-gold" x-text="n"></span><span class="text-gold-400">{{ stat.suffix }}</span>
                </div>
                <div class="mt-2 text-sm uppercase tracking-widest text-slate-400">{{ stat.label }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- RECENT WORK -->
{% if recent_projects %}
<section class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
            <div>
                <span class="eyebrow">Selected work</span>
                <h2 class="mt-5 font-display text-3xl font-bold text-ink-900 sm:text-4xl">Results across services</h2>
            </div>
            <a href="{{ url('website:our_work') }}" class="text-sm font-semibold text-brand-600 hover:text-brand-700">View all work →</a>
        </div>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {% for project in recent_projects %}
            <div class="section-card overflow-hidden">
                <img src="{{ project.image }}" alt="{{ project.title }}" class="h-44 w-full object-cover">
                <div class="p-6">
                    <span class="rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">{{ project.category }}</span>
                    <h3 class="mt-4 font-display text-lg font-semibold text-ink-900">{{ project.title }}</h3>
                    <p class="mt-2 font-display text-xl font-bold text-gold-600">{{ project.result }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<!-- LEAD CTA -->
<section class="bg-slate-50 pb-24 pt-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-2xl shadow-brand-900/5">
            <div class="grid lg:grid-cols-5">
                <div class="bg-brand-900 p-10 text-white lg:col-span-2">
                    <h2 class="font-display text-2xl font-bold sm:text-3xl">Not sure which service you need?</h2>
                    <p class="mt-4 text-sm text-slate-300">Book a free strategy call — we'll map the right channels for your goals.</p>
                    <div class="mt-8 space-y-3 text-sm">
                        {% for point in ['Free strategy session', 'ROI-focused roadmap', 'No obligation'] %}
                        <div class="flex items-center gap-2 text-slate-200">
                            <span class="text-gold-400">✓</span> {{ point }}
                        </div>
                        {% endfor %}
                    </div>
                </div>
                <div class="p-8 lg:col-span-3 lg:p-10">
                    {% set source_page = 'services' %}
                    {% include "partials/_lead_form.jinja" %}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
