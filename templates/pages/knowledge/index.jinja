{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<section class="mb-6">
    <span class="text-xs font-semibold uppercase tracking-[0.2em] text-brand-600">OS Hub</span>
    <h2 class="mt-2 font-display text-2xl font-bold text-ink-900">Knowledge Base</h2>
    <p class="mt-1 text-sm text-slate-600">Playbooks and package SOPs for your role.</p>
</section>

{% if categories %}
<div class="mb-4 flex flex-wrap gap-2">
    {% for cat in categories %}
    <span class="ops-chip">{{ cat }}</span>
    {% endfor %}
</div>
{% endif %}

<div class="grid gap-3 md:grid-cols-2">
    {% for article in articles %}
    <a href="{{ url('knowledge:detail', kwargs={'slug': article.slug}) }}" class="dash-panel block p-5 transition hover:border-brand-200 hover:shadow-md">
        {% if article.category %}
        <p class="text-[10px] font-bold uppercase tracking-wide text-slate-400">{{ article.category }}</p>
        {% endif %}
        <h3 class="mt-1 font-display text-lg font-semibold text-ink-900">{{ article.title }}</h3>
        <p class="mt-2 text-sm text-slate-600">{{ article.summary or article.body[:140] }}</p>
        <p class="mt-3 text-[10px] font-bold uppercase text-brand-600">Read →</p>
    </a>
    {% else %}
    <div class="dash-panel col-span-full p-10 text-center text-slate-500">No articles for your role yet.</div>
    {% endfor %}
</div>
{% endblock %}
