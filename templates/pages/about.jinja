{% extends "base.jinja" %}

{% block content %}
{% set hero_eyebrow = 'About us' %}
{% set hero_title = 'About ' ~ site_name %}
{% set hero_text = 'A professional digital growth company — not a training institute.' %}
{% include "components/page_hero.jinja" %}

<section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-2">
            <div class="order-2 lg:order-1">
                <h2 class="font-display text-2xl font-bold text-ink-900">Who We Are</h2>
                <p class="mt-4 text-slate-600 leading-relaxed">
                    {{ site_name }} is an AI Growth Partner for modern businesses. We help companies grow through
                    digital marketing, AI automation, web development, SEO, and performance marketing — delivered
                    by an experienced team with a relentless focus on ROI.
                </p>
                <p class="mt-4 text-slate-600 leading-relaxed">
                    Behind the scenes, we operate an internal Industry Academy that trains future professionals
                    by letting them work under senior experts on real client projects. This talent pipeline ensures
                    continuous quality and innovation — but our clients experience a professional agency, period.
                </p>
            </div>
            <img src="{{ site_images.about_team }}" alt="Who we are"
                 class="order-1 aspect-[4/3] w-full rounded-3xl object-cover lg:order-2">
        </div>
    </div>
</section>

<!-- FEATURE STRIP -->
<section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
            {% for item in why_choose_us[:4] %}
            <div class="rounded-2xl border border-slate-200 bg-white p-6">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent-400/20 text-brand-700">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <h3 class="mt-4 font-display font-semibold text-ink-900">{{ item.title }}</h3>
                <p class="mt-1.5 text-sm text-slate-600">{{ item.desc }}</p>
            </div>
            {% endfor %}
        </div>

        <div class="mt-14 grid gap-8 text-center sm:grid-cols-2 lg:grid-cols-4">
            {% for stat in stats %}
            <div>
                <div class="font-display text-3xl font-bold text-brand-600 sm:text-4xl">{{ stat.value }}{{ stat.suffix }}</div>
                <div class="mt-1 text-sm text-slate-600">{{ stat.label }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- OUR MODEL -->
<section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
            <span class="eyebrow">How we're built</span>
            <h2 class="mt-4 font-display text-3xl font-bold text-ink-900 sm:text-4xl">Our model</h2>
        </div>
        <div class="mt-14 space-y-16">
            {% for step in model_steps %}
            <div class="grid items-center gap-10 lg:grid-cols-2">
                <img src="{{ step.image }}" alt="{{ step.title }}"
                     class="aspect-[4/3] w-full rounded-3xl object-cover {% if loop.index is even %}lg:order-2{% endif %}">
                <div class="{% if loop.index is even %}lg:order-1{% endif %}">
                    <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-100 font-bold text-brand-700">{{ loop.index }}</span>
                    <h3 class="mt-4 font-display text-xl font-semibold text-ink-900">{{ step.title }}</h3>
                    <p class="mt-2 text-slate-600 leading-relaxed">{{ step.desc }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- TEAM -->
<section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
            <span class="eyebrow">The team</span>
            <h2 class="mt-4 font-display text-3xl font-bold text-ink-900 sm:text-4xl">Experienced specialists, every discipline</h2>
        </div>
        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
            {% for member in team_roles %}
            <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white text-center transition hover:-translate-y-1 hover:border-brand-300 hover:shadow-lg">
                <img src="{{ member.image }}" alt="{{ member.role }}" class="h-32 w-full object-cover">
                <div class="p-6">
                    <div class="font-display text-2xl font-bold text-brand-600">{{ member.count }}</div>
                    <h3 class="mt-2 text-sm font-semibold text-ink-900">{{ member.role }}</h3>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="relative overflow-hidden rounded-[2rem] bg-ink-900 p-10 text-center text-white sm:p-14">
            <div class="mesh absolute inset-0 opacity-70"></div>
            <div class="relative">
                <h2 class="font-display text-2xl font-bold sm:text-3xl">Ready to work with us?</h2>
                <p class="mt-3 text-slate-300">Book a free strategy call and let's map your growth blueprint.</p>
                <a href="{{ url('website:contact') }}" class="btn-accent mt-8 inline-flex">Work With Us →</a>
            </div>
        </div>
    </div>
</section>
{% endblock %}
