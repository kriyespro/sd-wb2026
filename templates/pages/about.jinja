{% extends "base.jinja" %}

{% block content %}
{% set hero_eyebrow = 'About us' %}
{% set hero_title = 'We help manufacturers sell direct' %}
{% set hero_text = 'A D2C growth agency for textile factories — powered by a delivery team and an internal academy.' %}
{% include "components/page_hero.jinja" %}

<section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-2">
            <div class="order-2 lg:order-1">
                <h2 class="font-display text-2xl font-bold text-ink-900">Who We Are</h2>
                <p class="mt-4 text-slate-600 leading-relaxed">
                    {{ site_name }} helps textile and garment manufacturers sell sarees, t-shirts, jeans, and kurtis
                    <strong class="font-semibold text-ink-900">directly to customers</strong> — online, prepaid, and with
                    2x–4x higher profit margins than the wholesale model.
                </p>
                <p class="mt-4 text-slate-600 leading-relaxed">
                    Clients experience a professional D2C agency: store setup, Meta & Google ads, WhatsApp automation,
                    and backoffice SOPs. Behind the scenes, our Academy trains specialists on real client work —
                    so delivery stays sharp without you hiring a full digital team.
                </p>
            </div>
            <img src="{{ site_images.about_team }}" alt="Who we are"
                 class="order-1 aspect-[4/3] w-full rounded-3xl object-cover lg:order-2">
        </div>
    </div>
</section>

<section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
            {% for item in why_choose_us[:4] %}
            <div class="rounded-2xl border border-slate-200 bg-white p-6">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent-400/20 text-brand-700">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                </div>
                <h3 class="mt-4 font-display font-semibold text-ink-900">{{ item.title }}</h3>
                <p class="mt-1.5 text-sm text-slate-600">{{ item.desc }}</p>
            </div>
            {% endfor %}
        </div>

        <div class="mt-14 grid gap-8 text-center sm:grid-cols-2 lg:grid-cols-4">
            {% for stat in stats %}
            <div>
                <div class="font-display text-3xl font-bold text-brand-600 sm:text-4xl">{{ stat.value }}{{ stat.suffix }}</div>
                <div class="mt-1 text-sm text-slate-600">{{ stat.label }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
            <span class="eyebrow">The F2C pipeline</span>
            <h2 class="mt-4 font-display text-3xl font-bold text-ink-900 sm:text-4xl">Factory to customer</h2>
        </div>
        <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {% for step in f2c_pipeline %}
            <div class="rounded-2xl border border-slate-200 bg-white p-6">
                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-gold-100 font-display font-bold text-gold-700">{% if loop.last %}✓{% else %}{{ loop.index }}{% endif %}</span>
                <h3 class="mt-4 font-display font-semibold text-ink-900">{{ step.title }}</h3>
                <p class="mt-2 text-sm text-slate-600">{{ step.desc }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
            <span class="eyebrow">How we're built</span>
            <h2 class="mt-4 font-display text-3xl font-bold text-ink-900 sm:text-4xl">Our model</h2>
        </div>
        <div class="mt-14 space-y-16">
            {% for step in model_steps %}
            <div class="grid items-center gap-10 lg:grid-cols-2">
                <img src="{{ step.image }}" alt="{{ step.title }}"
                     class="aspect-[4/3] w-full rounded-3xl object-cover {% if loop.index is even %}lg:order-2{% endif %}">
                <div class="{% if loop.index is even %}lg:order-1{% endif %}">
                    <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-100 font-bold text-brand-700">{{ loop.index }}</span>
                    <h3 class="mt-4 font-display text-xl font-semibold text-ink-900">{{ step.title }}</h3>
                    <p class="mt-2 text-slate-600 leading-relaxed">{{ step.desc }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
            <div>
                <span class="eyebrow">Leadership</span>
                <h2 class="mt-4 font-display text-3xl font-bold text-ink-900 sm:text-4xl">Making your business win</h2>
            </div>
            <a href="{{ url('website:team') }}" class="text-sm font-semibold text-brand-600 hover:text-brand-700">View team →</a>
        </div>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {% for member in team %}
            <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white text-center">
                {% set src = member.image %}{% set alt = member.name %}{% set class = 'h-44 w-full object-cover' %}
                {% include "partials/_img.jinja" %}
                <div class="p-6">
                    <h3 class="font-display font-semibold text-ink-900">{{ member.name }}</h3>
                    <p class="mt-1 text-sm text-brand-600">{{ member.role }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="relative overflow-hidden rounded-[2rem] bg-ink-900 p-10 text-center text-white sm:p-14">
            <div class="mesh absolute inset-0 opacity-70"></div>
            <div class="relative">
                <h2 class="font-display text-2xl font-bold sm:text-3xl">Ready to start selling directly?</h2>
                <p class="mt-3 text-slate-300">Book a free consultation — we'll map your factory-to-customer path.</p>
                <a href="{{ url('website:contact') }}" class="btn-accent mt-8 inline-flex">Book Free Consultation →</a>
            </div>
        </div>
    </div>
</section>
{% endblock %}
