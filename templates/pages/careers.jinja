{% extends "base.jinja" %}

{% block content %}
<section class="relative overflow-hidden bg-brand-900 py-20 text-white sm:py-24">
    <div class="mesh absolute inset-0 opacity-60"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <span class="eyebrow !text-gold-300 before:!bg-gold-400">Careers</span>
        <h1 class="mt-6 max-w-3xl font-display text-4xl font-bold leading-tight sm:text-5xl">
            Build with us.<br>
            <span class="font-serif text-gradient-gold">Ship real work.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300">
            Open roles and internships on live D2C and startup projects — not classroom simulations.
            Apply for a job below. Academy courses are separate.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
            <a href="#open-roles" class="btn-gold">View open roles →</a>
            <a href="#apply" class="btn-outline !border-white/30 !text-white hover:!bg-white/10">Apply now</a>
        </div>
    </div>
</section>

<section class="border-b border-slate-200 bg-slate-50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {% for perk in careers_perks %}
            <div class="rounded-2xl border border-slate-200 bg-white p-6">
                <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-gold-100 font-display text-sm font-bold text-gold-700">0{{ loop.index }}</span>
                <h2 class="mt-4 font-display text-lg font-semibold text-ink-900">{{ perk.title }}</h2>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">{{ perk.desc }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<section id="open-roles" class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
            <div>
                <span class="eyebrow">Hiring now</span>
                <h2 class="mt-5 font-display text-3xl font-bold text-ink-900 sm:text-4xl">Open roles</h2>
                <p class="mt-3 max-w-xl text-slate-600">Select a role to pre-fill the application form.</p>
            </div>
            <a href="#apply" class="text-sm font-semibold text-brand-600 hover:text-brand-700">Skip to apply →</a>
        </div>

        <div class="mt-12 grid gap-5 lg:grid-cols-2">
            {% for role in open_roles %}
            <article class="flex flex-col rounded-3xl border border-slate-200 bg-white p-7 transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-lg">
                <div class="flex flex-wrap items-center gap-2">
                    <span class="rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">{{ role.dept }}</span>
                    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">{{ role.type }}</span>
                    <span class="text-xs text-slate-400">{{ role.location }}</span>
                </div>
                <h3 class="mt-4 font-display text-xl font-bold text-ink-900">{{ role.title }}</h3>
                <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600">{{ role.summary }}</p>
                <div class="mt-4 flex flex-wrap gap-1.5">
                    {% for tag in role.tags %}
                    <span class="rounded-full border border-slate-200 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-slate-500">{{ tag }}</span>
                    {% endfor %}
                </div>
                <a href="{{ url('website:careers') }}?role={{ role.slug }}#apply"
                   class="btn-outline mt-6 w-full text-center sm:w-auto">Apply for this role →</a>
            </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-2">
            <div>
                <span class="eyebrow">Internship path</span>
                <h2 class="mt-5 font-display text-3xl font-bold text-ink-900">Prefer to learn first?</h2>
                <p class="mt-4 leading-relaxed text-slate-600">
                    Internships still apply through this careers form (choose “Growth Intern”).
                    If you want structured courses and certificates, that’s the Academy — a separate track.
                </p>
                <div class="mt-8 space-y-3">
                    {% for step in academy_process %}
                    <div class="flex items-center gap-3">
                        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-600 text-xs font-bold text-white">{{ loop.index }}</span>
                        <span class="text-sm font-medium text-slate-700">{{ step }}</span>
                    </div>
                    {% endfor %}
                </div>
                <a href="{{ url('academy:courses') }}" class="mt-8 inline-flex text-sm font-semibold text-brand-600 hover:text-brand-700">
                    Browse Academy courses (not a job apply) →
                </a>
            </div>
            <div class="grid gap-5 sm:grid-cols-2">
                {% for member in team_roles %}
                <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white text-center">
                    {% set src = member.image %}{% set alt = member.role %}{% set class = 'h-28 w-full object-cover' %}
                    {% include "partials/_img.jinja" %}
                    <div class="p-4">
                        <div class="font-display text-xl font-bold text-brand-600">{{ member.count }}</div>
                        <h3 class="mt-1 text-sm font-semibold text-ink-900">{{ member.role }}</h3>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<section id="apply" class="py-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-2xl shadow-brand-900/5">
            <div class="grid lg:grid-cols-5">
                <div class="bg-ink-900 p-10 text-white lg:col-span-2">
                    <h2 class="font-display text-2xl font-bold sm:text-3xl">Job application</h2>
                    <p class="mt-4 text-sm text-slate-300">
                        Submit once. We review for full-time and internship fits on real client delivery teams.
                    </p>
                    <ul class="mt-8 space-y-3 text-sm text-slate-200">
                        {% for point in ['Goes to hiring — not Academy enrollment', 'Response within a few business days', 'Portfolio / LinkedIn optional but helpful'] %}
                        <li class="flex items-center gap-2"><span class="text-gold-400">✓</span> {{ point }}</li>
                        {% endfor %}
                    </ul>
                </div>
                <div class="p-8 lg:col-span-3 lg:p-10">
                    {% set show_errors = show_errors|default(false) %}
                    {% include "partials/_job_apply_form.jinja" %}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
