{% extends "base.jinja" %}

{% block content %}
{% set hero_eyebrow = 'Industries' %}
{% set hero_title = 'Industries we serve' %}
{% set hero_text = 'Tailored digital growth strategies for your industry.' %}
{% include "components/page_hero.jinja" %}

<section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {% for industry in industries %}
            <div class="group rounded-3xl border border-slate-200 bg-white p-8 transition hover:-translate-y-1 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-600/5">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-brand-50 text-2xl transition group-hover:bg-brand-600 group-hover:scale-110">{{ industry.icon }}</div>
                <h2 class="mt-5 font-display text-xl font-semibold text-ink-900 group-hover:text-brand-700">{{ industry.title }}</h2>
                <p class="mt-3 text-sm leading-relaxed text-slate-600">{{ industry.desc }}</p>
            </div>
            {% endfor %}
        </div>
        <div class="mt-16 text-center">
            <a href="{{ url('website:contact') }}" class="btn-primary">Discuss Your Industry →</a>
        </div>
    </div>
</section>
{% endblock %}
