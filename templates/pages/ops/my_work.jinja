{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<section class="relative mb-6 overflow-hidden rounded-[1.75rem] bg-ink-900 px-6 py-7 text-white sm:px-8">
    <div class="relative">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-gold-300">Delivery desk</span>
        <h2 class="mt-2 font-display text-2xl font-bold">My Work</h2>
        <p class="mt-1 max-w-xl text-sm text-slate-300">
            DGC package orders assigned to you. Update status when delivery is ready.
        </p>
    </div>
</section>

{% if orders %}
<div class="grid gap-4 md:grid-cols-2">
    {% for order in orders %}
    <article class="dash-panel p-5">
        <div class="flex items-start justify-between gap-2">
            <div>
                <p class="text-[10px] font-bold uppercase tracking-wide text-slate-400">Order #{{ order.id }}</p>
                <h3 class="font-display text-lg font-semibold text-ink-900">{{ order.offer.title }}</h3>
                <p class="mt-1 text-xs text-slate-500">{{ order.partner.code }} · ₹{{ '{:,.0f}'.format(order.total) }}</p>
            </div>
            <span class="rounded-full px-2 py-0.5 text-[10px] font-bold uppercase
                {% if order.status == 'fulfilled' %}bg-emerald-100 text-emerald-800
                {% elif order.status == 'confirmed' %}bg-sky-100 text-sky-800
                {% else %}bg-amber-100 text-amber-800{% endif %}">{{ order.get_status_display() }}</span>
        </div>
        {% if order.due_at %}
        <p class="mt-3 text-[11px] font-semibold text-amber-700">Due {{ order.due_at.strftime('%d %b %Y') }}</p>
        {% endif %}
        {% if order.work_notes %}
        <p class="mt-2 whitespace-pre-wrap rounded-xl bg-slate-50 p-3 text-xs text-slate-600">{{ order.work_notes }}</p>
        {% endif %}
        <form method="post" action="{{ url('operations:dgc_order_status', kwargs={'pk': order.id}) }}" class="mt-4">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <label class="text-[10px] font-bold uppercase text-slate-400">Update status</label>
            <div class="mt-1 flex gap-2">
                <select name="status" class="ops-select text-xs">
                    {% for value, label in status_choices %}
                    <option value="{{ value }}" {% if order.status == value %}selected{% endif %}>{{ label }}</option>
                    {% endfor %}
                </select>
                <button type="submit" class="rounded-xl bg-gold-500 px-3 py-2 text-[10px] font-bold text-ink-900">Save</button>
            </div>
        </form>
    </article>
    {% endfor %}
</div>
{% else %}
<div class="dash-panel p-12 text-center text-slate-500">No orders assigned to you yet.</div>
{% endif %}
{% endblock %}
