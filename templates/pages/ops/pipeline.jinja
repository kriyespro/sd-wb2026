{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="grid gap-4 lg:grid-cols-4">
    {% for stage in stages %}
    <div class="rounded-2xl border border-slate-200/80 bg-slate-50/80 p-4">
        <div class="flex items-center justify-between">
            <h3 class="font-display text-sm font-semibold text-ink-900">{{ stage.label }}</h3>
            <span class="dash-badge bg-white text-slate-600 shadow-sm">{{ stage.applications|length }}</span>
        </div>
        <div class="mt-3 space-y-2">
            {% for app in stage.applications %}
            <div class="rounded-xl border border-slate-100 bg-white p-3 shadow-sm">
                <p class="text-sm font-medium text-slate-700">{{ app.name }}</p>
                <p class="text-xs text-slate-500">{{ app.course_interest or 'General' }}</p>
                <p class="mt-1 text-xs text-slate-400">{{ app.created_at.strftime('%d %b') }}</p>
            </div>
            {% else %}
            <p class="text-xs text-slate-400">Empty</p>
            {% endfor %}
        </div>
    </div>
    {% endfor %}
</div>

<div class="dash-panel mt-6">
    {% set title = 'Pipeline stages' %}{% include "partials/dashboard/_panel_header.jinja" %}
    <div class="p-5 sm:p-6">
        <div class="flex flex-wrap items-center gap-2 text-xs">
            {% for step in ['Applications', 'Assessments', 'Training', 'Mentor Allocation', 'Project Allocation', 'Performance', 'Graduation', 'Hiring'] %}
            <span class="rounded-lg bg-slate-100 px-3 py-1.5 font-medium text-slate-600">{{ step }}</span>
            {% if not loop.last %}<span class="text-slate-300">→</span>{% endif %}
            {% endfor %}
        </div>
        <p class="mt-4 text-xs text-slate-500">Manage application status in <a href="{{ url('admin:index') }}" class="font-semibold text-brand-600 hover:text-brand-700">admin</a> under Academy → Admission applications.</p>
    </div>
</div>
{% endblock %}
