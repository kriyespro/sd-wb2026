{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="mb-6 rounded-lg bg-brand-50 p-4 text-sm text-brand-800">
    Rule: every project needs <strong>1 PM (owner)</strong> and <strong>1 Senior Specialist (tech lead)</strong>.
    Students/interns need explicit authorization to contact clients.
</div>

<div class="grid gap-6 lg:grid-cols-3">
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="font-semibold text-brand-950">Assign to Project</h2>
        <form method="post" action="{{ url('operations:allocation_add') }}" class="mt-4 space-y-4">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Project</label>
                {{ form.project }}
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Team Member</label>
                {{ form.user }}
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Role</label>
                {{ form.role }}
            </div>
            <label class="flex items-center gap-2 text-sm text-slate-700">
                {{ form.can_contact_client }} Authorize client contact
            </label>
            <button type="submit" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">
                Assign
            </button>
        </form>
    </div>

    <div class="space-y-4 lg:col-span-2">
        {% for row in project_rows %}
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex items-center justify-between">
                <h3 class="font-medium text-brand-950">{{ row.project.name }}</h3>
                {% if row.issues %}
                <span class="text-xs text-red-600">⚠ {{ row.issues|join(', ') }}</span>
                {% else %}
                <span class="text-xs text-green-600">✓ Fully staffed</span>
                {% endif %}
            </div>
            {% if row.assignments %}
            <div class="mt-3 flex flex-wrap gap-2">
                {% for a in row.assignments %}
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs text-slate-600">
                    {{ a.user.get_full_name() or a.user.username }} · {{ a.get_role_display() }}
                    {% if a.can_contact_client %}<span class="text-green-600">· client-authorized</span>{% endif %}
                </span>
                {% endfor %}
            </div>
            {% else %}
            <p class="mt-3 text-xs text-slate-400">No one assigned yet.</p>
            {% endif %}
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
