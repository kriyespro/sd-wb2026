{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<section class="relative mb-6 overflow-hidden rounded-[1.75rem] bg-ink-900 px-6 py-7 text-white sm:px-8">
    <div class="pointer-events-none absolute -right-12 -top-12 h-40 w-40 rounded-full bg-violet-500/25 blur-3xl"></div>
    <div class="relative flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <div class="flex flex-wrap items-center gap-3">
                <span class="text-xs font-semibold uppercase tracking-[0.2em] text-gold-300">Hiring desk</span>
                <span class="rounded-full bg-white/10 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-slate-200">
                    {{ total_count }} total
                </span>
            </div>
            <h2 class="mt-2 font-display text-2xl font-bold">Job Applications</h2>
            <p class="mt-1 max-w-xl text-sm text-slate-300">
                Careers form submissions from the public site. Super Admin only.
            </p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="{{ url('website:careers') }}" target="_blank" rel="noopener"
               class="rounded-full border border-white/20 bg-white/5 px-4 py-2 text-xs font-bold text-white transition hover:bg-white/10">
                View /careers/
            </a>
            <a href="{{ url('operations:dashboard') }}"
               class="rounded-full border border-white/20 bg-white/5 px-4 py-2 text-xs font-bold text-white transition hover:bg-white/10">
                ← Mission Control
            </a>
        </div>
    </div>
</section>

<div class="mb-5 flex flex-wrap gap-2">
    {% for value, label in status_choices %}
    <span class="ops-chip
        {% if value == 'new' %}border-violet-200 bg-violet-50 text-violet-800
        {% elif value == 'hired' %}border-emerald-200 bg-emerald-50 text-emerald-800
        {% elif value == 'interview' %}border-amber-200 bg-amber-50 text-amber-800
        {% elif value == 'rejected' %}border-slate-200 bg-slate-50 text-slate-600
        {% endif %}">
        <span class="opacity-70">{{ label }}</span>
        <span class="font-bold">{{ status_counts[value] }}</span>
    </span>
    {% endfor %}
</div>

{% if applications %}
<div class="dash-panel overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full min-w-[960px] text-left text-sm">
            <thead class="border-b border-slate-100 bg-slate-50/80 text-[10px] uppercase tracking-[0.14em] text-slate-500">
                <tr>
                    <th class="px-5 py-3.5 font-semibold">Applicant</th>
                    <th class="px-4 py-3.5 font-semibold">Role</th>
                    <th class="px-4 py-3.5 font-semibold">Type</th>
                    <th class="px-4 py-3.5 font-semibold">Experience</th>
                    <th class="px-4 py-3.5 font-semibold">Links</th>
                    <th class="px-4 py-3.5 font-semibold">Applied</th>
                    <th class="px-4 py-3.5 font-semibold">Status</th>
                    <th class="px-5 py-3.5 font-semibold">Cover letter</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {% for app in applications %}
                {% include "partials/ops/_job_application_row.jinja" %}
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% include "components/pagination.jinja" %}
{% else %}
<div class="dash-panel p-12 text-center">
    <p class="font-display text-lg font-semibold text-ink-900">No job applications yet</p>
    <p class="mt-2 text-sm text-slate-500">
        Submissions from
        <a href="{{ url('website:careers') }}" class="font-semibold text-brand-600 hover:underline">/careers/</a>
        appear here.
    </p>
</div>
{% endif %}
{% endblock %}
