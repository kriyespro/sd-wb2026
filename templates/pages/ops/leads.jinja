{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="mb-6 flex flex-wrap items-center justify-between gap-4">
    <p class="text-sm text-slate-600">Manage inbound leads from the public site. Update status, assign sales, add handoff notes, and convert won leads to clients.</p>
    <div class="flex flex-wrap gap-2 text-xs">
        {% for value, label in status_choices %}
        <span class="rounded-full bg-slate-100 px-2.5 py-1 text-slate-600">{{ label }}: {{ status_counts[value] }}</span>
        {% endfor %}
    </div>
</div>

{% if leads %}
<div class="space-y-4">
    {% for lead in leads %}
    {% include "partials/_lead_row.jinja" %}
    {% endfor %}
</div>
{% else %}
<div class="dash-panel p-12 text-center">
    <p class="text-slate-500">No leads yet. Leads from contact forms and strategy calls appear here.</p>
</div>
{% endif %}
{% endblock %}
