{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="mb-6 flex flex-wrap items-center justify-between gap-4">
    <p class="text-sm text-slate-600">Manage inbound leads from the public site. Update status, assign sales, add handoff notes, and convert won leads to clients.</p>
    <div class="flex items-center gap-2">
        <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
        </span>
        <span class="text-xs font-medium text-emerald-700">Live</span>
    </div>
</div>

<div id="ops-leads-list"
     hx-get="{{ url('operations:live_leads') }}"
     hx-trigger="load, every 15s"
     hx-swap="innerHTML"
     hx-sync="this:drop">
    {% include "partials/ops/_leads_list.jinja" %}
</div>
{% endblock %}
