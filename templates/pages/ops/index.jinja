{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div id="mission-control-poll"
     hx-get="{{ url('operations:live_mission') }}"
     hx-trigger="load, every 15s"
     hx-swap="none"
     class="hidden"
     aria-hidden="true"></div>

{# Row 1: attention + jump links #}
<section class="mb-3 flex min-w-0 flex-col gap-2 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 shadow-sm sm:flex-row sm:items-center sm:justify-between sm:px-4">
    <div class="flex min-w-0 flex-wrap items-center gap-2">
        <span class="relative flex h-2 w-2 shrink-0">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-60"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
        </span>
        <span class="text-[10px] font-bold uppercase tracking-[0.14em] text-slate-400">Live</span>
        <span id="ops-live-timestamp" class="rounded bg-slate-100 px-1.5 py-0.5 font-mono text-[10px] font-semibold text-slate-600">
            {{ updated_at.strftime('%H:%M:%S') }}
        </span>
        <span class="hidden h-3 w-px bg-slate-200 sm:block"></span>
        <div id="ops-attention" class="min-w-0">
            {% include "partials/ops/_attention.jinja" %}
        </div>
    </div>
    <div class="flex shrink-0 flex-wrap gap-1">
        <a href="{{ url('operations:leads') }}" class="rounded-md bg-ink-900 px-2.5 py-1 text-[10px] font-bold text-white hover:bg-ink-800">Inbound</a>
        {% if include_jobs %}
        <a href="{{ url('operations:dgc_leads') }}" class="rounded-md border border-slate-200 px-2.5 py-1 text-[10px] font-semibold text-slate-600 hover:bg-slate-50">DGC</a>
        {% endif %}
        <a href="{{ url('operations:quality_check') }}" class="rounded-md border border-slate-200 px-2.5 py-1 text-[10px] font-semibold text-slate-600 hover:bg-slate-50">QA</a>
        <a href="{{ url('operations:invoices') }}" class="rounded-md border border-slate-200 px-2.5 py-1 text-[10px] font-semibold text-slate-600 hover:bg-slate-50">Billing</a>
        {% if include_jobs %}
        <a href="{{ url('operations:job_applications') }}" class="rounded-md border border-slate-200 px-2.5 py-1 text-[10px] font-semibold text-slate-600 hover:bg-slate-50">
            Jobs<span id="ops-jobs-badge">{% if job_application_new %} ({{ job_application_new }}){% endif %}</span>
        </a>
        <a href="{{ url('operations:dgc_applications') }}" class="rounded-md border border-slate-200 px-2.5 py-1 text-[10px] font-semibold text-slate-600 hover:bg-slate-50">Apps</a>
        {% endif %}
    </div>
</section>

{# Row 2: KPIs + pipeline (one unit) #}
<div id="ops-stats-bar" class="mb-3 min-w-0">
    {% include "partials/ops/_stats_bar.jinja" %}
</div>

{# Row 3: equal work panels — 2×3 grid, matched heights #}
<div class="grid min-w-0 grid-cols-1 gap-3 sm:grid-cols-2 {% if include_jobs %}xl:grid-cols-3{% endif %}">

    <section class="dash-panel flex min-h-[15rem] min-w-0 flex-col">
        <header class="flex shrink-0 items-center justify-between gap-2 border-b border-slate-100 px-3 py-2.5 sm:px-4">
            <div class="flex min-w-0 items-center gap-2">
                <span class="h-2 w-2 shrink-0 rounded-full bg-emerald-500"></span>
                <h2 class="truncate text-sm font-semibold text-ink-900">Inbound leads</h2>
            </div>
            <a href="{{ url('operations:leads') }}" class="shrink-0 text-[10px] font-semibold text-brand-600 hover:text-brand-700">Table →</a>
        </header>
        <div id="ops-leads-feed" class="min-h-0 flex-1 overflow-x-hidden overflow-y-auto px-3 sm:px-4">
            {% include "partials/ops/_leads_feed.jinja" %}
        </div>
    </section>

    {% if include_jobs %}
    <section class="dash-panel flex min-h-[15rem] min-w-0 flex-col">
        <header class="flex shrink-0 items-center justify-between gap-2 border-b border-slate-100 px-3 py-2.5 sm:px-4">
            <div class="flex min-w-0 items-center gap-2">
                <span class="h-2 w-2 shrink-0 rounded-full bg-teal-500"></span>
                <h2 class="truncate text-sm font-semibold text-ink-900">DGC leads</h2>
            </div>
            <a href="{{ url('operations:dgc_leads') }}" class="shrink-0 text-[10px] font-semibold text-brand-600 hover:text-brand-700">Table →</a>
        </header>
        <div id="ops-dgc-leads-feed" class="min-h-0 flex-1 overflow-x-hidden overflow-y-auto px-3 sm:px-4">
            {% include "partials/ops/_dgc_leads_feed.jinja" %}
        </div>
    </section>
    {% endif %}

    <section class="dash-panel flex min-h-[15rem] min-w-0 flex-col">
        <header class="flex shrink-0 items-center justify-between gap-2 border-b border-slate-100 px-3 py-2.5 sm:px-4">
            <div class="flex min-w-0 items-center gap-2">
                <span class="h-2 w-2 shrink-0 rounded-full bg-brand-600"></span>
                <h2 class="truncate text-sm font-semibold text-ink-900">Academy intake</h2>
            </div>
            <a href="{{ url('operations:pipeline') }}" class="shrink-0 text-[10px] font-semibold text-brand-600 hover:text-brand-700">Pipeline →</a>
        </header>
        <div id="ops-applications-feed" class="min-h-0 flex-1 overflow-x-hidden overflow-y-auto px-3 sm:px-4">
            {% include "partials/ops/_applications_feed.jinja" %}
        </div>
    </section>

    <section class="dash-panel flex min-h-[15rem] min-w-0 flex-col">
        <header class="flex shrink-0 items-center justify-between gap-2 border-b border-slate-100 px-3 py-2.5 sm:px-4">
            <div class="flex min-w-0 items-center gap-2">
                <span class="h-2 w-2 shrink-0 rounded-full bg-orange-500"></span>
                <h2 class="truncate text-sm font-semibold text-ink-900">QA queue</h2>
            </div>
            <a href="{{ url('operations:quality_check') }}" class="shrink-0 text-[10px] font-semibold text-brand-600 hover:text-brand-700">Review →</a>
        </header>
        <div id="ops-qa-queue" class="min-h-0 flex-1 overflow-x-hidden overflow-y-auto px-3 sm:px-4">
            {% include "partials/ops/_qa_queue.jinja" %}
        </div>
    </section>

    {% if include_jobs %}
    <section class="dash-panel flex min-h-[15rem] min-w-0 flex-col">
        <header class="flex shrink-0 items-center justify-between gap-2 border-b border-slate-100 px-3 py-2.5 sm:px-4">
            <div class="flex min-w-0 items-center gap-2">
                <span class="h-2 w-2 shrink-0 rounded-full bg-cyan-500"></span>
                <h2 class="truncate text-sm font-semibold text-ink-900">DGC applications</h2>
            </div>
            <a href="{{ url('operations:dgc_applications') }}" class="shrink-0 text-[10px] font-semibold text-brand-600 hover:text-brand-700">Approve →</a>
        </header>
        <div id="ops-dgc-apps-feed" class="min-h-0 flex-1 overflow-x-hidden overflow-y-auto px-3 sm:px-4">
            {% include "partials/ops/_dgc_apps_feed.jinja" %}
        </div>
    </section>

    <section class="dash-panel flex min-h-[15rem] min-w-0 flex-col">
        <header class="flex shrink-0 items-center justify-between gap-2 border-b border-slate-100 px-3 py-2.5 sm:px-4">
            <div class="flex min-w-0 items-center gap-2">
                <span class="h-2 w-2 shrink-0 rounded-full bg-violet-500"></span>
                <h2 class="truncate text-sm font-semibold text-ink-900">Job applications</h2>
            </div>
            <div class="flex shrink-0 items-center gap-2">
                <span id="ops-hiring-chips" class="hidden text-[10px] font-medium text-slate-400 lg:inline">
                    {{ stats.new_job_applications }} new
                </span>
                <a href="{{ url('operations:job_applications') }}" class="text-[10px] font-semibold text-brand-600 hover:text-brand-700">Table →</a>
            </div>
        </header>
        <div id="ops-jobs-feed" class="min-h-0 flex-1 overflow-x-hidden overflow-y-auto px-3 sm:px-4">
            {% include "partials/ops/_jobs_feed.jinja" %}
        </div>
    </section>
    {% endif %}
</div>
{% endblock %}
