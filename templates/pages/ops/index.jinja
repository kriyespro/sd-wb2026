{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{# Live poll — OOB swaps only #}
<div id="mission-control-poll"
     hx-get="{{ url('operations:live_mission') }}"
     hx-trigger="load, every 15s"
     hx-swap="none"
     class="hidden"
     aria-hidden="true"></div>

{# Command header #}
<section class="relative mb-8 overflow-hidden rounded-[1.75rem] bg-ink-900 px-6 py-8 text-white sm:px-8">
    <div class="pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full bg-brand-500/20 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-20 left-1/3 h-48 w-48 rounded-full bg-gold-500/10 blur-3xl"></div>
    <div class="relative flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <div class="flex flex-wrap items-center gap-3">
                <span class="relative flex h-2.5 w-2.5">
                    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
                </span>
                <span class="text-xs font-semibold uppercase tracking-[0.2em] text-gold-300">Mission Control</span>
                <span id="ops-live-timestamp" class="text-[10px] text-slate-400">
                    Updated {{ updated_at.strftime('%H:%M:%S') }}
                </span>
            </div>
            <h2 class="mt-3 font-display text-2xl font-bold sm:text-3xl">Ops command center</h2>
            <p class="mt-2 max-w-xl text-sm text-slate-300">
                Live leads, QA, academy intake{% if include_jobs %}, and job applications{% endif %} — refresh every 15s.
            </p>
            <div id="ops-attention" class="mt-5">
                {% include "partials/ops/_attention.jinja" %}
            </div>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="{{ url('operations:leads') }}" class="rounded-full bg-gold-500 px-4 py-2 text-xs font-bold text-ink-900 transition hover:bg-gold-400">Manage Leads →</a>
            <a href="{{ url('operations:quality_check') }}" class="rounded-full border border-white/20 bg-white/5 px-4 py-2 text-xs font-bold text-white transition hover:bg-white/10">QA Queue</a>
            {% if include_jobs %}
            <a href="{{ url('operations:job_applications') }}" class="rounded-full border border-white/20 bg-white/5 px-4 py-2 text-xs font-bold text-white transition hover:bg-white/10">
                Jobs <span id="ops-jobs-badge">{% if job_application_new %}({{ job_application_new }} new){% endif %}</span>
            </a>
            {% endif %}
        </div>
    </div>
</section>

{# Quick actions #}
<section class="mb-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6">
    {% set actions = [
        {'label': 'Leads', 'desc': 'Inbound pipeline', 'url': 'operations:leads', 'icon': '📞'},
        {'label': 'Quality Check', 'desc': 'Approve delivery', 'url': 'operations:quality_check', 'icon': '✔️'},
        {'label': 'Projects', 'desc': 'Active delivery', 'url': 'operations:projects', 'icon': '📁'},
        {'label': 'Talent Pipeline', 'desc': 'Academy apps', 'url': 'operations:pipeline', 'icon': '🔄'},
        {'label': 'Allocation', 'desc': 'Staff projects', 'url': 'operations:allocation', 'icon': '🔗'},
        {'label': 'Invoices', 'desc': 'Billing status', 'url': 'operations:invoices', 'icon': '🧾'},
    ] %}
    {% for action in actions %}
    <a href="{{ url(action.url) }}"
       class="group rounded-2xl border border-slate-200 bg-white p-4 transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md">
        <span class="text-lg">{{ action.icon }}</span>
        <p class="mt-2 text-sm font-semibold text-ink-900 group-hover:text-brand-700">{{ action.label }}</p>
        <p class="text-[11px] text-slate-500">{{ action.desc }}</p>
    </a>
    {% endfor %}
</section>

<div id="ops-stats-bar" class="mb-8">
    {% include "partials/ops/_stats_bar.jinja" %}
</div>

<div class="mb-6 grid gap-6 lg:grid-cols-3">
    <div class="dash-panel lg:col-span-2">
        <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4 sm:px-6">
            <div>
                <h2 class="font-display text-base font-semibold text-ink-900">Inbound Leads</h2>
                <p class="text-xs text-slate-500">Latest form submissions from the public site</p>
            </div>
            <a href="{{ url('operations:leads') }}" class="text-xs font-semibold text-brand-600 hover:text-brand-700">View all</a>
        </div>
        <div id="ops-leads-feed" class="p-5 sm:p-6">
            {% include "partials/ops/_leads_feed.jinja" %}
        </div>
    </div>

    <div class="dash-panel">
        <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4 sm:px-6">
            <div>
                <h2 class="font-display text-base font-semibold text-ink-900">QA Queue</h2>
                <p class="text-xs text-slate-500">Deliverables awaiting review</p>
            </div>
            <a href="{{ url('operations:quality_check') }}" class="text-xs font-semibold text-brand-600 hover:text-brand-700">Review</a>
        </div>
        <div id="ops-qa-queue" class="p-5 sm:p-6">
            {% include "partials/ops/_qa_queue.jinja" %}
        </div>
    </div>
</div>

<div class="mb-6 grid gap-6 lg:grid-cols-3">
    <div class="dash-panel lg:col-span-2">
        <div class="border-b border-slate-100 px-5 py-4 sm:px-6">
            <h2 class="font-display text-base font-semibold text-ink-900">Lead Pipeline</h2>
            <p class="text-xs text-slate-500">Counts by stage — updated live</p>
        </div>
        <div id="ops-pipeline-bar" class="p-5 sm:p-6">
            {% include "partials/ops/_pipeline_bar.jinja" %}
        </div>
    </div>

    <div class="dash-panel">
        <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4 sm:px-6">
            <div>
                <h2 class="font-display text-base font-semibold text-ink-900">Academy Intake</h2>
                <p class="text-xs text-slate-500">New applications</p>
            </div>
            <a href="{{ url('operations:pipeline') }}" class="text-xs font-semibold text-brand-600 hover:text-brand-700">Pipeline</a>
        </div>
        <div id="ops-applications-feed" class="p-5 sm:p-6">
            {% include "partials/ops/_applications_feed.jinja" %}
        </div>
    </div>
</div>

{% if include_jobs %}
<div class="mb-6 grid gap-6 lg:grid-cols-3">
    <div class="dash-panel lg:col-span-2">
        <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4 sm:px-6">
            <div>
                <h2 class="font-display text-base font-semibold text-ink-900">Job Applications</h2>
                <p class="text-xs text-slate-500">Careers form submissions — superuser only</p>
            </div>
            <a href="{{ url('operations:job_applications') }}" class="text-xs font-semibold text-brand-600 hover:text-brand-700">Open table →</a>
        </div>
        <div id="ops-jobs-feed" class="p-5 sm:p-6">
            {% include "partials/ops/_jobs_feed.jinja" %}
        </div>
    </div>

    <div class="dash-panel">
        <div class="border-b border-slate-100 px-5 py-4 sm:px-6">
            <h2 class="font-display text-base font-semibold text-ink-900">Hiring snapshot</h2>
            <p class="text-xs text-slate-500">From /careers/</p>
        </div>
        <div class="space-y-3 p-5 sm:p-6">
            <div class="rounded-2xl border border-violet-100 bg-gradient-to-br from-violet-50 to-white px-4 py-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-violet-600">New applications</p>
                <p class="mt-1 font-display text-3xl font-bold text-violet-900">{{ job_application_new }}</p>
            </div>
            <div class="rounded-2xl border border-slate-100 bg-slate-50 px-4 py-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Total received</p>
                <p class="mt-1 font-display text-3xl font-bold text-ink-900">{{ job_application_count }}</p>
            </div>
            <a href="{{ url('operations:job_applications') }}"
               class="inline-flex w-full items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-xs font-semibold text-slate-700 transition hover:border-brand-200 hover:bg-brand-50 hover:text-brand-700">
                Review all applications →
            </a>
        </div>
    </div>
</div>
{% endif %}

<div class="dash-panel">
    <div class="border-b border-slate-100 px-5 py-4 sm:px-6">
        <h2 class="font-display text-base font-semibold text-ink-900">Delivery Workflow</h2>
        <p class="text-xs text-slate-500">End-to-end ops flow</p>
    </div>
    <div class="p-5 sm:p-6">
        <div class="flex flex-wrap items-center gap-1.5 text-xs">
            {% for step in ['Lead', 'Sales', 'Consultant', 'PM', 'Senior Expert', 'Student Team', 'QA', 'Delivery'] %}
            <span class="rounded-lg bg-slate-100 px-2.5 py-1.5 font-medium text-slate-600">{{ step }}</span>
            {% if not loop.last %}<span class="text-slate-300">→</span>{% endif %}
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
