{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div id="mission-control-poll"
     hx-get="{{ url('operations:live_mission') }}"
     hx-trigger="load, every 15s"
     hx-swap="none"
     class="hidden"
     aria-hidden="true"></div>

<div class="mx-auto min-w-0 max-w-[1400px] space-y-4 overflow-x-hidden">
    <div id="ops-stats-bar" class="min-w-0">
        {% include "partials/ops/_stats_bar.jinja" %}
    </div>

    <div class="grid min-w-0 grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-3">
        {% macro panel(tone, title, href, link_label, feed_id, partial) %}
        <section class="dash-panel flex h-[20rem] min-w-0 flex-col overflow-hidden">
            <header class="flex shrink-0 items-center justify-between gap-2 border-b border-slate-100 bg-slate-50/50 px-3.5 py-2.5">
                <div class="flex min-w-0 items-center gap-2">
                    <span class="h-2 w-2 shrink-0 rounded-full {{ tone }}"></span>
                    <h2 class="truncate text-[13px] font-semibold text-ink-900">{{ title }}</h2>
                </div>
                <a href="{{ href }}" class="shrink-0 text-[10px] font-bold uppercase tracking-wide text-brand-600 hover:text-brand-700">{{ link_label }}</a>
            </header>
            <div id="{{ feed_id }}" class="min-h-0 min-w-0 flex-1 overflow-x-hidden overflow-y-auto px-3.5 py-1">
                {% include partial %}
            </div>
        </section>
        {% endmacro %}

        {{ panel('bg-emerald-500', 'Inbound leads', url('operations:leads'), 'Open →', 'ops-leads-feed', 'partials/ops/_leads_feed.jinja') }}

        {% if include_jobs %}
        {{ panel('bg-teal-500', 'DGC leads', url('operations:dgc_leads'), 'Open →', 'ops-dgc-leads-feed', 'partials/ops/_dgc_leads_feed.jinja') }}
        {% endif %}

        {{ panel('bg-brand-600', 'Academy intake', url('operations:pipeline'), 'Open →', 'ops-applications-feed', 'partials/ops/_applications_feed.jinja') }}

        {{ panel('bg-orange-500', 'QA queue', url('operations:quality_check'), 'Review →', 'ops-qa-queue', 'partials/ops/_qa_queue.jinja') }}

        {% if include_jobs %}
        {{ panel('bg-cyan-500', 'DGC applications', url('operations:dgc_applications'), 'Approve →', 'ops-dgc-apps-feed', 'partials/ops/_dgc_apps_feed.jinja') }}

        <section class="dash-panel flex h-[20rem] min-w-0 flex-col overflow-hidden">
            <header class="flex shrink-0 items-center justify-between gap-2 border-b border-slate-100 bg-slate-50/50 px-3.5 py-2.5">
                <div class="flex min-w-0 items-center gap-2">
                    <span class="h-2 w-2 shrink-0 rounded-full bg-violet-500"></span>
                    <h2 class="truncate text-[13px] font-semibold text-ink-900">Job applications</h2>
                    <span id="ops-hiring-chips" class="hidden truncate text-[10px] font-medium text-slate-400 sm:inline">{{ stats.new_job_applications }} new</span>
                </div>
                <a href="{{ url('operations:job_applications') }}" class="shrink-0 text-[10px] font-bold uppercase tracking-wide text-brand-600 hover:text-brand-700">Open →</a>
            </header>
            <div id="ops-jobs-feed" class="min-h-0 min-w-0 flex-1 overflow-x-hidden overflow-y-auto px-3.5 py-1">
                {% include "partials/ops/_jobs_feed.jinja" %}
            </div>
        </section>
        {% endif %}
    </div>
</div>
{% endblock %}
