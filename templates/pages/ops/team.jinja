{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if teams %}
<div class="grid gap-6 md:grid-cols-2">
    {% for team in teams %}
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="font-semibold text-brand-950">{{ team.name }}</h3>
        {% if team.description %}<p class="mt-1 text-sm text-slate-600">{{ team.description }}</p>{% endif %}
        <div class="mt-4 space-y-2">
            {% for member in team.members.all() %}
            <div class="flex items-center justify-between text-sm">
                <span class="text-slate-700">{{ member.user.get_full_name() or member.user.username }}</span>
                <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-600">{{ member.get_seniority_display() }}</span>
            </div>
            {% else %}
            <p class="text-xs text-slate-400">No members.</p>
            {% endfor %}
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">No teams defined. Create teams in admin under Operations.</p>
</div>
{% endif %}

<div class="mt-6 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="font-semibold text-brand-950">Org Structure</h2>
    <p class="mt-2 text-sm text-slate-600">CEO → COO → Agency Director → Teams</p>
    <p class="mt-1 text-xs text-slate-500">Each team: Senior → Executive → Intern → Student</p>
</div>
{% endblock %}
