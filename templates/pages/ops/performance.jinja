{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if reviews %}
<div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-slate-500">
            <tr>
                <th class="px-6 py-3 font-medium">Member</th>
                <th class="px-6 py-3 font-medium">Period</th>
                <th class="px-6 py-3 font-medium">Rating</th>
                <th class="px-6 py-3 font-medium">Reviewer</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            {% for review in reviews %}
            <tr>
                <td class="px-6 py-4 font-medium text-slate-700">{{ review.user.get_full_name() or review.user.username }}</td>
                <td class="px-6 py-4 text-slate-600">{{ review.period }}</td>
                <td class="px-6 py-4">
                    <span class="text-yellow-500">{{ '★' * review.rating }}</span><span class="text-slate-300">{{ '★' * (5 - review.rating) }}</span>
                </td>
                <td class="px-6 py-4 text-slate-600">
                    {% if review.reviewer %}{{ review.reviewer.get_full_name() or review.reviewer.username }}{% else %}—{% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">No performance reviews yet.</p>
</div>
{% endif %}
{% endblock %}
