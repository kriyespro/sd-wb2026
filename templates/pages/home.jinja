                            <p class="mt-2 text-sm leading-relaxed text-slate-500">{{ service.short }}</p>
                            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-gold-600 opacity-0 transition group-hover:opacity-100">Learn more →</span>
