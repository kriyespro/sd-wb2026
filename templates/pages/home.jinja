                    <img src="{{ featured_case_study.image }}" alt="{{ featured_case_study.title }}" class="absolute inset-0 h-full w-full object-cover">
                    <div class="absolute inset-0 bg-gradient-to-t from-brand-900/80 via-brand-900/20 to-transparent lg:bg-gradient-to-r lg:from-transparent lg:via-brand-900/10 lg:to-brand-900/40"></div>
