{% extends "base.jinja" %}

{% block content %}
<!-- ANNOUNCEMENT -->
<div class="border-b border-gold-600/30 bg-brand-900 py-2.5 text-center text-sm text-white">
    <span class="text-slate-300">We help textile manufacturers sell direct to customers —</span>
    <a href="{{ url('website:contact') }}" class="ml-1 font-semibold text-gold-300 hover:text-gold-200">Book a free call today →</a>
</div>

<!-- HERO -->
<section class="relative min-h-[calc(100vh-76px)] overflow-hidden bg-white">
    <span class="wm text-brand-100" style="font-size:14vw;bottom:22%;left:-1%;letter-spacing:-0.03em">DIRECT</span>
    <span class="wm text-brand-50" style="font-size:9vw;bottom:2%;right:0;letter-spacing:-0.03em">PROFIT</span>

    <div class="relative mx-auto flex min-h-[calc(100vh-76px)] max-w-7xl flex-col px-4 sm:px-6 lg:flex-row lg:items-end lg:px-8">
        <div class="flex flex-col justify-center pb-12 pt-10 lg:w-[52%] lg:pb-24 lg:pt-16">
            <span class="eyebrow animate-fade-up">We help manufacturers sell direct to customers</span>
            <h1 class="mt-7 font-display text-[clamp(2.75rem,5vw+1rem,4.5rem)] font-semibold leading-[0.92] tracking-tight text-ink-900 animate-fade-up" style="animation-delay:.05s">
                Your product.<br>
                Your price.<br>
                <span class="font-serif text-gradient-gold">Your profit.</span>
            </h1>
            <p class="mt-6 max-w-md text-base leading-relaxed text-slate-600 animate-fade-up" style="animation-delay:.1s">
                At Winning Blueprints, we help textile manufacturers sell sarees, t-shirts, jeans, and kurtis
                <strong class="font-semibold text-ink-900">directly to customers</strong> — online, prepaid, and with
                <strong class="font-semibold text-ink-900">2x–4x higher profit margins.</strong>
            </p>
            <div class="mt-9 flex flex-wrap gap-4 animate-fade-up" style="animation-delay:.15s">
                <a href="{{ url('website:contact') }}" class="btn-gold">Book Free Consultation →</a>
                <a href="{{ url('website:services') }}" class="btn-outline">Explore Services</a>
            </div>

            <div class="mt-8 flex flex-wrap gap-3 animate-fade-up" style="animation-delay:.18s">
                <div class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm">
                    <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-brand-50 text-brand-700">
                        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l2.4 7.4H22l-6 4.6 2.3 7-6.3-4.6L5.7 21l2.3-7-6-4.6h7.6z"/></svg>
                    </span>
                    <div>
                        <div class="flex gap-0.5 text-gold-500">
                            {% for _ in range(5) %}<svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.958a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.368 2.447a1 1 0 00-.363 1.118l1.287 3.957c.3.922-.755 1.688-1.538 1.118l-3.367-2.446a1 1 0 00-1.176 0l-3.367 2.446c-.783.57-1.838-.196-1.538-1.118l1.287-3.957a1 1 0 00-.363-1.118L2.062 9.385c-.783-.57-.38-1.81.588-1.81h4.163a1 1 0 00.95-.69l1.286-3.958z"/></svg>{% endfor %}
                        </div>
                        <p class="text-xs font-semibold text-ink-900">98% <span class="font-normal text-slate-500">satisfied clients</span></p>
                    </div>
                </div>
                <div class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-sm">
                    <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-gold-100 font-display text-xs font-bold text-gold-700">WB</span>
                    <div>
                        <p class="text-xs font-semibold text-ink-900">{{ stats[0].value }}{{ stats[0].suffix }} Years</p>
                        <p class="text-[11px] text-slate-500">{{ stats[1].value }}{{ stats[1].suffix }} profit margins</p>
                    </div>
                </div>
            </div>

            <ul class="mt-8 space-y-2.5 text-sm text-slate-600 animate-fade-up" style="animation-delay:.2s">
                {% for point in hero_points %}
                <li class="flex items-center gap-2.5">
                    <span class="flex h-5 w-5 items-center justify-center rounded-full bg-gold-100 text-xs text-gold-600">✓</span>
                    {{ point }}
                </li>
                {% endfor %}
            </ul>
        </div>

        <div class="relative flex flex-1 items-end justify-center pb-12 lg:-translate-y-[200px] lg:justify-end lg:pb-20">
            <div class="absolute bottom-32 right-0 hidden h-[70%] w-[55%] rounded-tl-[3rem] bg-gradient-to-br from-slate-50 via-gold-50/40 to-brand-50 lg:block"></div>
            <div class="relative w-full max-w-md lg:max-w-lg">
                <div class="absolute -right-4 top-16 z-20 hidden rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-xl sm:flex sm:items-center sm:gap-3">
                    <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                    </span>
                    <div>
                        <p class="font-display text-sm font-bold text-ink-900">+60%</p>
                        <p class="text-[11px] text-slate-500">Profit margin lift</p>
                    </div>
                </div>
                <div class="absolute -left-2 bottom-36 z-20 hidden rounded-2xl border border-slate-200 bg-white px-4 py-3 shadow-xl sm:flex sm:items-center sm:gap-3">
                    <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-gold-100 text-gold-700">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    </span>
                    <div>
                        <p class="font-display text-sm font-bold text-ink-900">{{ stats[0].value }}{{ stats[0].suffix }}</p>
                        <p class="text-[11px] text-slate-500">Years experience</p>
                    </div>
                </div>
                <div class="absolute right-6 top-[42%] z-20 hidden rounded-2xl bg-brand-700 px-4 py-3 shadow-xl lg:block">
                    <p class="font-display text-sm font-bold text-white">Prepaid Orders</p>
                    <p class="text-[11px] text-gold-200">No credit risk</p>
                </div>
                <div class="relative z-10 overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-2xl shadow-brand-900/10">
                    <img src="{{ site_images.about_team }}" alt="Winning Blueprints team" class="h-56 w-full object-cover object-top sm:h-72">
                    <div class="grid grid-cols-2 gap-px bg-slate-100 p-px">
                        {% for stat in stats[:4] %}
                        <div class="bg-white px-4 py-4 text-center sm:px-5">
                            <div class="font-display text-xl font-bold text-brand-700 sm:text-2xl">{{ stat.value }}{{ stat.suffix }}</div>
                            <div class="text-[10px] uppercase tracking-wider text-slate-500 sm:text-xs">{{ stat.label }}</div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- TRUST MARQUEE -->
<section class="border-y border-slate-200 bg-slate-50 py-10">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Built for manufacturers going direct</p>
    <div class="relative mt-6 overflow-hidden">
        <div class="flex w-max animate-marquee items-center gap-10">
            {% for i in range(2) %}
            {% for tag in audience_tags %}
            <span class="whitespace-nowrap rounded-full border border-slate-200 bg-white px-5 py-2 text-sm font-semibold text-ink-900 shadow-sm">{{ tag }}</span>
            <span class="text-gold-400">✦</span>
            {% endfor %}
            {% endfor %}
        </div>
    </div>
</section>

<!-- ABOUT PREVIEW -->
<section class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-2">
            <div class="relative">
                <img src="{{ site_images.about_team }}" alt="Our team at work" class="aspect-[4/3] w-full rounded-3xl object-cover shadow-xl">
                <div class="absolute -bottom-6 -right-4 rounded-2xl border border-slate-200 bg-white p-5 shadow-xl sm:-right-6">
                    <p class="font-display text-3xl font-bold text-brand-700">{{ stats[0].value }}{{ stats[0].suffix }}</p>
                    <p class="text-sm text-slate-600">{{ stats[0].label }}</p>
                </div>
            </div>
            <div>
                <span class="eyebrow">Who we are</span>
                <h2 class="mt-5 font-display text-3xl font-bold leading-tight text-ink-900 sm:text-4xl">
                    Designed to take factories <span class="text-gradient-gold">directly to consumers</span>
                </h2>
                <p class="mt-6 leading-relaxed text-slate-600">
                    We build factory-to-customer (F2C) pipelines — store, ads, prepaid orders, and backoffice —
                    so you control your brand, your prices, and your profit.
                </p>
                <p class="mt-4 leading-relaxed text-slate-600">
                    Behind the scenes, our internal Academy trains specialists on real client work — so you get
                    agency-quality delivery at scale, without hiring a full digital team yourself.
                </p>
                <div class="mt-8 flex flex-wrap gap-4">
                    <a href="{{ url('website:about') }}" class="btn-primary">About Us →</a>
                    <a href="{{ url('website:case_studies') }}" class="btn-outline">See Results</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SERVICES -->
<section class="bg-slate-50 py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
            <div class="lg:col-span-5">
                <div class="lg:sticky lg:top-28">
                    <span class="eyebrow">Tailored service offerings</span>
                    <h2 class="mt-5 font-display text-4xl font-bold leading-tight text-ink-900 sm:text-5xl">
                        Select the ideal plan for you
                    </h2>
                    <p class="mt-6 max-w-md leading-relaxed text-slate-600">
                        From eCommerce and Meta ads to backoffice SOPs — packages built for manufacturers
