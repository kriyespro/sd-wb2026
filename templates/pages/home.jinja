                        <a href="{{ url('website:case_studies') }}" class="btn-outline">All Case Studies</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endif %}

<!-- PROJECTS -->
<section class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
            <div>
                <span class="eyebrow">Selected work</span>
                <h2 class="mt-5 font-display text-3xl font-bold text-ink-900 sm:text-4xl">Recent projects &amp; results</h2>
            </div>
            <a href="{{ url('website:our_work') }}" class="text-sm font-semibold text-brand-600 hover:text-brand-700">View all work →</a>
        </div>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {% for project in recent_projects %}
            <a href="{{ url('website:our_work') }}" class="group section-card overflow-hidden">
                <div class="relative overflow-hidden">
                    <img src="{{ project.image }}" alt="{{ project.title }}" class="h-48 w-full object-cover transition duration-500 group-hover:scale-105">
                    <div class="absolute inset-0 bg-brand-900/0 transition group-hover:bg-brand-900/20"></div>
                </div>
                <div class="p-6">
                    <span class="rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">{{ project.category }}</span>
                    <h3 class="mt-4 font-display text-lg font-semibold text-ink-900 group-hover:text-brand-700">{{ project.title }}</h3>
                    <p class="mt-2 font-display text-xl font-bold text-gold-600">{{ project.result }}</p>
                </div>
            </a>
            {% endfor %}
        </div>
    </div>
</section>

<!-- PRICING PREVIEW -->
<section class="bg-slate-50 py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <span class="eyebrow justify-center">Pricing</span>
            <h2 class="mt-5 font-display text-3xl font-bold text-ink-900 sm:text-4xl">Flexible plans for your factory</h2>
            <p class="mt-4 text-slate-600">Priced for factory size and growth goals — from first D2C store to full-scale ads & ops.</p>
        </div>
        <div class="mt-14 grid gap-6 lg:grid-cols-3">
            {% for tier in pricing_tiers %}
            <div class="section-card relative flex flex-col p-8 {% if tier.highlight %}border-brand-400 ring-2 ring-brand-400/20{% endif %}">
                {% if tier.highlight %}
                <span class="absolute -top-3 left-8 rounded-full bg-gold-500 px-3 py-1 text-xs font-bold uppercase text-ink-900">Most Popular</span>
                {% endif %}
                <h3 class="font-display text-xl font-bold text-ink-900">{{ tier.name }}</h3>
                <div class="mt-4 font-display text-4xl font-bold text-brand-700">{{ tier.price }}<span class="text-base font-normal text-slate-500">{{ tier.period }}</span></div>
                <ul class="mt-6 flex-1 space-y-3 text-sm text-slate-600">
                    {% for feature in tier.features %}
                    <li class="flex gap-2"><span class="text-gold-500">✓</span>{{ feature }}</li>
                    {% endfor %}
                </ul>
                <a href="{{ url('website:contact') }}" class="{% if tier.highlight %}btn-gold{% else %}btn-outline{% endif %} mt-8 w-full text-center">Get Started</a>
            </div>
            {% endfor %}
        </div>
        <p class="mt-8 text-center">
            <a href="{{ url('website:pricing') }}" class="text-sm font-semibold text-brand-600 hover:text-brand-700">View full pricing details →</a>
        </p>
    </div>
</section>

<!-- TESTIMONIALS -->
<section class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-10 lg:grid-cols-3">
            <div class="lg:col-span-1">
                <span class="eyebrow">Client stories</span>
                <h2 class="mt-5 font-display text-3xl font-bold text-ink-900">What our clients say</h2>
                <p class="mt-4 text-slate-600">Manufacturers who went direct — and kept the margin.</p>
            </div>
            <div class="grid gap-6 sm:grid-cols-2 lg:col-span-2">
                {% for t in testimonials %}
                <figure class="section-card flex flex-col p-8">
                    <div class="flex gap-0.5 text-gold-500">
                        {% for _ in range(5) %}
                        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.958a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.368 2.447a1 1 0 00-.363 1.118l1.287 3.957c.3.922-.755 1.688-1.538 1.118l-3.367-2.446a1 1 0 00-1.176 0l-3.367 2.446c-.783.57-1.838-.196-1.538-1.118l1.287-3.957a1 1 0 00-.363-1.118L2.062 9.385c-.783-.57-.38-1.81.588-1.81h4.163a1 1 0 00.95-.69l1.286-3.958z"/></svg>
                        {% endfor %}
                    </div>
                    <blockquote class="mt-5 flex-1 text-sm leading-relaxed text-slate-600">"{{ t.quote }}"</blockquote>
                    <figcaption class="mt-6 flex items-center gap-3 border-t border-slate-100 pt-6">
                        {% if t.photo %}
                        <img src="{{ t.photo }}" alt="{{ t.name }}" class="h-11 w-11 rounded-full object-cover">
                        {% else %}
                        <span class="flex h-11 w-11 items-center justify-center rounded-full bg-brand-700 text-sm font-bold text-gold-300">{{ t.initials }}</span>
                        {% endif %}
                        <div>
                            <div class="text-sm font-semibold text-ink-900">{{ t.name }}</div>
                            <div class="text-xs text-slate-500">{{ t.role }}, {{ t.company }}</div>
                        </div>
                    </figcaption>
                </figure>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<!-- INDUSTRIES -->
<section class="border-y border-slate-200 bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
            <div>
                <span class="eyebrow">Industries</span>
                <h2 class="mt-5 font-display text-3xl font-bold text-ink-900">Growth strategies for your sector</h2>
            </div>
            <a href="{{ url('website:industries') }}" class="text-sm font-semibold text-brand-600 hover:text-brand-700">All industries →</a>
        </div>
        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {% for industry in industries %}
            <div class="rounded-2xl border border-slate-200 bg-white p-6 transition hover:border-brand-300 hover:shadow-md">
                <span class="text-2xl">{{ industry.icon }}</span>
                <h3 class="mt-4 font-display font-semibold text-ink-900">{{ industry.title }}</h3>
                <p class="mt-2 text-sm text-slate-600">{{ industry.desc }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- ACADEMY CTA -->
<section class="bg-brand-900 py-16 text-white">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-8 px-4 sm:px-6 md:flex-row lg:px-8">
        <div>
            <span class="text-xs font-semibold uppercase tracking-widest text-gold-300">Winning Blueprints Academy</span>
            <h2 class="mt-3 font-display text-2xl font-bold sm:text-3xl">Train the next generation of digital experts</h2>
            <p class="mt-3 max-w-xl text-slate-300">Job-ready programs in AI, automation, digital marketing, and more — with real projects and mentor support.</p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-4">
            <a href="{{ url('academy:courses') }}" class="btn-gold">Explore Courses →</a>
            <a href="{{ url('academy:apply') }}" class="btn-outline !border-white/30 !text-white hover:!bg-white/10">Apply Now</a>
        </div>
    </div>
</section>

<!-- FAQ -->
<section class="py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
            <span class="eyebrow justify-center">FAQ</span>
            <h2 class="mt-5 font-display text-3xl font-bold text-ink-900">Common questions</h2>
        </div>
        <div class="mt-10 space-y-3" x-data="{ open: 0 }">
            {% for faq in general_faqs %}
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
                <button type="button" @click="open = open === {{ loop.index }} ? 0 : {{ loop.index }}"
                        class="flex w-full items-center justify-between gap-4 px-6 py-5 text-left">
                    <span class="font-display font-semibold text-ink-900">{{ faq.q }}</span>
                    <svg class="h-5 w-5 shrink-0 text-slate-400 transition" :class="open === {{ loop.index }} ? 'rotate-45' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                </button>
                <div x-show="open === {{ loop.index }}" x-cloak x-transition class="border-t border-slate-100 px-6 py-4">
                    <p class="text-sm leading-relaxed text-slate-600">{{ faq.a }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- LEAD FORM CTA -->
<section class="bg-slate-50 pb-24 pt-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-2xl shadow-brand-900/5">
            <div class="grid lg:grid-cols-5">
                <div class="bg-brand-900 p-10 text-white lg:col-span-2">
                    <h2 class="font-display text-2xl font-bold sm:text-3xl">Ready to start selling directly?</h2>
                    <p class="mt-4 text-sm text-slate-300">Tell us about your factory. We'll map a D2C plan — store, ads, prepaid orders — within 24 hours.</p>
                    <div class="mt-8 space-y-3 text-sm">
                        {% for point in ['Free consultation', '30–45 day path to first orders', 'You focus on production'] %}
                        <div class="flex items-center gap-2 text-slate-200">
                            <span class="text-gold-400">✓</span> {{ point }}
                        </div>
                        {% endfor %}
                    </div>
                </div>
                <div class="p-8 lg:col-span-3 lg:p-10">
                    {% set source_page = 'home' %}
                    {% include "partials/_lead_form.jinja" %}
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
