</section>

<!-- WHY CHOOSE US -->
<section class="bg-slate-50 py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
            <span class="eyebrow justify-center">Why manufacturers choose us</span>
            <h2 class="mt-5 font-display text-3xl font-bold text-ink-900 sm:text-4xl">Bypass wholesale. Own the customer.</h2>
            <p class="mt-4 text-slate-600">Proven systems that take factories directly to consumers — prepaid, branded, and profitable.</p>
        </div>

        <div class="mt-12 overflow-hidden rounded-3xl bg-brand-900 text-white shadow-xl shadow-brand-900/20">
            <div class="grid gap-8 p-8 sm:p-10 lg:grid-cols-2 lg:items-center lg:gap-12">
                <div>
                    <span class="inline-flex rounded-full bg-gold-500/20 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-gold-300">Core promise</span>
                    <h3 class="mt-5 font-display text-2xl font-bold sm:text-3xl">Factory → Customer. Direct.</h3>
                    <p class="mt-4 max-w-lg text-sm leading-relaxed text-slate-300 sm:text-base">
                        Store setup, traffic & ads, prepaid orders, then scale — so you keep the margin traders used to take.
                    </p>
                </div>
                <ul class="grid gap-3 sm:grid-cols-1">
                    {% for point in ['Prepaid orders — no credit risk', '2x–4x margins vs wholesale', 'Your brand, your data, your tribe'] %}
                    <li class="flex items-start gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-3.5 text-sm text-slate-200">
                        <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-gold-500 text-xs font-bold text-ink-900">✓</span>
                        {{ point }}
                    </li>
                    {% endfor %}
                </ul>
            </div>
        </div>

        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
            {% for item in why_choose_us[:4] %}
            <div class="rounded-2xl border border-slate-200 bg-white p-7 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-md">
                <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 font-display text-sm font-bold text-brand-700">0{{ loop.index }}</span>
                <h3 class="mt-5 font-display text-lg font-semibold text-ink-900">{{ item.title }}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-600">{{ item.desc }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- PROCESS -->
<section class="bg-slate-50 py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid items-center gap-12 lg:grid-cols-2">
            <div>
                <span class="eyebrow">The F2C pipeline</span>
                <h2 class="mt-5 font-display text-3xl font-bold text-ink-900 sm:text-4xl">From factory floor to prepaid orders</h2>
                <p class="mt-4 max-w-md text-slate-600">A clear path: store → ads → prepaid checkout → scale. You focus on production; we handle the digital side.</p>
                <img src="{{ site_images.hero }}" alt="Textile D2C growth" class="mt-8 hidden aspect-video w-full rounded-2xl object-cover shadow-lg lg:block">
            </div>
            <div class="space-y-4">
                {% for step in f2c_pipeline %}
                <div class="flex gap-5 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold-100 font-display font-bold text-gold-700">{% if loop.last %}✓{% else %}{{ loop.index }}{% endif %}</span>
                    <div>
                        <h3 class="font-display font-semibold text-ink-900">{{ step.title }}</h3>
                        <p class="mt-1 text-sm text-slate-600">{{ step.desc }}</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<!-- STATS -->
<section class="bg-brand-900 py-20 text-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-12 text-center">
            <span class="eyebrow !text-gold-300 before:!bg-gold-400 justify-center">By the numbers</span>
            <h2 class="mt-4 font-display text-3xl font-bold sm:text-4xl">Results that speak for themselves</h2>
        </div>
        <div class="grid gap-8 text-center sm:grid-cols-2 lg:grid-cols-4">
            {% for stat in stats %}
            <div x-data="{ n: 0 }"
                 x-init="
                    const target = {{ stat.value }};
                    const obs = new IntersectionObserver((entries) => {
                        entries.forEach(entry => {
                            if (entry.isIntersecting) {
                                const duration = 1600;
                                const start = performance.now();
                                const tick = (now) => {
                                    const p = Math.min((now - start) / duration, 1);
                                    n = Math.round((1 - Math.pow(1 - p, 3)) * target);
                                    if (p < 1) requestAnimationFrame(tick);
                                };
                                requestAnimationFrame(tick);
                                obs.unobserve(entry.target);
                            }
                        });
                    }, { threshold: 0.4 });
                    obs.observe($el);
                 ">
                <div class="font-display text-5xl font-bold sm:text-6xl">
                    <span class="text-gradient-gold" x-text="n"></span><span class="text-gold-400">{{ stat.suffix }}</span>
                </div>
                <div class="mt-2 text-sm uppercase tracking-widest text-slate-400">{{ stat.label }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<!-- FEATURED CASE STUDY -->
{% if featured_case_study %}
<section class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
