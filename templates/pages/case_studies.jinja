{% extends "base.jinja" %}

{% block content %}
{% set hero_eyebrow = 'Case studies' %}
{% set hero_title = 'Real results from real clients' %}
{% set hero_text = 'See how we drive measurable growth across industries.' %}
{% include "components/page_hero.jinja" %}

<section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 md:grid-cols-2">
            {% for study in case_studies %}
            <a href="{{ url('website:case_study_detail', kwargs={'slug': study.slug}) }}" class="group overflow-hidden rounded-3xl border border-slate-200 bg-white transition hover:-translate-y-1 hover:border-brand-300 hover:shadow-xl">
                <img src="{{ study.image }}" alt="{{ study.title }}" class="h-48 w-full object-cover">
                <div class="p-8">
                    <div class="flex items-center justify-between">
                        <span class="rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">{{ study.category }}</span>
                        <span class="text-sm text-slate-500">{{ study.client }}</span>
                    </div>
                    <h2 class="mt-4 font-display text-xl font-semibold text-ink-900 group-hover:text-brand-700">{{ study.title }}</h2>
                    <p class="mt-2 text-sm text-slate-600">{{ study.summary }}</p>
                    <p class="mt-4 text-sm font-bold text-brand-600">{{ study.result }}</p>
                </div>
            </a>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
