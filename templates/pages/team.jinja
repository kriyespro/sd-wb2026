{% extends "base.jinja" %}

{% block content %}
{% set hero_eyebrow = 'Our team' %}
{% set hero_title = 'Making your business win' %}
{% set hero_text = 'Strategy, tech, marketing, and operations — the people behind your factory-to-customer pipeline.' %}
{% include "components/page_hero.jinja" %}

<section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
            {% for member in team %}
            <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
                <img src="{{ member.image }}" alt="{{ member.name }}" class="h-56 w-full object-cover">
                <div class="p-6">
                    <h2 class="font-display text-xl font-bold text-ink-900">{{ member.name }}</h2>
                    <p class="mt-1 text-sm font-semibold text-brand-600">{{ member.role }}</p>
                    <div class="mt-3 flex flex-wrap gap-1.5">
                        {% for tag in member.tags %}
                        <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-slate-600">{{ tag }}</span>
                        {% endfor %}
                    </div>
                    <p class="mt-4 text-sm leading-relaxed text-slate-600">{{ member.bio }}</p>
                </div>
            </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
            <span class="eyebrow">Delivery capacity</span>
            <h2 class="mt-4 font-display text-3xl font-bold text-ink-900">Specialists across every discipline</h2>
            <p class="mt-3 text-slate-600">Leadership above — execution depth across strategy, ads, product, and ops.</p>
        </div>
        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
            {% for role in team_roles %}
            <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white text-center">
                <img src="{{ role.image }}" alt="{{ role.role }}" class="h-28 w-full object-cover">
                <div class="p-5">
                    <div class="font-display text-2xl font-bold text-brand-600">{{ role.count }}</div>
                    <h3 class="mt-1 text-sm font-semibold text-ink-900">{{ role.role }}</h3>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="relative overflow-hidden rounded-[2rem] bg-ink-900 p-10 text-center text-white sm:p-14">
            <div class="mesh absolute inset-0 opacity-70"></div>
            <div class="relative">
                <h2 class="font-display text-2xl font-bold sm:text-3xl">Want this team on your factory’s D2C?</h2>
                <p class="mt-3 text-slate-300">Book a free consultation — we’ll map store, ads, and ops for your products.</p>
                <a href="{{ url('website:contact') }}" class="btn-accent mt-8 inline-flex">Book Free Consultation →</a>
            </div>
        </div>
    </div>
</section>
{% endblock %}
