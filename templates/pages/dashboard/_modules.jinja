{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {% for module in modules %}
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="text-2xl">{{ module.icon }}</div>
        <h3 class="mt-3 font-semibold text-brand-950">{{ module.title }}</h3>
        <p class="mt-1 text-sm text-slate-600">{{ module.desc }}</p>
        <span class="mt-4 inline-block rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-500">Coming in Phase 3+</span>
    </div>
    {% endfor %}
</div>
{% endblock %}
