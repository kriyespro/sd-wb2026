{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="mb-5 grid gap-4 lg:grid-cols-3">
    <div class="dash-panel p-5 lg:col-span-1">
        <h3 class="text-sm font-bold text-ink-900">Request payout</h3>
        <p class="mt-2 text-xs text-slate-500">
            Available: <span class="font-bold text-ink-900">₹{{ summary.available }}</span>
        </p>
        {% if can_payout %}
        <p class="mt-3 rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs text-emerald-800">
            Payout window is open today (21st).
        </p>
        <form method="post" action="{{ url('partners:payout_request') }}" class="mt-3">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <button type="submit" class="w-full rounded-xl bg-gold-500 px-4 py-2.5 text-xs font-bold text-ink-900 hover:bg-gold-400">
                Request payout now
            </button>
        </form>
        {% else %}
        <p class="mt-3 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-900">
            Payout requests open only on the <strong>21st</strong> of each month.
        </p>
        {% endif %}

        {% if payout_form %}
        <h4 class="mt-6 text-xs font-bold uppercase tracking-wide text-slate-500">Payout details</h4>
        <form method="post" action="{{ url('partners:payout_details') }}" class="mt-2 space-y-2">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            {{ payout_form.upi_id }}
            {{ payout_form.bank_account }}
            {{ payout_form.bank_ifsc }}
            <button type="submit" class="w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50">Save details</button>
        </form>
        {% endif %}
    </div>

    <div class="dash-panel overflow-hidden lg:col-span-2">
        <div class="border-b border-slate-100 px-4 py-3">
            <h3 class="text-sm font-bold text-ink-900">Payout history</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full min-w-[560px] text-left text-sm">
                <thead class="bg-slate-50 text-[10px] uppercase tracking-wider text-slate-500">
                    <tr>
                        <th class="px-4 py-3">Month</th>
                        <th class="px-4 py-3">Amount</th>
                        <th class="px-4 py-3">Status</th>
                        <th class="px-4 py-3">Requested</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% for p in payouts %}
                    <tr>
                        <td class="px-4 py-3 font-medium">{{ p.period_month.strftime('%b %Y') }}</td>
                        <td class="px-4 py-3">₹{{ p.amount }}</td>
                        <td class="px-4 py-3 text-xs">{{ p.get_status_display() }}</td>
                        <td class="px-4 py-3 text-xs text-slate-500">{{ p.created_at.strftime('%d %b %Y') }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="4" class="px-4 py-8 text-center text-slate-500">No payout requests yet.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
