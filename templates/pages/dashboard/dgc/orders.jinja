{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="mb-5 grid gap-4 lg:grid-cols-3">
    <div class="dash-panel p-5 lg:col-span-1">
        <h3 class="text-sm font-bold text-ink-900">Place order</h3>
        <form method="post" action="{{ url('partners:order_create') }}" class="mt-3 space-y-3">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-500">Offer</label>
                {{ form.offer }}
            </div>
            <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-500">Quantity</label>
                {{ form.quantity }}
            </div>
            <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-slate-500">Notes</label>
                {{ form.notes }}
            </div>
            <button type="submit" class="w-full rounded-xl bg-gold-500 px-4 py-2.5 text-xs font-bold text-ink-900 hover:bg-gold-400">Place order</button>
        </form>
    </div>
    <div class="dash-panel overflow-hidden lg:col-span-2">
        <div class="border-b border-slate-100 px-4 py-3">
            <h3 class="text-sm font-bold text-ink-900">Order history</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full min-w-[640px] text-left text-sm">
                <thead class="bg-slate-50 text-[10px] uppercase tracking-wider text-slate-500">
                    <tr>
                        <th class="px-4 py-3">Offer</th>
                        <th class="px-4 py-3">Qty</th>
                        <th class="px-4 py-3">Total</th>
                        <th class="px-4 py-3">Status</th>
                        <th class="px-4 py-3">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% for order in orders %}
                    <tr>
                        <td class="px-4 py-3 font-medium text-ink-900">{{ order.offer.title }}</td>
                        <td class="px-4 py-3">{{ order.quantity }}</td>
                        <td class="px-4 py-3">₹{{ order.total }}</td>
                        <td class="px-4 py-3 text-xs">{{ order.get_status_display() }}</td>
                        <td class="px-4 py-3 text-xs text-slate-500">{{ order.created_at.strftime('%d %b %Y') }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="5" class="px-4 py-8 text-center text-slate-500">No orders yet.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="px-4 pb-4">
        {% include "components/pagination.jinja" %}
        </div>
    </div>
</div>
{% endblock %}
