{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="mb-5 grid gap-4 lg:grid-cols-3">
    <div class="dash-panel p-5 lg:col-span-1">
        <h3 class="text-sm font-bold text-ink-900">Submit lead</h3>
        <form method="post" action="{{ url('partners:lead_create') }}" class="mt-3 space-y-3">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <div>{{ form.name }}</div>
            <div>{{ form.phone }}</div>
            <div>{{ form.email }}</div>
            <div>{{ form.company }}</div>
            <div>{{ form.interest }}</div>
            <div>
                <label class="mb-1 block text-xs font-semibold text-slate-500">Deal value (₹)</label>
                {{ form.deal_value }}
            </div>
            <div>{{ form.notes }}</div>
            <button type="submit" class="w-full rounded-xl bg-brand-700 px-4 py-2.5 text-xs font-bold text-white hover:bg-brand-600">Submit lead</button>
        </form>
    </div>
    <div class="dash-panel overflow-hidden lg:col-span-2">
        <div class="border-b border-slate-100 px-4 py-3">
            <h3 class="text-sm font-bold text-ink-900">Your leads</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full min-w-[720px] text-left text-sm">
                <thead class="bg-slate-50 text-[10px] uppercase tracking-wider text-slate-500">
                    <tr>
                        <th class="px-4 py-3">Lead</th>
                        <th class="px-4 py-3">Company</th>
                        <th class="px-4 py-3">Interest</th>
                        <th class="px-4 py-3">Deal</th>
                        <th class="px-4 py-3">Status</th>
                        <th class="px-4 py-3">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% for lead in leads %}
                    <tr>
                        <td class="px-4 py-3">
                            <p class="font-medium text-ink-900">{{ lead.name }}</p>
                            <p class="text-xs text-slate-500">{{ lead.phone }}</p>
                        </td>
                        <td class="px-4 py-3 text-slate-600">{{ lead.company or '—' }}</td>
                        <td class="px-4 py-3 text-slate-600">{{ lead.interest or '—' }}</td>
                        <td class="px-4 py-3">₹{{ lead.deal_value }}</td>
                        <td class="px-4 py-3">
                            <span class="rounded-full px-2 py-0.5 text-[10px] font-bold uppercase
                                {% if lead.status == 'won' %}bg-emerald-100 text-emerald-800
                                {% elif lead.status == 'lost' %}bg-slate-100 text-slate-600
                                {% elif lead.status == 'contacted' %}bg-sky-100 text-sky-800
                                {% else %}bg-amber-100 text-amber-800{% endif %}">
                                {{ lead.get_status_display() }}
                            </span>
                        </td>
                        <td class="px-4 py-3 text-xs text-slate-500">{{ lead.created_at.strftime('%d %b') }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="6" class="px-4 py-8 text-center text-slate-500">No leads yet.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
