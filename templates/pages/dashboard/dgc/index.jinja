{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if not partner %}
<div class="dash-panel p-8 text-center">
    <p class="text-slate-600">No partner profile linked. Contact ops.</p>
</div>
{% else %}
<section class="relative mb-5 overflow-hidden rounded-2xl bg-ink-900 px-5 py-5 text-white sm:px-6">
    <div class="relative flex flex-wrap items-end justify-between gap-3">
        <div>
            <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-gold-300">Digital Growth Consultant</p>
            <h2 class="mt-1 font-display text-xl font-bold">Welcome, {{ partner.code }}</h2>
            <p class="mt-1 text-xs text-slate-300">Reseller offers · leads · commission · payout on the 21st</p>
        </div>
        <a href="{{ url('partners:payouts') }}" class="rounded-full bg-gold-500 px-3 py-1.5 text-[11px] font-bold text-ink-900 hover:bg-gold-400">
            {% if stats.can_payout %}Request payout today →{% else %}Payouts →{% endif %}
        </a>
    </div>
</section>

<div class="mb-5 grid gap-2 sm:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-xl border border-emerald-200 bg-emerald-50/70 px-3 py-2.5">
        <p class="text-[10px] font-bold uppercase tracking-wide text-emerald-700">Open leads</p>
        <p class="mt-0.5 font-display text-2xl font-bold text-emerald-800">{{ stats.open_leads }}</p>
    </div>
    <div class="rounded-xl border border-sky-200 bg-sky-50/70 px-3 py-2.5">
        <p class="text-[10px] font-bold uppercase tracking-wide text-sky-700">Orders</p>
        <p class="mt-0.5 font-display text-2xl font-bold text-sky-800">{{ stats.orders }}</p>
    </div>
    <div class="rounded-xl border border-violet-200 bg-violet-50/70 px-3 py-2.5">
        <p class="text-[10px] font-bold uppercase tracking-wide text-violet-700">Pending commission</p>
        <p class="mt-0.5 font-display text-2xl font-bold text-violet-800">₹{{ stats.pending_commission }}</p>
    </div>
    <div class="rounded-xl border border-amber-200 bg-amber-50/70 px-3 py-2.5">
        <p class="text-[10px] font-bold uppercase tracking-wide text-amber-700">Payout window</p>
        <p class="mt-0.5 font-display text-lg font-bold text-amber-900">
            {% if stats.can_payout %}Open today{% else %}Day {{ stats.payout_day }}{% endif %}
        </p>
        <p class="text-[10px] text-amber-800/70">Today {{ stats.today.strftime('%d %b') }}</p>
    </div>
</div>

<div class="grid gap-4 lg:grid-cols-2">
    <div class="dash-panel">
        <div class="flex items-center justify-between border-b border-slate-100 px-4 py-3">
            <h3 class="text-sm font-bold text-ink-900">Recent leads</h3>
            <a href="{{ url('partners:leads') }}" class="text-[11px] font-bold text-brand-600">View all</a>
        </div>
        <div class="px-4 py-2">
            {% if recent_leads %}
            <ul class="divide-y divide-slate-100">
                {% for lead in recent_leads %}
                <li class="flex justify-between gap-2 py-2 text-sm">
                    <span class="font-medium text-slate-800">{{ lead.name }}</span>
                    <span class="text-xs text-slate-500">{{ lead.get_status_display() }}</span>
                </li>
                {% endfor %}
            </ul>
            {% else %}
            <p class="py-4 text-xs text-slate-500">No leads yet.</p>
            {% endif %}
        </div>
    </div>
    <div class="dash-panel">
        <div class="flex items-center justify-between border-b border-slate-100 px-4 py-3">
            <h3 class="text-sm font-bold text-ink-900">Recent commissions</h3>
            <a href="{{ url('partners:commissions') }}" class="text-[11px] font-bold text-brand-600">View all</a>
        </div>
        <div class="px-4 py-2">
            {% if recent_commissions %}
            <ul class="divide-y divide-slate-100">
                {% for c in recent_commissions %}
                <li class="flex justify-between gap-2 py-2 text-sm">
                    <span class="text-slate-700">₹{{ c.amount }} · {{ c.get_source_display() }}</span>
                    <span class="text-xs text-slate-500">{{ c.get_status_display() }}</span>
                </li>
                {% endfor %}
            </ul>
            {% else %}
            <p class="py-4 text-xs text-slate-500">No commissions yet.</p>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}
{% endblock %}
