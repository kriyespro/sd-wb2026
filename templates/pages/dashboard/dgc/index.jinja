{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if not partner %}
<div class="dash-panel p-8 text-center">
    <p class="text-slate-600">No partner profile linked. Contact ops.</p>
</div>
{% else %}
<section class="relative mb-5 overflow-hidden rounded-2xl bg-ink-900 px-5 py-5 text-white sm:px-6">
    <div class="relative flex flex-wrap items-end justify-between gap-3">
        <div>
            <p class="text-[10px] font-bold uppercase tracking-[0.18em] text-gold-300">Digital Growth Consultant</p>
            <h2 class="mt-1 font-display text-xl font-bold">Welcome, {{ partner.code }}</h2>
            <p class="mt-1 text-xs text-slate-300">Submit factory leads, track status, and earn commission</p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="#submit-lead" class="rounded-full bg-gold-500 px-3 py-1.5 text-[11px] font-bold text-ink-900 hover:bg-gold-400">Submit lead →</a>
            <a href="{{ url('partners:leads') }}" class="rounded-full border border-white/20 bg-white/5 px-3 py-1.5 text-[11px] font-bold text-white hover:bg-white/10">All leads</a>
        </div>
    </div>
</section>

<div class="mb-5 grid gap-2 sm:grid-cols-2 xl:grid-cols-4">
    <a href="{{ url('partners:leads') }}" class="rounded-xl border border-emerald-200 bg-emerald-50/70 px-3 py-2.5 transition hover:border-emerald-300">
        <p class="text-[10px] font-bold uppercase tracking-wide text-emerald-700">Open leads</p>
        <p class="mt-0.5 font-display text-2xl font-bold text-emerald-800">{{ stats.open_leads }}</p>
    </a>
    <div class="rounded-xl border border-sky-200 bg-sky-50/70 px-3 py-2.5">
        <p class="text-[10px] font-bold uppercase tracking-wide text-sky-700">Orders</p>
        <p class="mt-0.5 font-display text-2xl font-bold text-sky-800">{{ stats.orders }}</p>
    </div>
    <div class="rounded-xl border border-violet-200 bg-violet-50/70 px-3 py-2.5">
        <p class="text-[10px] font-bold uppercase tracking-wide text-violet-700">Pending commission</p>
        <p class="mt-0.5 font-display text-2xl font-bold text-violet-800">₹{{ stats.pending_commission }}</p>
    </div>
    <div class="rounded-xl border border-amber-200 bg-amber-50/70 px-3 py-2.5">
        <p class="text-[10px] font-bold uppercase tracking-wide text-amber-700">Payout window</p>
        <p class="mt-0.5 font-display text-lg font-bold text-amber-900">
            {% if stats.can_payout %}Open today{% else %}Day {{ stats.payout_day }}{% endif %}
        </p>
        <p class="text-[10px] text-amber-800/70">Today {{ stats.today.strftime('%d %b') }}</p>
    </div>
</div>

<div id="submit-lead" class="mb-5 grid gap-4 lg:grid-cols-3">
    <div class="dash-panel border-emerald-100 p-5 lg:col-span-1">
        <h3 class="text-sm font-bold text-ink-900">Submit a lead</h3>
        <p class="mt-1 text-xs text-slate-500">Factory / D2C prospect — status updates show in your leads list.</p>
        <form method="post" action="{{ url('partners:lead_create') }}" class="mt-3 space-y-2.5">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            {{ lead_form.name }}
            {{ lead_form.phone }}
            {{ lead_form.email }}
            {{ lead_form.company }}
            {{ lead_form.interest }}
            <div>
                <label class="mb-1 block text-[10px] font-bold uppercase tracking-wide text-slate-500">Deal value (₹)</label>
                {{ lead_form.deal_value }}
            </div>
            {{ lead_form.notes }}
            <button type="submit" class="w-full rounded-xl bg-emerald-600 px-4 py-2.5 text-xs font-bold text-white hover:bg-emerald-500">
                Submit lead
            </button>
        </form>
    </div>

    <div class="dash-panel overflow-hidden lg:col-span-2">
        <div class="flex items-center justify-between border-b border-slate-100 px-4 py-3">
            <h3 class="text-sm font-bold text-ink-900">Your recent leads</h3>
            <a href="{{ url('partners:leads') }}" class="text-[11px] font-bold text-brand-600">Manage all →</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full min-w-[520px] text-left text-sm">
                <thead class="bg-slate-50 text-[10px] uppercase tracking-wider text-slate-500">
                    <tr>
                        <th class="px-4 py-2.5">Lead</th>
                        <th class="px-4 py-2.5">Interest</th>
                        <th class="px-4 py-2.5">Status</th>
                        <th class="px-4 py-2.5">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% for lead in recent_leads %}
                    <tr>
                        <td class="px-4 py-3">
                            <p class="font-medium text-ink-900">{{ lead.name }}</p>
                            <p class="text-xs text-slate-500">{{ lead.company or lead.phone }}</p>
                        </td>
                        <td class="px-4 py-3 text-xs text-slate-600">{{ lead.interest or '—' }}</td>
                        <td class="px-4 py-3">
                            <span class="rounded-full px-2 py-0.5 text-[10px] font-bold uppercase
                                {% if lead.status == 'won' %}bg-emerald-100 text-emerald-800
                                {% elif lead.status == 'lost' %}bg-slate-100 text-slate-600
                                {% elif lead.status == 'contacted' %}bg-sky-100 text-sky-800
                                {% else %}bg-amber-100 text-amber-800{% endif %}">
                                {{ lead.get_status_display() }}
                            </span>
                        </td>
                        <td class="px-4 py-3 text-xs text-slate-500">{{ lead.created_at.strftime('%d %b') }}</td>
                    </tr>
                    {% else %}
                    <tr><td colspan="4" class="px-4 py-8 text-center text-xs text-slate-500">No leads yet — submit your first one.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="dash-panel">
    <div class="flex items-center justify-between border-b border-slate-100 px-4 py-3">
        <h3 class="text-sm font-bold text-ink-900">Recent commissions</h3>
        <a href="{{ url('partners:commissions') }}" class="text-[11px] font-bold text-brand-600">View all</a>
    </div>
    <div class="px-4 py-2">
        {% if recent_commissions %}
        <ul class="divide-y divide-slate-100">
            {% for c in recent_commissions %}
            <li class="flex justify-between gap-2 py-2 text-sm">
                <span class="text-slate-700">₹{{ c.amount }} · {{ c.get_source_display() }}</span>
                <span class="text-xs text-slate-500">{{ c.get_status_display() }}</span>
            </li>
            {% endfor %}
        </ul>
        {% else %}
        <p class="py-4 text-xs text-slate-500">No commissions yet.</p>
        {% endif %}
    </div>
</div>
{% endif %}
{% endblock %}
