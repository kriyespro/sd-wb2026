{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if assignments %}
<div class="space-y-4">
    {% for assignment in assignments %}
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <span class="rounded-full bg-brand-50 px-2 py-0.5 text-xs font-medium text-brand-700">{{ assignment.course.title }}</span>
                <h3 class="mt-2 font-semibold text-brand-950">{{ assignment.title }}</h3>
                <p class="mt-1 text-sm text-slate-600">{{ assignment.description }}</p>
                <p class="mt-2 text-xs text-slate-500">Due: {{ assignment.due_date }}</p>
            </div>
            {% if assignment.id in submissions %}
            <span class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">Submitted</span>
            {% else %}
            <span class="rounded-full bg-orange-100 px-3 py-1 text-xs font-medium text-orange-700">Pending</span>
            {% endif %}
        </div>

        {% if assignment.id in submissions %}
        <div class="mt-4 rounded-lg bg-slate-50 p-4 text-sm">
            <p class="font-medium text-slate-700">Your submission:</p>
            <p class="mt-1 text-slate-600">{{ submissions[assignment.id].content }}</p>
            {% if submissions[assignment.id].feedback %}
            <p class="mt-3 font-medium text-brand-700">Mentor feedback:</p>
            <p class="mt-1 text-slate-600">{{ submissions[assignment.id].feedback }}</p>
            {% endif %}
        </div>
        {% else %}
        <div id="submission-{{ assignment.id }}" class="mt-4">
            {% include "partials/_submission_form.jinja" %}
        </div>
        {% endif %}
    </div>
    {% endfor %}
</div>
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">No assignments yet.</p>
</div>
{% endif %}
{% endblock %}
