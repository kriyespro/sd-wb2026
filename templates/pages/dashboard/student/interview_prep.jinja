{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="grid gap-4 md:grid-cols-2">
    {% for resource in resources %}
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="font-semibold text-brand-950">{{ resource.title }}</h3>
        <p class="mt-2 text-sm text-slate-600">{{ resource.desc }}</p>
        <span class="mt-4 inline-block rounded-full bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700">Resource</span>
    </div>
    {% endfor %}
</div>
{% endblock %}
