{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if tasks %}
<div class="space-y-3">
    {% for task in tasks %}
    <div class="flex flex-wrap items-center justify-between gap-4 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <div>
            <h3 class="font-medium text-brand-950">{{ task.title }}</h3>
            {% if task.description %}<p class="mt-1 text-sm text-slate-600">{{ task.description }}</p>{% endif %}
            {% if task.due_date %}<p class="mt-1 text-xs text-slate-500">Due: {{ task.due_date }}</p>{% endif %}
        </div>
        <span class="rounded-full px-3 py-1 text-xs font-medium
            {% if task.status == 'done' %}bg-green-100 text-green-700
            {% elif task.status == 'in_progress' %}bg-blue-100 text-blue-700
            {% else %}bg-slate-100 text-slate-600{% endif %}">
            {{ task.get_status_display() }}
        </span>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">No tasks assigned yet.</p>
</div>
{% endif %}
{% endblock %}
