{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if applications %}
<div class="space-y-4">
    {% for app in applications %}
    <div class="flex flex-wrap items-center justify-between gap-4 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div>
            <h3 class="font-semibold text-brand-950">{{ app.company }}</h3>
            <p class="text-sm text-slate-600">{{ app.role }}</p>
            <p class="mt-1 text-xs text-slate-500">Applied: {{ app.applied_at.strftime('%d %b %Y') }}</p>
        </div>
        <span class="rounded-full px-3 py-1 text-xs font-medium
            {% if app.status == 'offered' %}bg-green-100 text-green-700
            {% elif app.status == 'interview' %}bg-blue-100 text-blue-700
            {% elif app.status == 'rejected' %}bg-red-100 text-red-700
            {% else %}bg-slate-100 text-slate-600{% endif %}">
            {{ app.get_status_display() }}
        </span>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">No placement applications yet. Your placement coordinator will add opportunities.</p>
</div>
{% endif %}
{% endblock %}
