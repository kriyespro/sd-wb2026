{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="mb-6">
    <a href="{{ url('academy_dashboard:courses') }}" class="text-sm text-brand-600 hover:text-brand-700">← All Courses</a>
    <h2 class="mt-2 text-xl font-bold text-brand-950">{{ course.title }}</h2>
    <p class="mt-2 text-sm text-slate-600">{{ course.description }}</p>
    <div class="mt-3 flex items-center gap-4 text-sm text-slate-500">
        <span>Progress: {{ enrollment.progress_percent }}%</span>
        <span>Status: {{ enrollment.get_status_display() }}</span>
    </div>
</div>

<div class="space-y-6">
    {% for module in course.modules.all() %}
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="font-semibold text-brand-950">Module {{ loop.index }}: {{ module.title }}</h3>
        <ul class="mt-4 space-y-3">
            {% for lesson in module.lessons.all() %}
            <li class="flex items-center justify-between rounded-lg bg-slate-50 px-4 py-3 text-sm">
                <span class="text-slate-700">{{ lesson.title }}</span>
                <span class="text-xs text-slate-500">{{ lesson.duration_minutes }} min</span>
            </li>
            {% endfor %}
        </ul>
    </div>
    {% else %}
    <p class="text-sm text-slate-500">No modules added yet.</p>
    {% endfor %}
</div>
{% endblock %}
