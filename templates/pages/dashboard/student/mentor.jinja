{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if mentor %}
<div class="max-w-2xl rounded-xl border border-slate-200 bg-white p-8 shadow-sm">
    <div class="flex items-center gap-4">
        <div class="flex h-16 w-16 items-center justify-center rounded-full bg-brand-100 text-2xl font-bold text-brand-700">
            {{ (mentor.first_name or mentor.username)[0]|upper }}
        </div>
        <div>
            <h2 class="text-xl font-semibold text-brand-950">{{ mentor.get_full_name() or mentor.username }}</h2>
            <p class="text-sm text-slate-500">{{ mentor.profile.get_role_display() }}</p>
            <p class="text-sm text-brand-600">{{ mentor.email }}</p>
        </div>
    </div>
    {% if allocation and allocation.notes %}
    <div class="mt-6 rounded-lg bg-slate-50 p-4">
        <p class="text-sm font-medium text-slate-700">Mentor Notes</p>
        <p class="mt-1 text-sm text-slate-600">{{ allocation.notes }}</p>
    </div>
    {% endif %}
</div>
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">No mentor assigned yet. Your academy admin will allocate one soon.</p>
</div>
{% endif %}
{% endblock %}
