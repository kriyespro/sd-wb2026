{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if projects %}
<div class="grid gap-4 md:grid-cols-2">
    {% for project in projects %}
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between">
            <span class="rounded-full bg-brand-50 px-2 py-0.5 text-xs font-medium text-brand-700">{{ project.get_project_type_display() }}</span>
            <span class="rounded-full px-2 py-0.5 text-xs font-medium
                {% if project.status == 'completed' %}bg-green-100 text-green-700{% else %}bg-blue-100 text-blue-700{% endif %}">
                {{ project.get_status_display() }}
            </span>
        </div>
        <h3 class="mt-3 font-semibold text-brand-950">{{ project.title }}</h3>
        <p class="mt-2 text-sm text-slate-600">{{ project.description }}</p>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">No projects assigned yet.</p>
</div>
{% endif %}
{% endblock %}
