{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if certificates %}
<div class="grid gap-4 md:grid-cols-2">
    {% for cert in certificates %}
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="text-3xl">🏆</div>
        <h3 class="mt-3 font-semibold text-brand-950">{{ cert.title }}</h3>
        {% if cert.course %}<p class="text-sm text-slate-500">{{ cert.course.title }}</p>{% endif %}
        <p class="mt-2 text-xs text-slate-500">Issued: {{ cert.issued_at }}</p>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">No certificates earned yet. Complete courses to earn certifications.</p>
</div>
{% endif %}
{% endblock %}
