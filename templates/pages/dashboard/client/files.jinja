{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if deliverables %}
<div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 text-left text-slate-500">
            <tr>
                <th class="px-6 py-3 font-medium">File</th>
                <th class="px-6 py-3 font-medium">Project</th>
                <th class="px-6 py-3 font-medium">Date</th>
                <th class="px-6 py-3 font-medium"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
            {% for deliverable in deliverables %}
            <tr>
                <td class="px-6 py-4">
                    <p class="font-medium text-slate-700">{{ deliverable.title }}</p>
                    {% if deliverable.description %}<p class="text-xs text-slate-500">{{ deliverable.description }}</p>{% endif %}
                </td>
                <td class="px-6 py-4 text-slate-600">{{ deliverable.project.name }}</td>
                <td class="px-6 py-4 text-slate-500">{{ deliverable.created_at.strftime('%d %b %Y') }}</td>
                <td class="px-6 py-4 text-right">
                    {% if deliverable.file_url %}
                    <a href="{{ deliverable.file_url }}" target="_blank" class="text-brand-600 hover:text-brand-700">Download</a>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% include "components/pagination.jinja" %}
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">No files available. Deliverables appear here once approved by our team.</p>
</div>
{% endif %}
{% endblock %}
