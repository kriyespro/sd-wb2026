{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="mb-6">
    <a href="{{ url('clients:projects') }}" class="text-sm text-brand-600 hover:text-brand-700">← All Projects</a>
    <div class="mt-2 flex flex-wrap items-center gap-3">
        <h2 class="text-xl font-bold text-brand-950">{{ project.name }}</h2>
        <span class="rounded-full px-2 py-0.5 text-xs font-medium
            {% if project.status == 'completed' %}bg-green-100 text-green-700
            {% elif project.status == 'active' %}bg-blue-100 text-blue-700
            {% else %}bg-slate-100 text-slate-600{% endif %}">
            {{ project.get_status_display() }}
        </span>
    </div>
    {% if project.description %}<p class="mt-2 text-sm text-slate-600">{{ project.description }}</p>{% endif %}
    <div class="mt-4 flex items-center gap-2 max-w-md">
        <div class="h-2 flex-1 rounded-full bg-slate-100">
            <div class="h-2 rounded-full bg-brand-600" style="width: {{ project.progress_percent }}%"></div>
        </div>
        <span class="text-xs font-medium text-brand-600">{{ project.progress_percent }}%</span>
    </div>
</div>

<div class="grid gap-6 lg:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="font-semibold text-brand-950">Milestones</h3>
        {% if milestones %}
        <ul class="mt-4 space-y-3">
            {% for milestone in milestones %}
            <li class="flex items-center justify-between text-sm">
                <span class="flex items-center gap-2 text-slate-700">
                    {% if milestone.status == 'done' %}<span class="text-green-600">✓</span>{% else %}<span class="text-slate-300">○</span>{% endif %}
                    {{ milestone.title }}
                </span>
                <span class="text-xs text-slate-500">{% if milestone.due_date %}{{ milestone.due_date }}{% endif %}</span>
            </li>
            {% endfor %}
        </ul>
        {% else %}
        <p class="mt-4 text-sm text-slate-500">No milestones yet.</p>
        {% endif %}
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="font-semibold text-brand-950">Deliverables</h3>
        {% if deliverables %}
        <ul class="mt-4 space-y-3">
            {% for deliverable in deliverables %}
            <li class="rounded-lg border border-slate-100 p-3">
                <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-slate-700">{{ deliverable.title }}</span>
                    {% if deliverable.file_url %}<a href="{{ deliverable.file_url }}" target="_blank" class="text-xs text-brand-600 hover:text-brand-700">Download</a>{% endif %}
                </div>
                {% if deliverable.description %}<p class="mt-1 text-xs text-slate-500">{{ deliverable.description }}</p>{% endif %}
            </li>
            {% endfor %}
        </ul>
        {% else %}
        <p class="mt-4 text-sm text-slate-500">No approved deliverables yet.</p>
        {% endif %}
    </div>
</div>
{% endblock %}
