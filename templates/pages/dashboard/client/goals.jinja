{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if goals %}
<div class="space-y-4">
    {% for goal in goals %}
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <div>
                <h3 class="font-semibold text-brand-950">{{ goal.title }}</h3>
                <p class="text-sm text-slate-500">Target: {{ goal.target }}</p>
            </div>
            <span class="rounded-full px-3 py-1 text-xs font-medium
                {% if goal.status == 'achieved' %}bg-green-100 text-green-700
                {% elif goal.status == 'at_risk' %}bg-red-100 text-red-700
                {% else %}bg-blue-100 text-blue-700{% endif %}">
                {{ goal.get_status_display() }}
            </span>
        </div>
        <div class="mt-4 flex items-center gap-2">
            <div class="h-2 flex-1 rounded-full bg-slate-100">
                <div class="h-2 rounded-full bg-brand-600" style="width: {{ goal.progress_percent }}%"></div>
            </div>
            <span class="text-xs font-medium text-brand-600">{{ goal.progress_percent }}%</span>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">No goals set yet. Your account manager will define goals with you.</p>
</div>
{% endif %}
{% endblock %}
