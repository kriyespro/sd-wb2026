{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if projects %}
<div class="grid gap-6 md:grid-cols-2">
    {% for project in projects %}
    <a href="{{ url('clients:project_detail', kwargs={'pk': project.id}) }}"
       class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-brand-300 hover:shadow-md">
        <div class="flex items-center justify-between">
            {% if project.service_type %}<span class="rounded-full bg-brand-50 px-2 py-0.5 text-xs font-medium text-brand-700">{{ project.service_type }}</span>{% endif %}
            <span class="rounded-full px-2 py-0.5 text-xs font-medium
                {% if project.status == 'completed' %}bg-green-100 text-green-700
                {% elif project.status == 'active' %}bg-blue-100 text-blue-700
                {% elif project.status == 'on_hold' %}bg-yellow-100 text-yellow-700
                {% else %}bg-slate-100 text-slate-600{% endif %}">
                {{ project.get_status_display() }}
            </span>
        </div>
        <h3 class="mt-3 text-lg font-semibold text-brand-950">{{ project.name }}</h3>
        {% if project.description %}<p class="mt-1 text-sm text-slate-600 line-clamp-2">{{ project.description }}</p>{% endif %}
        <div class="mt-4 flex items-center gap-2">
            <div class="h-2 flex-1 rounded-full bg-slate-100">
                <div class="h-2 rounded-full bg-brand-600" style="width: {{ project.progress_percent }}%"></div>
            </div>
            <span class="text-xs font-medium text-brand-600">{{ project.progress_percent }}%</span>
        </div>
    </a>
    {% endfor %}
</div>
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">No projects yet.</p>
</div>
{% endif %}
{% endblock %}
