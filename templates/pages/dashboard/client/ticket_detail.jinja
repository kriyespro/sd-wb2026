{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="mb-6">
    <a href="{{ url('clients:support') }}" class="text-sm text-brand-600 hover:text-brand-700">← All Tickets</a>
    <div class="mt-2 flex flex-wrap items-center gap-3">
        <h2 class="text-xl font-bold text-brand-950">{{ ticket.subject }}</h2>
        <span class="rounded-full px-2 py-0.5 text-xs font-medium
            {% if ticket.status == 'resolved' %}bg-green-100 text-green-700
            {% elif ticket.status == 'in_progress' %}bg-blue-100 text-blue-700
            {% else %}bg-orange-100 text-orange-700{% endif %}">
            {{ ticket.get_status_display() }}
        </span>
    </div>
</div>

<div class="max-w-2xl space-y-4">
    {% for message in messages_list %}
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="flex items-center justify-between text-xs text-slate-500">
            <span class="font-medium text-slate-700">
                {% if message.sender %}{{ message.sender.get_full_name() or message.sender.username }}{% else %}Support{% endif %}
            </span>
            <span>{{ message.created_at.strftime('%d %b %Y · %H:%M') }}</span>
        </div>
        <p class="mt-2 text-sm text-slate-600">{{ message.body }}</p>
    </div>
    {% endfor %}

    {% if ticket.status != 'resolved' %}
    <form method="post" action="{{ url('clients:ticket_reply', kwargs={'pk': ticket.id}) }}" class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
        {{ reply_form.body }}
        <button type="submit" class="mt-3 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">
            Send Reply
        </button>
    </form>
    {% endif %}
</div>
{% endblock %}
