{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if metrics %}
<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {% for metric in metrics %}
    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-sm text-slate-500">{{ metric.label }}</p>
        <p class="mt-1 text-2xl font-bold text-brand-950">{{ metric.value }}</p>
        {% if metric.change %}<p class="mt-1 text-xs font-medium text-green-600">{{ metric.change }}</p>{% endif %}
    </div>
    {% endfor %}
</div>
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">Analytics will appear once your reports are published.</p>
</div>
{% endif %}
{% endblock %}
