{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="grid gap-6 lg:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="font-semibold text-brand-950">Open a Ticket</h2>
        <form method="post" action="{{ url('clients:ticket_create') }}" class="mt-4 space-y-4">
            <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Subject</label>
                {{ form.subject }}
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-slate-700">Message</label>
                {{ form.body }}
            </div>
            <button type="submit" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700">
                Submit Ticket
            </button>
        </form>
    </div>

    <div>
        <h2 class="font-semibold text-brand-950">Your Tickets</h2>
        {% if tickets %}
        <div class="mt-4 space-y-3">
            {% for ticket in tickets %}
            <a href="{{ url('clients:ticket_detail', kwargs={'pk': ticket.id}) }}"
               class="flex items-center justify-between rounded-xl border border-slate-200 bg-white p-4 shadow-sm hover:border-brand-300">
                <div>
                    <p class="text-sm font-medium text-slate-700">{{ ticket.subject }}</p>
                    <p class="text-xs text-slate-500">{{ ticket.updated_at.strftime('%d %b %Y') }}</p>
                </div>
                <span class="rounded-full px-2 py-0.5 text-xs font-medium
                    {% if ticket.status == 'resolved' %}bg-green-100 text-green-700
                    {% elif ticket.status == 'in_progress' %}bg-blue-100 text-blue-700
                    {% else %}bg-orange-100 text-orange-700{% endif %}">
                    {{ ticket.get_status_display() }}
                </span>
            </a>
            {% endfor %}
        </div>
        {% include "components/pagination.jinja" %}
        {% else %}
        <p class="mt-4 text-sm text-slate-500">No tickets yet.</p>
        {% endif %}
    </div>
</div>
{% endblock %}
