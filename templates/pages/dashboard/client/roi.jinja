{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
<div class="grid gap-4 sm:grid-cols-3">
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm text-slate-500">Total Projects</p>
        <p class="mt-1 text-3xl font-bold text-brand-950">{{ total_projects }}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm text-slate-500">Completed</p>
        <p class="mt-1 text-3xl font-bold text-green-600">{{ completed_projects }}</p>
    </div>
    <div class="rounded-xl border border-brand-200 bg-brand-50 p-6">
        <p class="text-sm text-brand-700">Delivery Rate</p>
        <p class="mt-1 text-3xl font-bold text-brand-950">
            {% if total_projects %}{{ ((completed_projects / total_projects) * 100)|round|int }}%{% else %}—{% endif %}
        </p>
    </div>
</div>

<div class="mt-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="font-semibold text-brand-950">ROI Summary</h2>
    <p class="mt-2 text-sm text-slate-600">
        Detailed ROI dashboards with revenue attribution arrive in Phase 8. For now, track delivery
        progress across your projects and review performance metrics in Reports.
    </p>
</div>
{% endblock %}
