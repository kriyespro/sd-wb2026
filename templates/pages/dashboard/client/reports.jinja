{% extends "layouts/dashboard.jinja" %}

{% block dashboard_content %}
{% if reports %}
<div class="space-y-6">
    {% for report in reports %}
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <div>
                <h3 class="font-semibold text-brand-950">{{ report.title }}</h3>
                <p class="text-xs text-slate-500">{{ report.project.name }}{% if report.period %} · {{ report.period }}{% endif %}</p>
            </div>
            <span class="text-xs text-slate-400">{{ report.created_at.strftime('%d %b %Y') }}</span>
        </div>
        {% if report.summary %}<p class="mt-3 text-sm text-slate-600">{{ report.summary }}</p>{% endif %}
        {% set metrics = report.metrics.all() %}
        {% if metrics %}
        <div class="mt-4 grid gap-3 sm:grid-cols-3">
            {% for metric in metrics %}
            <div class="rounded-lg bg-slate-50 p-3">
                <p class="text-xs text-slate-500">{{ metric.label }}</p>
                <p class="text-lg font-bold text-brand-950">{{ metric.value }}</p>
                {% if metric.change %}<p class="text-xs font-medium text-green-600">{{ metric.change }}</p>{% endif %}
            </div>
            {% endfor %}
        </div>
        {% endif %}
    </div>
    {% endfor %}
</div>
{% else %}
<div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
    <p class="text-slate-500">No reports available yet.</p>
</div>
{% endif %}
{% endblock %}
