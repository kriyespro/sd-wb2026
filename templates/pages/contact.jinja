{% extends "base.jinja" %}

{% block content %}
<section class="relative overflow-hidden bg-ink-900 py-28 text-white sm:py-36">
    <div class="absolute inset-0 bg-cover bg-center opacity-40" style="background-image: url('{{ site_images.contact_bg }}')"></div>
    <div class="mesh absolute inset-0 opacity-80"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-ink-900 via-ink-900/70 to-ink-900/20"></div>
    <div class="relative mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-brand-200 backdrop-blur">
            <span class="h-1.5 w-1.5 rounded-full bg-accent-400"></span>Let's talk
        </span>
        <h1 class="mx-auto mt-5 max-w-3xl font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl">Book a free strategy call</h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-slate-300">Send us a message and we respond within 24 hours — no obligation.</p>
    </div>
</section>

<section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-2xl border border-slate-200 bg-white p-5 text-center">
                <span class="mx-auto flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-xl">📧</span>
                <p class="mt-3 font-semibold text-ink-900">Email</p>
                <p class="mt-1 text-sm text-slate-600">{{ contact_info.email }}</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-5 text-center">
                <span class="mx-auto flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-xl">📞</span>
                <p class="mt-3 font-semibold text-ink-900">Phone</p>
                <p class="mt-1 text-sm text-slate-600">{{ contact_info.phone }}</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-5 text-center">
                <span class="mx-auto flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-xl">📍</span>
                <p class="mt-3 font-semibold text-ink-900">Address</p>
                <p class="mt-1 text-sm text-slate-600">{{ contact_info.address }}</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-5 text-center">
                <span class="mx-auto flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-xl">🕘</span>
                <p class="mt-3 font-semibold text-ink-900">Hours</p>
                <p class="mt-1 text-sm text-slate-600">{{ contact_info.hours }}</p>
            </div>
        </div>

        <div class="mt-14 grid gap-12 lg:grid-cols-2">
            <div>
                <h2 class="font-display text-2xl font-bold text-ink-900">Let's talk growth</h2>
                <p class="mt-4 text-slate-600">
                    Whether you need SEO, paid ads, a new website, or full-stack growth — we'll help you find the right path.
                </p>
                <div class="mt-8 flex items-center gap-4">
                    <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 text-slate-500 transition hover:border-brand-500 hover:text-brand-600">
                        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12a10 10 0 10-11.5 9.9v-7H8v-2.9h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6v1.9H16l-.4 2.9h-2.1v7A10 10 0 0022 12z"/></svg>
                    </a>
                    <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 text-slate-500 transition hover:border-brand-500 hover:text-brand-600">
                        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.5 2 2 6.5 2 12c0 4.4 2.9 8.2 6.8 9.5.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.1-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.3 1.1 2.9.8.1-.7.4-1.1.6-1.4-2.2-.3-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.5-1.3.1-2.8 0 0 .8-.3 2.7 1a9.4 9.4 0 015 0c1.9-1.3 2.7-1 2.7-1 .5 1.5.2 2.5.1 2.8.6.7 1 1.6 1 2.7 0 3.9-2.4 4.7-4.6 5 .4.3.7 1 .7 2v3c0 .3.2.6.7.5A10 10 0 0022 12c0-5.5-4.5-10-10-10z"/></svg>
                    </a>
                    <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 text-slate-500 transition hover:border-brand-500 hover:text-brand-600">
                        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2V5a2 2 0 00-2-2zM8.3 18H5.7V9.5h2.6V18zM7 8.4a1.5 1.5 0 110-3 1.5 1.5 0 010 3zM18.3 18h-2.6v-4.4c0-1-.4-1.8-1.4-1.8-.8 0-1.3.5-1.5 1-.1.2-.1.5-.1.8V18h-2.6s0-8 0-8.5h2.6v1.2c.3-.5 1-1.4 2.5-1.4 1.8 0 3.1 1.2 3.1 3.7V18z"/></svg>
                    </a>
                </div>
                <p class="mt-6 text-sm font-semibold text-brand-600">Ready when you are — book a free strategy call today.</p>
            </div>
            <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-xl shadow-brand-600/5">
                {% set source_page = 'contact' %}
                {% include "partials/_lead_form.jinja" %}
            </div>
        </div>
    </div>
</section>
{% endblock %}
