{% extends "base.jinja" %}

{% block content %}
<section class="flex min-h-[60vh] items-center py-16">
    <div class="mx-auto max-w-md px-4 text-center">
        <h1 class="font-display text-2xl font-bold text-ink-900">Password updated</h1>
        <p class="mt-4 text-slate-600">You can now sign in with your new password.</p>
        <a href="{{ url('users:login') }}" class="mt-8 inline-block rounded-full bg-brand-600 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-500">Sign in</a>
    </div>
</section>
{% endblock %}
