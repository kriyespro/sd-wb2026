{% extends "base.jinja" %}

{% block content %}
<section class="relative flex min-h-[80vh] items-center overflow-hidden bg-ink-900 py-16">
    <div class="mesh absolute inset-0 opacity-80"></div>
    <div class="relative mx-auto w-full max-w-md px-4">
        <div class="rounded-3xl border border-white/10 bg-white p-8 shadow-2xl">
            <h1 class="font-display text-2xl font-bold text-ink-900">Reset password</h1>
            <p class="mt-2 text-sm text-slate-600">Enter your email and we'll send reset instructions.</p>
            <form method="post" class="mt-8 space-y-4">
                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">Email</label>
                    <input type="email" name="email" required class="wb-input" autocomplete="email">
                </div>
                <button type="submit" class="w-full rounded-full bg-brand-600 px-4 py-3 text-sm font-semibold text-white hover:bg-brand-500">Send reset link</button>
            </form>
            <p class="mt-6 text-center text-sm"><a href="{{ url('users:login') }}" class="text-brand-600 hover:text-brand-700">← Back to sign in</a></p>
        </div>
    </div>
</section>
{% endblock %}
