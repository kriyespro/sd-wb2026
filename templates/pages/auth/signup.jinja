{% extends "base.jinja" %}

{% block content %}
<section class="relative flex min-h-[80vh] items-center overflow-hidden bg-ink-900 py-16">
    <div class="mesh absolute inset-0 opacity-80"></div>
    <div class="grid-lines absolute inset-0 opacity-50"></div>
    <div class="relative mx-auto w-full max-w-md px-4">
        <div class="rounded-3xl border border-white/10 bg-white p-8 shadow-2xl">
            <div class="text-center">
                <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 text-lg font-bold text-white shadow-lg shadow-brand-600/30">WB</span>
                <h1 class="mt-4 font-display text-2xl font-bold text-ink-900">Create account</h1>
                <p class="mt-2 text-sm text-slate-600">Choose your role, then sign up with Google or email</p>
            </div>

            {% if form.non_field_errors() %}
            <div class="mt-6 rounded-lg bg-red-50 p-3 text-sm text-red-700">
                {% for error in form.non_field_errors() %}
                <p>{{ error }}</p>
                {% endfor %}
            </div>
            {% endif %}

            <form method="post" class="mt-8 space-y-4">
                <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token }}">

                <fieldset>
                    <legend class="mb-2 text-sm font-medium text-slate-700">I am joining as</legend>
                    <div class="space-y-2">
                        {% for value, label in form.role.field.choices %}
                        <label class="flex cursor-pointer items-center gap-3 rounded-xl border border-slate-200 px-4 py-3 text-sm transition has-[:checked]:border-brand-500 has-[:checked]:bg-brand-50">
                            <input type="radio" name="role" value="{{ value }}"
                                   class="text-brand-600 focus:ring-brand-500"
                                   {% if form.role.value() == value or (not form.is_bound and selected_role == value) %}checked{% endif %}
                                   required>
                            <span class="font-medium text-ink-900">{{ label }}</span>
                        </label>
                        {% endfor %}
                    </div>
                    {% if form.role.errors %}
                    <p class="mt-1 text-xs text-red-600">{{ form.role.errors[0] }}</p>
                    {% endif %}
                </fieldset>

                <div class="grid gap-4 sm:grid-cols-2">
                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">First name</label>
                        {{ form.first_name }}
                        {% if form.first_name.errors %}<p class="mt-1 text-xs text-red-600">{{ form.first_name.errors[0] }}</p>{% endif %}
                    </div>
                    <div>
                        <label class="mb-1 block text-sm font-medium text-slate-700">Last name</label>
                        {{ form.last_name }}
                    </div>
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">Email</label>
                    {{ form.email }}
                    {% if form.email.errors %}<p class="mt-1 text-xs text-red-600">{{ form.email.errors[0] }}</p>{% endif %}
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">Phone</label>
                    {{ form.phone }}
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">Password</label>
                    {{ form.password1 }}
                    {% if form.password1.errors %}<p class="mt-1 text-xs text-red-600">{{ form.password1.errors[0] }}</p>{% endif %}
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">Confirm password</label>
                    {{ form.password2 }}
                    {% if form.password2.errors %}<p class="mt-1 text-xs text-red-600">{{ form.password2.errors[0] }}</p>{% endif %}
                </div>

                <button type="submit" class="w-full rounded-full bg-brand-600 px-4 py-3 text-sm font-semibold text-white transition hover:bg-brand-500">
                    Create account
                </button>
            </form>

            <div class="relative my-6">
                <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-slate-200"></div></div>
                <div class="relative flex justify-center text-xs uppercase"><span class="bg-white px-2 text-slate-400">Or</span></div>
            </div>

            <a id="google-signup"
               href="{{ url('users:google_start') }}{% if selected_role %}?role={{ selected_role }}{% endif %}"
               class="flex w-full items-center justify-center gap-3 rounded-full border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
                Continue with Google
            </a>
            <p class="mt-2 text-center text-xs text-slate-500">Select a role above first — Google signup uses that role.</p>

            <p class="mt-6 text-center text-sm text-slate-600">
                Already have an account?
                <a href="{{ url('users:login') }}" class="font-semibold text-brand-600 hover:text-brand-700">Sign in</a>
            </p>
            <p class="mt-2 text-center text-xs text-slate-500">
                <a href="{{ url('website:join') }}" class="text-brand-600 hover:text-brand-700">See all join options</a>
            </p>
        </div>
    </div>
</section>
<script>
(function () {
  var link = document.getElementById('google-signup');
  if (!link) return;
  var base = link.getAttribute('href').split('?')[0];
  document.querySelectorAll('input[name="role"]').forEach(function (radio) {
    radio.addEventListener('change', function () {
      link.setAttribute('href', base + '?role=' + encodeURIComponent(radio.value));
    });
  });
})();
</script>
{% endblock %}
