{% extends "base.jinja" %}

{% block content %}
<section class="flex min-h-[60vh] items-center py-16">
    <div class="mx-auto max-w-md px-4 text-center">
        <h1 class="font-display text-2xl font-bold text-ink-900">Check your email</h1>
        <p class="mt-4 text-slate-600">If an account exists for that email, we've sent password reset instructions.</p>
        <a href="{{ url('users:login') }}" class="mt-8 inline-block text-sm font-semibold text-brand-600 hover:text-brand-700">← Back to sign in</a>
    </div>
</section>
{% endblock %}
