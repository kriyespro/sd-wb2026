{% extends "base.jinja" %}

{% block content %}
<section class="relative overflow-hidden bg-ink-900 py-24 text-white">
    <div class="mesh absolute inset-0"></div>
    <div class="grid-lines absolute inset-0 opacity-70"></div>
    <div class="absolute -left-20 top-24 h-72 w-72 rounded-full bg-brand-600/30 blur-3xl animate-float"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-brand-200 backdrop-blur">
            <span class="h-1.5 w-1.5 rounded-full bg-accent-400"></span>Winning Blueprints Academy
        </span>
        <h1 class="mt-6 max-w-3xl font-display text-4xl font-bold leading-[1.08] tracking-tight sm:text-6xl">
            Become an <span class="text-gradient">industry ready</span> digital professional
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-slate-300">
            Don't learn from simulations. Work on real business projects under senior experts.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
            <a href="{{ url('academy:apply') }}" class="btn-accent">Apply Now →</a>
            {% if user.is_authenticated %}
            <a href="{{ url('academy_dashboard:dashboard') }}" class="btn-ghost">Student Dashboard</a>
            {% else %}
            <a href="{{ url('users:login') }}" class="btn-ghost">Student Login</a>
            {% endif %}
        </div>
    </div>
</section>

{% if courses %}
<section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-center text-3xl font-bold text-brand-950">Programs</h2>
        <p class="mt-3 text-center text-slate-600">Industry-focused courses with real project experience.</p>
        <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {% for course in courses %}
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <h3 class="text-lg font-semibold text-brand-950">{{ course.title }}</h3>
                <p class="mt-2 text-sm text-slate-600 line-clamp-3">{{ course.description }}</p>
                <p class="mt-4 text-xs text-slate-500">{{ course.duration_weeks }} weeks</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<section class="bg-slate-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-center text-3xl font-bold text-brand-950">Your Journey</h2>
        <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
            {% for step in academy_process %}
            <div class="flex items-center gap-4">
                <div class="rounded-xl border border-brand-200 bg-white px-5 py-3 text-sm font-semibold text-brand-800">{{ step }}</div>
                {% if not loop.last %}
                <span class="hidden text-brand-400 sm:inline">→</span>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<section class="py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-brand-950">Why Our Academy Is Different</h2>
        <p class="mt-4 text-slate-600 leading-relaxed">
            You're inside a real digital growth company, assigned to teams, working on real client deliverables —
            with mentor review before anything goes out.
        </p>
        <div class="mt-10 grid gap-6 sm:grid-cols-3">
            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <p class="text-2xl">🎯</p>
                <h3 class="mt-3 font-semibold text-brand-950">Real Projects</h3>
                <p class="mt-2 text-sm text-slate-600">Client work, not mock assignments.</p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <p class="text-2xl">👨‍🏫</p>
                <h3 class="mt-3 font-semibold text-brand-950">Senior Mentors</h3>
                <p class="mt-2 text-sm text-slate-600">Learn from industry experts.</p>
            </div>
            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
                <p class="text-2xl">💼</p>
                <h3 class="mt-3 font-semibold text-brand-950">Placement Support</h3>
                <p class="mt-2 text-sm text-slate-600">Portfolio, certs, and job prep.</p>
            </div>
        </div>
    </div>
</section>

<section class="relative overflow-hidden bg-ink-900 py-20 text-white">
    <div class="mesh absolute inset-0 opacity-70"></div>
    <div class="relative mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="font-display text-2xl font-bold sm:text-3xl">Ready to start?</h2>
        <p class="mt-4 text-slate-300">Submit your admission application. We respond within 48 hours.</p>
        <a href="{{ url('academy:apply') }}" class="btn-accent mt-8">Apply to Academy →</a>
    </div>
</section>
{% endblock %}
