{% extends "base.jinja" %}

{% block content %}
<!-- HERO -->
<section class="bg-brand-900 py-12 text-white sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-6 flex flex-wrap gap-2 text-xs font-semibold uppercase tracking-wide">
            <span class="rounded-full border border-white/20 bg-white/10 px-3 py-1 text-gold-300">Verified Curriculum</span>
            <span class="rounded-full border border-white/20 bg-white/10 px-3 py-1">{{ course.rating }} Rated</span>
            {% if course.salary_range %}
            <span class="rounded-full border border-white/20 bg-white/10 px-3 py-1">{{ course.salary_range }} potential</span>
            {% endif %}
            <span class="rounded-full border border-white/20 bg-white/10 px-3 py-1">Lifetime Access</span>
        </div>
        <p class="text-sm text-slate-400">
            <a href="{{ url('academy:courses') }}" class="hover:text-gold-300">Courses</a> / {{ course.level }}
        </p>
        <h1 class="mt-3 max-w-4xl font-display text-3xl font-bold sm:text-5xl">{{ course.title }}</h1>
        <p class="mt-5 max-w-3xl text-lg leading-relaxed text-slate-300">{{ course.goal }}</p>

        <div class="mt-8 grid gap-8 lg:grid-cols-3 lg:items-start">
            <div class="space-y-4 lg:col-span-2">
                <ul class="space-y-2 text-sm text-slate-300">
                    {% if course.modules_count %}
                    <li>{{ course.modules_count }} structured modules covering practical, job-ready skills</li>
                    {% endif %}
                    <li>Earn a verified Winning Blueprints certificate to strengthen your portfolio</li>
                    {% if course.salary_range %}
                    <li>{{ course.salary_range }} career potential in India-focused roles</li>
                    {% endif %}
                </ul>
                <div class="flex flex-wrap items-center gap-4 text-sm text-slate-400">
                    <span>{{ course.enrolled }}+ learners enrolled</span>
                    <span>{{ course.rating }} ({{ course.reviews_count }} reviews)</span>
                </div>

                <div class="mt-8 rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur sm:p-8">
                    <div class="flex items-center gap-3">
                        <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gold-500/15 text-gold-300">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                        </span>
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gold-300/80">What you'll gain</p>
                            <h2 class="mt-1 font-display text-2xl font-bold text-white">Practical outcomes from this program</h2>
                        </div>
                    </div>
                    <div class="mt-6 grid gap-4 sm:grid-cols-3">
                        {% for gain in course.gains %}
                        <div class="rounded-2xl border border-white/10 bg-brand-950/30 p-5">
                            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-gold-400 text-sm font-bold text-ink-900">{{ loop.index }}</span>
                            <p class="mt-4 text-sm leading-relaxed text-slate-200">{{ gain }}</p>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur lg:-mt-[160px]">
                <img src="{{ course.image }}" alt="{{ course.title }}" class="mb-4 h-36 w-full rounded-xl object-cover">
                <div class="font-display text-3xl font-bold text-gold-400">{{ course.price }}</div>
                {% if course.salary_range %}
                <p class="mt-1 text-sm text-gold-200/80">↑ {{ course.salary_range }} salary</p>
                {% endif %}
                <div class="mt-5 space-y-2">
                    <a href="{{ url('academy:apply') }}" class="btn-gold w-full text-center">Get started free</a>
                    <a href="{{ url('users:login') }}" class="btn-outline !border-white/30 !text-white hover:!bg-white/10 w-full text-center">Log in</a>
                </div>
                <dl class="mt-6 space-y-2 text-sm">
                    <div class="flex justify-between"><dt class="text-slate-400">Type</dt><dd>{{ course.level }}</dd></div>
                    <div class="flex justify-between"><dt class="text-slate-400">Duration</dt><dd>{{ course.duration }}</dd></div>
                    <div class="flex justify-between"><dt class="text-slate-400">Format</dt><dd>{{ course.format }}</dd></div>
                    {% if course.modules_count %}
                    <div class="flex justify-between"><dt class="text-slate-400">Modules</dt><dd>{{ course.modules_count }}</dd></div>
                    {% endif %}
                </dl>
            </div>
        </div>
    </div>
</section>

<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-3">
        <div class="space-y-16 lg:col-span-2">

            <!-- WHAT YOU'LL LEARN -->
            <section>
                <h2 class="font-display text-2xl font-bold text-ink-900">What you'll learn</h2>
                <p class="mt-2 text-sm text-slate-500">{{ course.modules_count }} modules · {{ course.topics_count }} topics covered</p>
                <div class="mt-6 grid gap-3 sm:grid-cols-2">
                    {% for mod in course.learn_modules %}
                    <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-medium text-ink-900">{{ mod }}</div>
                    {% endfor %}
                </div>
            </section>

            <!-- OVERVIEW -->
            <section>
                <h2 class="font-display text-2xl font-bold text-ink-900">Program overview</h2>
                <div class="mt-6 space-y-4 text-slate-600 leading-relaxed">
                    {% for para in course.overview %}
                    <p>{{ para }}</p>
                    {% endfor %}
                </div>
            </section>

            <!-- CURRICULUM -->
            <section id="curriculum">
                <h2 class="font-display text-2xl font-bold text-ink-900">Course curriculum</h2>
                <p class="mt-2 text-sm text-slate-500">
                    {{ course.modules_count }} modules · {{ course.topics_count }} topics · first 2 modules free preview
                </p>
                <div class="mt-6 space-y-3" x-data="{ open: 1 }">
                    {% for mod in course.curriculum %}
                    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white">
                        <button type="button" @click="open = open === {{ loop.index }} ? 0 : {{ loop.index }}"
                                class="flex w-full items-center justify-between gap-4 px-5 py-4 text-left">
                            <div class="flex items-center gap-4">
                                <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-100 text-sm font-bold text-brand-700">{{ loop.index }}</span>
                                <div>
                                    <div class="text-xs text-slate-400">Module {{ loop.index }}</div>
                                    <div class="font-semibold text-ink-900">{{ mod.title }}</div>
                                </div>
                            </div>
                            <div class="flex items-center gap-3">
                                {% if mod.free_preview %}
                                <span class="rounded-full bg-gold-100 px-2.5 py-0.5 text-xs font-semibold text-gold-700">Free preview</span>
                                {% endif %}
                                <span class="text-xs text-slate-400">{{ mod.topics|length }} topics</span>
                                <svg class="h-4 w-4 text-slate-400 transition" :class="open === {{ loop.index }} ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                            </div>
                        </button>
                        <div x-show="open === {{ loop.index }}" x-cloak x-transition class="border-t border-slate-100 px-5 py-4">
                            <ol class="space-y-2 text-sm text-slate-600">
                                {% for topic in mod.topics %}
                                <li class="flex gap-2"><span class="text-slate-300">{{ loop.index }}.</span>{{ topic }}</li>
                                {% endfor %}
                            </ol>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </section>

            {% if course.career %}
            <!-- CAREER -->
            <section>
                <h2 class="font-display text-2xl font-bold text-ink-900">Career outcomes</h2>
                <p class="mt-2 text-sm text-slate-500">Expected salary · India market 2025</p>
                <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-8 text-center">
                    <div class="font-display text-3xl font-bold text-brand-700">{{ course.salary_range }}</div>
                    <p class="mt-1 text-sm text-slate-500">Lakh Per Annum · {{ course.career.label }}</p>
                    <div class="mx-auto mt-6 flex max-w-xs justify-between text-sm font-semibold text-ink-900">
                        <span>{{ course.career.min }}<br><span class="text-xs font-normal text-slate-500">Entry</span></span>
                        <span>{{ course.career.max }}<br><span class="text-xs font-normal text-slate-500">Senior</span></span>
                    </div>
                </div>
                <h3 class="mt-8 font-semibold text-ink-900">Job roles you can apply for</h3>
                <div class="mt-4 flex flex-wrap gap-2">
                    {% for role in course.ideal_paths %}
                    <span class="rounded-full border border-brand-200 bg-brand-50 px-3 py-1.5 text-sm text-brand-800">{{ role }}</span>
                    {% endfor %}
                </div>
            </section>
            {% endif %}

            {% if course.reviews %}
            <!-- REVIEWS -->
            <section>
                <h2 class="font-display text-2xl font-bold text-ink-900">Student success stories</h2>
                <p class="mt-2 text-sm text-slate-500">{{ course.rating }} / 5.0 from {{ course.reviews_count }} students</p>
                <div class="mt-6 space-y-4">
                    {% for review in course.reviews %}
                    <blockquote class="rounded-2xl border border-slate-200 bg-white p-6">
                        <p class="text-sm leading-relaxed text-slate-600">"{{ review.quote }}"</p>
                        <footer class="mt-4 flex items-center gap-3">
                            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-700 text-sm font-bold text-gold-300">{{ review.name[0] }}</span>
                            <div>
                                <div class="text-sm font-semibold text-ink-900">{{ review.name }}</div>
                                <div class="text-xs text-slate-500">{{ review.role }} · {{ review.city }}</div>
                            </div>
                        </footer>
                    </blockquote>
                    {% endfor %}
                </div>
            </section>
            {% endif %}
        </div>

        <!-- SIDEBAR -->
        <aside class="lg:col-span-1">
            <div class="sticky top-28 space-y-6">
                <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-lg">
                    <h3 class="font-display font-bold text-ink-900">{{ course.title }}</h3>
                    <p class="mt-2 font-display text-2xl font-bold text-brand-700">{{ course.price }}</p>
                    <ul class="mt-5 space-y-2 text-sm text-slate-600">
                        {% for item in course.includes %}
                        <li class="flex gap-2"><span class="text-gold-500">✓</span>{{ item }}</li>
                        {% endfor %}
                    </ul>
                    <a href="{{ url('academy:apply') }}" class="btn-gold mt-6 w-full text-center">Sign up &amp; enroll</a>
                </div>

                {% if course.highlight_quote %}
                <blockquote class="rounded-2xl border border-slate-200 bg-slate-50 p-5 text-sm italic text-slate-600">
                    "{{ course.highlight_quote }}"
                    <footer class="mt-3 not-italic text-xs font-semibold text-ink-900">— {{ course.highlight_author }}</footer>
                </blockquote>
                {% endif %}

                <div class="rounded-2xl border border-slate-200 bg-white p-5 text-sm">
                    <p class="font-semibold text-ink-900">Starts with</p>
                    <p class="mt-1 text-slate-600">{{ course.starts_with }}</p>
                    <a href="#curriculum" class="mt-3 inline-block text-brand-600 hover:text-brand-700">Browse full curriculum →</a>
                </div>
            </div>
        </aside>
    </div>
</div>

{% if other_courses %}
<section class="border-t border-slate-200 bg-slate-50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="font-display text-2xl font-bold text-ink-900">More programs</h2>
        <div class="mt-8 grid gap-6 md:grid-cols-3">
            {% for c in other_courses %}
            {% set course = c %}
            {% include "partials/academy/_course_card.jinja" %}
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

<section class="bg-brand-900 py-16 text-white">
    <div class="mx-auto max-w-2xl px-4 text-center">
        <h2 class="font-display text-2xl font-bold">Ready to get started?</h2>
        <p class="mt-3 text-slate-300">Apply to Winning Blueprints Academy and enroll in minutes.</p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
            <a href="{{ url('academy:apply') }}" class="btn-gold">Sign up free →</a>
            <a href="{{ url('users:login') }}" class="btn-outline !border-white/30 !text-white hover:!bg-white/10">Log in</a>
        </div>
    </div>
</section>
{% endblock %}
