<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ page_title }} | {{ site_name }}{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}{{ meta_description|default(site_tagline) }}{% endblock %}">
    {% include "components/head_assets.jinja" %}
    {% block extra_head %}{% endblock %}
</head>
<body class="bg-white font-sans text-slate-600 antialiased" hx-headers='{"X-CSRFToken": "{{ csrf_token }}"}'>
    {% include "components/nav.jinja" %}
    <main>
        {% block content %}{% endblock %}
    </main>
    {% include "components/footer.jinja" %}
    {% block extra_js %}{% endblock %}
</body>
</html>
