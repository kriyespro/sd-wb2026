<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ page_title }} | {{ portal_name|default('Dashboard') }}{% endblock %}</title>
    {% include "components/head_assets.jinja" %}
    {% block extra_head %}{% endblock %}
</head>
<body class="bg-slate-50 font-sans text-slate-800 antialiased" hx-headers='{"X-CSRFToken": "{{ csrf_token }}"}'>
    <div x-data="{ sidebarOpen: false }" class="flex min-h-screen">
        {% include "components/dashboard_sidebar.jinja" %}

        <div class="flex min-w-0 flex-1 flex-col">
            <header class="sticky top-0 z-30 border-b border-slate-200/80 bg-white/90 px-4 py-3 backdrop-blur-xl sm:px-6">
                <div class="flex items-center justify-between gap-4">
                    <div class="flex items-center gap-3">
                        <button @click="sidebarOpen = true" class="rounded-xl p-2 text-slate-600 hover:bg-slate-100 md:hidden" aria-label="Open menu">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                        </button>
                        <div>
                            <h1 class="font-display text-lg font-semibold text-ink-900">{{ page_title }}</h1>
                            <p class="text-xs text-slate-500">Welcome back, {{ user.get_full_name() or user.username }}</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 sm:gap-3">
                        <span class="hidden rounded-full bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700 sm:inline-flex">
                            {{ user.profile.get_role_display() }}
                        </span>
                        <a href="{{ url('website:home') }}" class="hidden text-sm text-slate-500 transition hover:text-brand-600 sm:inline">Public Site</a>
                        <a href="{{ url('users:logout') }}" class="rounded-full border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-600 transition hover:border-red-200 hover:bg-red-50 hover:text-red-600">Logout</a>
                    </div>
                </div>
            </header>

            <main class="flex-1 p-4 sm:p-6">
                {% if messages %}
                <div class="mb-4 space-y-2">
                    {% for message in messages %}
                    <div class="rounded-xl border px-4 py-3 text-sm
                        {% if message.tags == 'error' %}border-red-200 bg-red-50 text-red-800
                        {% elif message.tags == 'success' %}border-emerald-200 bg-emerald-50 text-emerald-800
                        {% else %}border-slate-200 bg-slate-50 text-slate-700{% endif %}">
                        {{ message }}
                    </div>
                    {% endfor %}
                </div>
                {% endif %}
                {% block dashboard_content %}{% endblock %}
            </main>
        </div>
    </div>
    {% block extra_js %}{% endblock %}
</body>
</html>
