# Django
DJANGO_ENV=dev
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave DATABASE_URL empty for SQLite)
# DATABASE_URL=postgres
# POSTGRES_DB=winningblueprints
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=winningblueprints@gmail.com
LEAD_NOTIFICATION_EMAIL=winningblueprints@gmail.com
EMAIL_HOST_USER=winningblueprints@gmail.com

# Google OAuth (never commit real secrets — put values in .env / .env.prod only)
# Redirect URIs: http://localhost:8000/accounts/google/login/callback/
#                https://winningblueprints.com/accounts/google/login/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Production only
# SECURE_SSL_REDIRECT=True
# CSRF_TRUSTED_ORIGINS=https://winningblueprints.in,https://www.winningblueprints.in
